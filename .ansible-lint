---
profile: production

exclude_paths:
  - .git/
  - .github/
  - "*.log"
  - "ansible/vars/secrets.yml"
  - "ansible/collections/"
  # Claude Code creates git worktrees under .claude/worktrees/<name>/, each a FULL repo
  # checkout — including its own copy of the vendored ansible/collections/ whose changelog
  # YAMLs trip yaml[indentation]. The root `ansible/collections/` exclude above only matches
  # the primary worktree's copy, so the whole subtree must be excluded here (ansible-lint walks
  # the filesystem, not git). Without this, ANY staged .yml fails the full-repo lint hook.
  - ".claude/worktrees/"

skip_list:
  - no-changed-when
  - yaml[line-length]
  # Role dirs are intentionally hyphenated to mirror their container/compose service
  # names (home-assistant, docker-proxy, wg-easy, ...) and deploy tags derive from the
  # name, so renaming would cascade through containers_list/host_vars/tags. ansible-lint
  # v26.6.0 tightened role-name to reject hyphens (^[a-z][a-z0-9_]*$) — skip it, don't rename.
  - role-name

offline: false
