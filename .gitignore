# Ignore everything except ansible and docs
/*
!/ansible
!/docs
!/scripts
!/docker-cloudflare-ddns
!prek.toml
!.ansible-lint
!ansible.cfg
!/.vscode
!/.github
!/README.md
!/renovate.json
!/pyproject.toml
!/uv.lock
!/.python-version
# Make sure these are ignored
ansible/.env
scripts/availability_bots/.env
ansible/.aws
ansible/.ansible
ansible/collections
ansible/roles/containers/code-server/templates/github
ansible/roles/foundry/files/*.zip
*.pyc
__pycache__/
.pytest_cache/
# Never commit private key material — defense-in-depth alongside the gitleaks
# pre-commit hook. These patterns have no leading slash, so they match in ANY
# directory, including the allowlisted ansible/ tree where a stray key would
# otherwise slip past the top-level /* deny rule.
keys.txt
*.agekey
*.pem
*.key
id_rsa
id_ed25519
!/CLAUDE.md
!/.claude
# Claude Code machine-local files live under the allowlisted .claude/ tree but are
# per-machine state (local settings/permissions, session buffers) — never commit them.
# The global ~/.config/git/ignore catches settings.local.json on this host; codify it
# in-repo too so a fresh clone is protected without relying on each machine's git config.
.claude/*.local.json
.claude/*.local.md
