# Ignore everything except ansible and docs
/*
!/ansible
!/docs
!/scripts
!/evals
# Email-to-RSS Cloudflare Worker — tracked as a git submodule (see .gitmodules);
# its own .gitignore keeps wrangler.toml (KV ids) and node_modules local-only.
!/Email-to-RSS
!/.gitmodules
!prek.toml
!.ansible-lint
!/.gitleaks.toml
!ansible.cfg
!/.vscode
!/.github
!/README.md
!/renovate.json
!/pyproject.toml
!/uv.lock
!/.python-version
!/PLANS.md
# Track the SOPS-aware diff-driver attribute for secrets.yml. NB: rendering the
# decrypted diff also requires a per-machine `git config diff.sops.textconv`,
# which isn't set here yet — so this attribute is currently a no-op.
!/.gitattributes
# Make sure these are ignored
ansible/.env
scripts/availability_bots/.env
ansible/.aws
ansible/.ansible
ansible/collections
ansible/roles/containers/code-server/templates/github
*.pyc
__pycache__/
.pytest_cache/
# Never commit private key material — defense-in-depth alongside the gitleaks
# pre-commit hook. These patterns have no leading slash, so they match in ANY
# directory, including the allowlisted ansible/ tree where a stray key would
# otherwise slip past the top-level /* deny rule.
keys.txt
*.agekey
*.pem
*.key
id_rsa
id_ed25519
!/CLAUDE.md
!/.claude
# Claude Code machine-local files live under the allowlisted .claude/ tree but are
# per-machine state (local settings/permissions, session buffers) — never commit them.
# The global ~/.config/git/ignore catches settings.local.json on this host; codify it
# in-repo too so a fresh clone is protected without relying on each machine's git config.
.claude/*.local.json
.claude/*.local.md
# Backup written by `audit-permissions.py --prune-dead` before it rewrites the local allowlist.
.claude/*.local.json.bak
# Permission-audit hook store — per-host runtime state written by
# .claude/hooks/log-permission.py; counts are machine-local by design.
.claude/logs/
