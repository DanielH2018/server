{
    "ansible.python.interpreterPath": "/bin/python3",
    "ansible.validation.enabled": true,
    "ansible.validation.lint.enabled": true,
    "ansible.validation.lint.arguments": "--config-file ansible/.ansible-lint",
    "files.exclude": {
        "containers/code-server/config/extensions": true,
        "Email-to-RSS": true
    },
    "search.exclude": {
        "containers/code-server/config/extensions": true,
        "Email-to-RSS": true
    },
    "files.associations": {
        "*.yml.j2": "jinja-yaml"
    }
}
