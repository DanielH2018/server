{
  "disableClaudeAiConnectors": true,
  "permissions": {
    "allow": [
      "Bash(ansible-lint *)",
      "Bash(git check-ignore *)",
      "Bash(uv run python scripts/probe.py:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/server/.claude/hooks/auto-approve-readonly.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/server/.claude/hooks/block-protected-edits.sh"
          }
        ]
      },
      {
        "matcher": "^(Bash|Write|Edit|WebFetch|WebSearch|Task|Agent|Skill|mcp__.*)$",
        "hooks": [
          {
            "type": "command",
            "command": "~/server/.claude/hooks/log-permission.sh",
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/server/.claude/hooks/log-permission.sh",
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/server/.claude/hooks/log-permission.sh",
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/ubuntu/server/.claude/hooks/ansible-lint.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash /home/ubuntu/server/.claude/hooks/validate-compose.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/server/.claude/hooks/log-instructions.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/server/.claude/hooks/session-health.sh",
            "timeout": 15
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "claude-permission-audit@daniel-tools": false
  }
}
