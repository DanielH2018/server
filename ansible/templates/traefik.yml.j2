{% macro labels(container, port, docker_network, authelia, extra_middlewares='') -%}
      - "traefik.enable=true"
      - "traefik.docker.network={{ docker_network }}"
      - "traefik.http.routers.{{ container }}.entrypoints=http"
      - "traefik.http.routers.{{ container }}.rule=Host(`{{ container }}.{{ domain }}`) || Host(`{{ container }}.local.{{ domain }}`)"
      - "traefik.http.routers.{{ container }}-secure.entrypoints=https"
      - "traefik.http.routers.{{ container }}-secure.rule=Host(`{{ container }}.{{ domain }}`) || Host(`{{ container }}.local.{{ domain }}`)"
      - "traefik.http.routers.{{ container }}-secure.tls=true"
      - "traefik.http.routers.{{ container }}-secure.tls.certresolver=cloudflare"
      - "traefik.http.routers.{{ container }}-secure.tls.domains[0].main={{ domain }}"
      - "traefik.http.routers.{{ container }}-secure.tls.domains[0].sans=*.{{ domain }},*.local.{{ domain }}"
      - "traefik.http.routers.{{ container }}-secure.service={{ container }}"
      - "traefik.http.services.{{ container }}.loadbalancer.server.port={{ port }}"
      {% if authelia -%}
      - "traefik.http.routers.{{ container }}-secure.middlewares=rate-limit@file,authelia@docker{% if extra_middlewares %},{{ extra_middlewares }}{% endif %}"
      {%- else -%}
      - "traefik.http.routers.{{ container }}-secure.middlewares=rate-limit@file{% if extra_middlewares %},{{ extra_middlewares }}{% endif %}"
      {%- endif %}
{%- endmacro %}
