{% from 'traefik.yml.j2' import labels with context %}
---
version: "3.8"
services:
  bazarr:
    image: lscr.io/linuxserver/bazarr:latest
    container_name: bazarr
    environment:
      - PUID={{ PUID }}
      - PGID={{ PGID }}
      - TZ={{ TZ }}
    volumes:
      - /etc/localtime:/etc/localtime:ro
      - ./config:/config
      - /home/{{ SYS_USER }}/server/data/media/tv:/tv
      - /home/{{ SYS_USER }}/server/data/media/movies:/movies
      - /home/{{ SYS_USER }}/server/data/downloads:/downloads
    ports:
      - 6767:6767
    restart: unless-stopped
    networks:
      - {{ DOCKER_NETWORK }}
    healthcheck:
      test: curl --fail -s http://localhost:6767/ || exit 1
      interval: 30s
      timeout: 10s
      retries: 3
    labels:
      # Enable traefik for container
      - "traefik.enable=true"
      # Use traefik network
      - "traefik.docker.network={{ DOCKER_NETWORK }}"

      {# Generate labels(container_name, port, use_authelia) -#}
      {{ labels(container, '6767', 'y') }}

networks:
  {{ DOCKER_NETWORK }}:
    external: true