{% from 'traefik.yml.j2' import labels with context %}
---
version: "3.8"
services:
  grafana:
    image: grafana/grafana:latest
    container_name: grafana
    user: "{{ PUID }}"
    restart: unless-stopped
    volumes:
      - ./:/var/lib/grafana
    ports:
     - 3000:3000
    networks:
      - {{ DOCKER_NETWORK }}
    healthcheck:
      test: wget --no-verbose --tries=1 --spider http://localhost:3000/ || exit 1
      interval: 30s
      timeout: 10s
      retries: 3
    labels:
      # Enable traefik for container
      - "traefik.enable=true"
      # Use traefik network
      - "traefik.docker.network={{ DOCKER_NETWORK }}"

      {# Generate labels(container_name, port, use_authelia) -#}
      {{ labels(container, '3000', 'y') }}
      # Watchtower
      - "com.centurylinklabs.watchtower.depends-on: prometheus"
  loki:
    image: grafana/loki
    container_name: loki
    restart: unless-stopped
    environment:
      - TZ={{ TZ }}
    expose:
      - 3100
    volumes:
      - ./loki-config.yaml:/etc/loki/loki-config.yaml:ro
      - loki:/tmp
    command: -config.file=/etc/loki/loki-config.yaml
    networks:
      - {{ DOCKER_NETWORK }}
  promtail:
    image: grafana/promtail
    container_name: promtail
    restart: unless-stopped
    environment:
      - TZ={{ TZ }}
    volumes:
      - ./promtail-config.yaml:/etc/promtail/promtail-config.yaml:ro
      - /var/log/:/logs
    command: -config.file=/etc/promtail/promtail-config.yaml
    networks:
      - {{ DOCKER_NETWORK }}

networks:
  {{ DOCKER_NETWORK }}:
    external: true

volumes:
    loki:
