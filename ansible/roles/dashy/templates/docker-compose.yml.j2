{% from 'traefik.yml.j2' import labels with context %}
---
version: "3.8"
services:
  dashy:
    container_name: dashy
    image: lissy93/dashy
    volumes:
      - ./local-conf.yml:/app/public/conf.yml
    ports:
      - 4000:80
    environment:
      - PUID={{ PUID }}
      - PGID={{ PGID }}
      - TZ={{ TZ }}
    restart: unless-stopped
    healthcheck:
      test: ['CMD', 'node', '/app/services/healthcheck']
      interval: 1m30s
      timeout: 10s
      retries: 3
      start_period: 40s
    networks:
      - {{ DOCKER_NETWORK }}
    labels:
      # Enable traefik for container
      - "traefik.enable=true"
      # Use traefik network
      - "traefik.docker.network={{ DOCKER_NETWORK }}"

      {# Generate labels(container_name, port, use_authelia) -#}
      {{ labels(container, '80', 'y') }}

networks:
  {{ DOCKER_NETWORK }}:
    external: true
