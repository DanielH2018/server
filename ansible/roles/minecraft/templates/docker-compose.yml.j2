version: '3.8'
services:
  minecraft:
    image: itzg/minecraft-server
    container_name: minecraft
    environment:
      EULA: "true"
      ENABLE_RCON: "true"
      TYPE: PAPER
      VIEW_DISTANCE: 10
      MEMORY: 750m
      CONSOLE: "false"
      ENABLE_AUTOPAUSE: "TRUE"
      TZ: {{ env.TZ }}
    ports:
      - 25566:25565
    volumes:
      - /home/{{ env.SYS_USER }}/server/minecraft/data:/data
    restart: unless-stopped
