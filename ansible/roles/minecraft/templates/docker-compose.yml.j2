version: '3.8'
services:
  minecraft:
    image: itzg/minecraft-server:latest
    container_name: minecraft
    environment:
      EULA: "true"
      TYPE: FABRIC
      ENABLE_RCON: "false"
      VIEW_DISTANCE: 15
      MEMORY: 16G
      CONSOLE: "false"
      #ENABLE_AUTOPAUSE: "TRUE"
      TZ: {{ TZ }}
      VERSION: "1.21.8"
      ENABLE_COMMAND_BLOCK: "true"
      SPAWN_PROTECTION: 0
      ALLOW_FLIGHT: "TRUE"
      WHITELIST: |
        DBoy13
        hannahcevs
        CryingPie
        Hei_Jman
        PoutyPicklez # Anna
        handel6619 # Nick
        LordAlpaca57 # Marco
        V1RuSWasNotTaken
        Haovk 
        DittoHippo11 # Sophie
        CurrentlyBroke # IDK
    ports:
      - 25565:25565
    volumes:
      - ./data:/data
    restart: unless-stopped
