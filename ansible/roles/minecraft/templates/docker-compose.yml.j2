version: '3.8'
services:
  minecraft:
    image: itzg/minecraft-server
    container_name: minecraft
    environment:
      EULA: "true"
      ENABLE_RCON: "false"
      TYPE: PAPER
      VIEW_DISTANCE: 15
      MEMORY: 6G
      CONSOLE: "false"
      ENABLE_AUTOPAUSE: "TRUE"
      TZ: {{ TZ }}
    ports:
      - 25565:25565
    volumes:
      - /home/{{ SYS_USER }}/server/minecraft/data:/data
    restart: unless-stopped
