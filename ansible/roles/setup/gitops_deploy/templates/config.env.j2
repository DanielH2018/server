REPO_DIR=/home/{{ sys_user }}/server
BRANCH=master
HEALTH_TIMEOUT_S=300
# Wall-clock budget for the health-gate phase (see gitops_deploy.py RUN_BUDGET_S). RUN_START is
# measured AFTER flock acquires (gitops-deploy.service ExecStart), but TimeoutStartSec (25min=1500s)
# counts from unit activation and so INCLUDES up to the `flock -w 180` wait. Budget for the worst
# case: 180 (max flock wait) + 1020 (this gate) + 300 (HEALTH_TIMEOUT_S rollback redeploy) = 1500, so
# the ~5min rollback window survives even under max lock contention with the weekly secret-rotate.
RUN_BUDGET_S=1020
DISCORD_WEBHOOK={{ gitops_deploy_discord_webhook }}
