#!/usr/bin/env bash
# Weekly unattended rotation of DUE auto-tier secrets — managed by Ansible; edits overwritten.
#
# Rotates only `auto` push tokens that (a) are past their staggered due-date and (b) have a
# single-redeploy consumer (monitor-bridge / cloudflare-ddns). Cross-host tokens stay manual.
# Because due-dates are staggered, most weeks this rotates 0-2 tokens. On any failure it
# REVERTS the working tree (so a half-rotated secret is never left committed) and alerts via
# the "Secret Rotation" Kuma monitor.
set -uo pipefail

REPO=/home/{{ sys_user }}/server
# sops lives in /usr/local/bin (outside cron's PATH); uv resolves ansible from the pinned env.
export PATH=/usr/local/bin:/usr/bin:/bin:/home/{{ sys_user }}/.local/bin
UV=/home/{{ sys_user }}/.local/bin/uv
KUMA="https://uptime-kuma.local.{{ domain }}/api/push/{{ secret_rotation_push_token }}"
# Array (not a plain string) so each path survives as its own argument below without
# relying on unquoted word-splitting (shellcheck SC2086).
TRACKED=(ansible/vars/secrets.yml ansible/secret_rotation.yml)

cd "$REPO" || exit 1

alert() { curl -fsS --max-time 10 -G "$KUMA" --data-urlencode "status=down" \
            --data-urlencode "msg=$1" >/dev/null 2>&1 || true; logger -t secret-rotate "$1"; }
revert() { git checkout -- "${TRACKED[@]}" 2>/dev/null || true; }

# Serialize against the GitOps deployer — both mutate this same working tree, and gitops's
# `git reset --hard` on a failed deploy would silently discard a concurrent half-rotation here.
# flock makes every git-tree mutation mutually exclusive; fd 9 is held for the script's life.
exec 9>/var/lock/server-git-tree.lock
flock -w 1200 9 || { alert "secret-rotate: git-tree lock held >20m (gitops deploy stuck?) — skipped"; exit 1; }

# Start from a clean, current tree — a dirty tree means a prior failure to investigate.
if [ -n "$(git status --porcelain "${TRACKED[@]}")" ]; then
  alert "secret-rotate aborted: working tree dirty (manual review needed)"; exit 1
fi
git pull --rebase --autostash >/dev/null 2>&1 || { alert "secret-rotate: git pull failed"; exit 1; }

# Rotate + redeploy consumers. On failure, discard the partial change and alert.
# --frozen: install from the committed uv.lock, never rewrite it on the host — a lock rewrite
# would dirty the tree and wedge the GitOps deployer's dirty-skip (matches gitops_deploy's deploy()).
if ! $UV run --frozen python scripts/secret_rotation.py rotate --commit --deploy; then
  revert; alert "secret-rotate: rotate/deploy failed — reverted"; exit 1
fi

if [ -n "$(git status --porcelain "${TRACKED[@]}")" ]; then
  git add "${TRACKED[@]}"
  # --no-verify skips the prek pre-commit chain: this is a mechanical two-file `sops set` commit
  # and the chain's ansible-lint step does a network galaxy-install, so a transient flake there
  # would abort the commit. The rotation is ALREADY live in the container by now, so a failed
  # commit must be caught (never fall through to the misleading success log) but must NOT be
  # reverted — discarding it would strand the live-but-uncommitted new value. CI re-validates the
  # push server-side. Without this guard the abort left the tree dirty and false-logged success,
  # wedging the GitOps deployer's dirty-skip with no signal.
  if git -c user.name="secret-rotate" -c user.email="{{ email }}" \
      commit --no-verify -m "chore(secrets): auto-rotate due auto-tier push tokens" >/dev/null; then
    if git push >/dev/null 2>&1; then
      logger -t secret-rotate "rotated + deployed + pushed due auto-tier tokens"
    else
      alert "secret-rotate: rotated + deployed but git push FAILED (commit is local)"
    fi
  else
    alert "secret-rotate: rotated + deployed but git commit FAILED — tree left dirty, commit by hand"
  fi
fi
