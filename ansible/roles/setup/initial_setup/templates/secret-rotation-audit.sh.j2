#!/usr/bin/env bash
# Daily secret-rotation audit — managed by Ansible (initial_setup); edits overwritten.
#
# Runs scripts/secret_rotation.py audit --push, which reads the rotation registry
# (ansible/secret_rotation.yml) and pushes up/down to the "Secret Rotation" Kuma monitor:
# DOWN when any secret is past its per-tier rotation window, or when a secret exists in
# secrets.yml but not the registry (reminding the operator to `secret_rotation.py sync`
# + commit). Read-only by design — the cron never edits the git-tracked registry, so git
# stays the source of truth; rotation is an explicit operator action.
#
# Mode 0700: the Kuma push URL embeds the monitor token. Pushes through the LAN-only
# Authelia bypass on ^/api/push/ (uptime-kuma.local.<domain> → split-horizon → 10.x).
set -uo pipefail

export SECRET_ROTATION_KUMA="https://uptime-kuma.local.{{ domain }}/api/push/{{ secret_rotation_push_token }}"
cd /home/{{ sys_user }}/server || exit 1

# A prior weekly secret-rotate that failed to COMMIT (tree left dirty) or to PUSH (local ahead of
# origin) leaves real un-actioned rotation state — but it shares THIS "Secret Rotation" monitor, so
# the normal audit below would push UP and mask secret-rotate's own DOWN within ~23h (2026-07-15
# review L4). Short-circuit to a sticky DOWN here instead — this is the only durable signal once the
# weekly page ages out. (rotate/pull failures REVERT to a clean tree and are legitimately transient,
# so they don't trip this.)
TRACKED=(ansible/vars/secrets.yml ansible/secret_rotation.yml)
if [ -n "$(git status --porcelain "${TRACKED[@]}" 2>/dev/null)" ]; then
  reason="secret-rotate left uncommitted changes in secrets.yml/registry — commit by hand"
# Scope the unpushed check to TRACKED (mirroring the dirty check above): an operator's
# fix-forward-local commit that doesn't touch secrets.yml/registry shouldn't flip the Secret
# Rotation monitor DOWN with a rotation-blaming message — only a genuinely unpushed rotation
# commit should (2026-07-15 review L3).
elif [ "$(git rev-list --count '@{u}..HEAD' -- "${TRACKED[@]}" 2>/dev/null || echo 0)" != 0 ]; then
  reason="a local rotation commit touching secrets.yml/registry is unpushed (secret-rotate push failed?) — push by hand"
fi
if [ -n "${reason:-}" ]; then
  curl -fsS --max-time 10 -G "$SECRET_ROTATION_KUMA" --data-urlencode "status=down" \
       --data-urlencode "msg=$reason" >/dev/null 2>&1 || true
  logger -t secret-rotation-audit "$reason"
  exit 0
fi

# uv (absolute path — cron's PATH lacks it) syncs the pinned env, then runs the auditor.
# --frozen: never rewrite uv.lock on the host — a rewrite would dirty the tree (this daily audit
# has no clean-tree guard) and wedge the GitOps deployer's dirty-skip.
exec /home/{{ sys_user }}/.local/bin/uv run --frozen python scripts/secret_rotation.py audit --push
