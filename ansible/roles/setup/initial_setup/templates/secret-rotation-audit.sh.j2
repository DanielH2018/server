#!/usr/bin/env bash
# Daily secret-rotation audit — managed by Ansible (initial_setup); edits overwritten.
#
# Runs scripts/secret_rotation.py audit --push, which reads the rotation registry
# (ansible/secret_rotation.yml) and pushes up/down to the "Secret Rotation" Kuma monitor:
# DOWN when any secret is past its per-tier rotation window, or when a secret exists in
# secrets.yml but not the registry (reminding the operator to `secret_rotation.py sync`
# + commit). Read-only by design — the cron never edits the git-tracked registry, so git
# stays the source of truth; rotation is an explicit operator action.
#
# Mode 0700: the Kuma push URL embeds the monitor token. Pushes through the LAN-only
# Authelia bypass on ^/api/push/ (uptime-kuma.local.<domain> → split-horizon → 10.x).
set -uo pipefail

export SECRET_ROTATION_KUMA="https://uptime-kuma.local.{{ domain }}/api/push/{{ secret_rotation_push_token }}"
cd /home/{{ sys_user }}/server || exit 1

# uv (absolute path — cron's PATH lacks it) syncs the pinned env, then runs the auditor.
exec /home/{{ sys_user }}/.local/bin/uv run python scripts/secret_rotation.py audit --push
