# can't use mem_limit in a 3.x docker-compose file in non swarm mode
# see https://github.com/docker/compose/issues/4513
version: "2.4"

services:
  whoogle:
    image: benbusby/whoogle-search
    container_name: whoogle
    restart: unless-stopped
    pids_limit: 50
    mem_limit: 256mb
    memswap_limit: 256mb
    # user debian-tor from tor package
    user: whoogle
    security_opt:
      - no-new-privileges
    cap_drop:
      - ALL
    networks:
      - {{ DOCKER_NETWORK }}
    healthcheck:
      test: curl --fail -s http://localhost:5000/ || exit 1
      interval: 30s
      timeout: 10s
      retries: 3
    tmpfs:
      - /config/:size=10M,uid=927,gid=927,mode=1700
      - /var/lib/tor/:size=15M,uid=927,gid=927,mode=1700
      - /run/tor/:size=1M,uid=927,gid=927,mode=1700
    ports:
      - 5000:5000
    labels:
      # Enable traefik for container
      - "traefik.enable=true"
      # Setup HTTP entrypoint
      - "traefik.http.routers.whoogle.entrypoints=http"
      - "traefik.http.routers.whoogle.rule=Host(`whoogle.{{ DOMAIN }}`)"
      # Redirect HTTP to HTTPS
      - "traefik.http.middlewares.whoogle-https-redirect.redirectscheme.scheme=https"
      - "traefik.http.routers.whoogle.middlewares=whoogle-https-redirect"
      # Setup HTTPS entrypoint
      - "traefik.http.routers.whoogle-secure.entrypoints=https"
      - "traefik.http.routers.whoogle-secure.rule=Host(`whoogle.{{ DOMAIN }}`)"
      - "traefik.http.routers.whoogle-secure.tls=true"
      # Setup port forwarding to internal port
      - "traefik.http.routers.whoogle-secure.service=whoogle"
      - "traefik.http.services.whoogle.loadbalancer.server.port=5000"
      # Use traefik network
      - "traefik.docker.network={{ DOCKER_NETWORK }}"
      # Add authelia
      #- 'traefik.http.routers.whoogle-secure.middlewares=authelia@docker'

networks:
  {{ DOCKER_NETWORK }}:
    external: true

