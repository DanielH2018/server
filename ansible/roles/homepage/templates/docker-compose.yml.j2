{% from 'traefik.yml.j2' import labels with context %}
---
version: "3.8"
services:
  homepage:
    image: ghcr.io/gethomepage/homepage:latest
    container_name: homepage
    environment:
      - PUID={{ PUID }}
      - PGID={{ PGID }}
      - TZ={{ TZ }}
    ports:
      - 3006:3000
    restart: unless-stopped
    networks:
      - {{ DOCKER_NETWORK }}
    volumes:
      - ./config:/app/config
      - /var/run/docker.sock:/var/run/docker.sock
    labels:
      # Enable traefik for container
      - "traefik.enable=true"
      # Use traefik network
      - "traefik.docker.network={{ DOCKER_NETWORK }}"

      {# Generate labels(container_name, port, use_authelia) -#}
      {{ labels(container, '3000', 'y') }}

networks:
  {{ DOCKER_NETWORK }}:
    external: true
    