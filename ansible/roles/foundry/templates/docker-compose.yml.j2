{% from 'traefik.yml.j2' import labels with context %}
---
version: "3.8"
services:
  foundry:
    image: direckthit/fvtt-docker:latest
    container_name: foundry
    user: root # Workaround for permission errors
    volumes:
      - ./data:/data/foundryvtt
      - ./foundrydl:/host
      - foundry_data:/opt/foundryvtt/resources/app
    ports:
      - 30000:30000
    restart: unless-stopped
    networks:
      - {{ DOCKER_NETWORK }}
    healthcheck:
      test: wget --no-verbose --tries=1 --spider http://localhost:30000/ || exit 1
      interval: 30s
      timeout: 10s
      retries: 3
    labels:
      # Enable traefik for container
      - "traefik.enable=true"
      # Use traefik network
      - "traefik.docker.network={{ DOCKER_NETWORK }}"

      {# Generate labels(container_name, port, use_authelia) -#}
      {{ labels(container, '30000', 'n') }}

networks:
  {{ DOCKER_NETWORK }}:
    external: true
volumes:
  foundry_data:
