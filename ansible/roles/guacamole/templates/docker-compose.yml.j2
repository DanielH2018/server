{% from 'traefik.yml.j2' import labels with context %}
---
version: "3.8"
services:
  guacamole:
    image: oznu/guacamole:latest
    container_name: guacamole
    restart: unless-stopped
    volumes:
      - postgres:/config
    ports:
      - 9600:8080
    networks:
      - {{ DOCKER_NETWORK }}
    healthcheck:
      test: curl --fail -s http://localhost:8080/ || exit 1
      interval: 30s
      timeout: 10s
      retries: 3
    labels:
      # Enable traefik for container
      - "traefik.enable=true"
      # Use traefik network
      - "traefik.docker.network={{ DOCKER_NETWORK }}"

      {# Generate labels(container_name, port, use_authelia) -#}
      {{ labels(container, '8080', 'y') }}

networks:
  {{ DOCKER_NETWORK }}:
    external: true

volumes:
  postgres:
    driver: local
