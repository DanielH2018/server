version: "3.8"

services:
  stubby:
    image: mvance/stubby:latest
    container_name: stubby
    restart: unless-stopped
    networks:
      - {{ DOCKER_NETWORK }}

  unbound:
    image: mvance/unbound:1.14.0-stubby
    container_name: unbound
    restart: unless-stopped
    ports:
      - 5353:53/tcp
      - 5353:53/udp
    depends_on:
      - stubby   
    networks:
      {{ DOCKER_NETWORK }}:
        ipv4_address: 172.18.1.1

  pihole:
    container_name: pihole
    image: pihole/pihole:latest
    restart: unless-stopped
    networks:
      - {{ DOCKER_NETWORK }}
    ports:
      - "53:53/tcp"
      - "53:53/udp"
      - "67:67/udp"
      - "8053:80/tcp"
      - "8054:443/tcp"
    environment:
      TZ: {{ TZ }}
      WEBPASSWORD: {{ PIHOLE_PASSWORD }}
      ServerIP: {{ SERVER_IP }}
      PIHOLE_DNS_: 172.18.1.1#5353
    volumes:
       - './data/etc-pihole/:/etc/pihole/'
       - './data/etc-dnsmasq.d/:/etc/dnsmasq.d/'
    cap_add:
      - NET_ADMIN
    labels:
      # Enable traefik for container
      - "traefik.enable=true"
      # Setup HTTP entrypoint
      - "traefik.http.routers.pihole.entrypoints=http"
      - "traefik.http.routers.pihole.rule=Host(`pihole.{{ DOMAIN }}`)"
      # Redirect HTTP to HTTPS
      - "traefik.http.middlewares.pihole-https-redirect.redirectscheme.scheme=https"
      - "traefik.http.routers.pihole.middlewares=pihole-https-redirect"
      # Setup HTTPS entrypoint
      - "traefik.http.routers.pihole-secure.entrypoints=https"
      - "traefik.http.routers.pihole-secure.rule=Host(`pihole.{{ DOMAIN }}`)"
      - "traefik.http.routers.pihole-secure.tls=true"
      # Setup port forwarding to internal port
      - "traefik.http.routers.pihole-secure.service=pihole"
      - "traefik.http.services.pihole.loadbalancer.server.port=80"
      # Use traefik network
      - "traefik.docker.network={{ DOCKER_NETWORK }}"
      # Add authelia
      - 'traefik.http.routers.pihole-secure.middlewares=authelia@docker'
      # Add admin prefix to url
      - "traefik.http.routers.pihole-secure.middlewares=add-admin"
      - "traefik.http.middlewares.add-admin.addprefix.prefix=/admin"

networks:
  default:
    external:
      name: {{ DOCKER_NETWORK }}
  {{ DOCKER_NETWORK }}:
    external: true
