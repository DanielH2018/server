{% from 'traefik.yml.j2' import labels with context %}
---
version: "3.8"

services:
  dnscrypt:
    image: klutchell/dnscrypt-proxy:latest
    container_name: dnscrypt-proxy
    restart: unless-stopped
    networks:
      {{ DOCKER_NETWORK }}:
        ipv4_address: 172.19.0.42
    expose:
      - "5300/udp"
      - "5300/tcp"
    environment:
      TZ: {{ TZ }}
    dns:
      - 1.1.1.1
    volumes:
      - './data/etc-dnscrypt-proxy:/config'

  pihole:
    container_name: pihole
    image: pihole/pihole:latest
    restart: unless-stopped
    depends_on:
      - dnscrypt
    networks:
      - {{ DOCKER_NETWORK }}
    dns:
      - 1.1.1.1
    ports:
      - "53:53/tcp"
      - "53:53/udp"
      - "67:67/udp"
      - "8053:80/tcp"
      - "8054:443/tcp"
    environment:
      TZ: {{ TZ }}
      WEBPASSWORD: {{ PIHOLE_PASSWORD }}
      ServerIP: {{ SERVER_IP }}
      PIHOLE_DNS_: 172.19.0.42#5300
    volumes:
       - './data/etc-pihole/:/etc/pihole/'
       - './data/etc-dnsmasq.d/:/etc/dnsmasq.d/'
    cap_add:
      - NET_ADMIN
    labels:
      # Enable traefik for container
      - "traefik.enable=true"
      # Use traefik network
      - "traefik.docker.network={{ DOCKER_NETWORK }}"

      {# Generate labels(container_name, port, use_authelia) -#}
      {{ labels(container, '80', 'y') }}
      
      # Add admin prefix to url
      - "traefik.http.routers.pihole-secure.middlewares=add-admin"
      - "traefik.http.middlewares.add-admin.addprefix.prefix=/admin"

networks:
  default:
    external:
      name: {{ DOCKER_NETWORK }}
  {{ DOCKER_NETWORK }}:
    external: true
