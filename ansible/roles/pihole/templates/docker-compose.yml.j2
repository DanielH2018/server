version: "3"

services:
  unbound:
    image: mvance/unbound:latest
    container_name: unbound
    restart: unless-stopped
    ports:
      - 5353:53/tcp
      - 5353:53/udp
    volumes:
      - '/home/{{ env.SYS_USER }}/server/unbound:/opt/unbound/etc/unbound
    networks:
      {{ env.DOCKER_NETWORK }}:
        ipv4_address: 172.168.0.26

  pihole:
    container_name: pihole
    image: pihole/pihole:latest
    restart: unless-stopped
    networks:
      - {{ env.DOCKER_NETWORK }}
    ports:
      - "53:53/tcp"
      - "53:53/udp"
      - "67:67/udp"
      - "8053:80/tcp"
      - "8054:443/tcp"
    environment:
      PIHOLE_DNS_: 172.168.0.26#5353;1.1.1.1
      TZ: {{ env.TZ }}
      WEBPASSWORD: {{ env.PIHOLE_PASSWORD }}
      ServerIP: {{ env.SERVER_IP}}
    volumes:
       - '/home/{{ env.SYS_USER }}/server/pihole/data/etc-pihole/:/etc/pihole/'
       - '/home/{{ env.SYS_USER }}/server/pihole/data/etc-dnsmasq.d/:/etc/dnsmasq.d/'
    cap_add:
      - NET_ADMIN
    labels:
      # Enable traefik for container
      - "traefik.enable=true"
      # Setup HTTP entrypoint
      - "traefik.http.routers.pihole.entrypoints=http"
      - "traefik.http.routers.pihole.rule=Host(`pihole.{{ env.DOMAIN }}`)"
      # Redirect HTTP to HTTPS
      - "traefik.http.middlewares.pihole-https-redirect.redirectscheme.scheme=https"
      - "traefik.http.routers.pihole.middlewares=pihole-https-redirect"
      # Setup HTTPS entrypoint
      - "traefik.http.routers.pihole-secure.entrypoints=https"
      - "traefik.http.routers.pihole-secure.rule=Host(`pihole.{{ env.DOMAIN }}`)"
      - "traefik.http.routers.pihole-secure.tls=true"
      # Setup port forwarding to internal port
      - "traefik.http.routers.pihole-secure.service=pihole"
      - "traefik.http.services.pihole.loadbalancer.server.port=80"
      # Use traefik network
      - "traefik.docker.network={{ env.DOCKER_NETWORK }}"
      # Add authelia
      - 'traefik.http.routers.pihole-secure.middlewares=authelia@docker'
      # Add admin prefix to url
      - "traefik.http.routers.pihole-secure.middlewares=add-admin"
      - "traefik.http.middlewares.add-admin.addprefix.prefix=/admin"

networks:
  {{ env.DOCKER_NETWORK }}:
    external: true
