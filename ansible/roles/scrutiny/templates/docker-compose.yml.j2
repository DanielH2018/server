---
version: "2.1"
services:
  scrutiny:
    image: lscr.io/linuxserver/scrutiny
    container_name: scrutiny
    cap_add:
      - SYS_RAWIO
      - SYS_ADMIN #optional
    environment:
      - PUID={{ env.PUID }}
      - PGID={{ env.PUID }}
      - TZ={{ env.TZ }}
      - SCRUTINY_API_ENDPOINT=http://localhost:8082
      - SCRUTINY_WEB=true
      - SCRUTINY_COLLECTOR=true
    volumes:
      - /home/{{ env.SYS_USER }}/server/scrutiny/config:/config
      - /run/udev:/run/udev:ro
    ports:
      - 8082:8080
    devices:
      - /dev/sda:/dev/sda
      - /dev/sdb:/dev/sdb
      - /dev/nvme1n1:/dev/nvme1n1
    restart: unless-stopped