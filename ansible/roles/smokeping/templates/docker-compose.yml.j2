---
version: "2.1"
services:
  smokeping:
    image: lscr.io/linuxserver/smokeping
    container_name: smokeping
    environment:
      - PUID={{ env.PUID }}
      - PGID={{ env.PGID }}
      - TZ={{ env.TZ }}
    volumes:
      - ./config:/config
      - ./data:/data
    ports:
      - 81:80
    restart: unless-stopped
    networks:
      - {{ env.DOCKER_NETWORK }}
    labels:
      # Enable traefik for container
      - "traefik.enable=true"
      # Setup HTTP entrypoint
      - "traefik.http.routers.smokeping.entrypoints=http"
      - "traefik.http.routers.smokeping.rule=Host(`smokeping.{{ env.DOMAIN }}`)"
      # Redirect HTTP to HTTPS
      - "traefik.http.middlewares.smokeping-https-redirect.redirectscheme.scheme=https"
      - "traefik.http.routers.smokeping.middlewares=smokeping-https-redirect"
      # Setup HTTPS entrypoint
      - "traefik.http.routers.smokeping-secure.entrypoints=https"
      - "traefik.http.routers.smokeping-secure.rule=Host(`smokeping.{{ env.DOMAIN }}`)"
      - "traefik.http.routers.smokeping-secure.tls=true"
      # Setup port forwarding to internal port
      - "traefik.http.routers.smokeping-secure.service=smokeping"
      - "traefik.http.services.smokeping.loadbalancer.server.port=80"
      # Use traefik network
      - "traefik.docker.network={{ env.DOCKER_NETWORK }}"
      # Add authelia
      - 'traefik.http.routers.smokeping-secure.middlewares=authelia@docker'

networks:
  {{ env.DOCKER_NETWORK }}:
    external: true
