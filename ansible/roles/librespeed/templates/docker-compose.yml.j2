---
version: "2.1"
services:
  librespeed:
    image: lscr.io/linuxserver/librespeed
    container_name: librespeed
    environment:
      - PUID={{ PUID }}
      - PGID={{ PGID }}
      - TZ={{ TZ }}
      - PASSWORD={{ LIBRESPEED_PASSWORD }}
      - DB_TYPE=sqlite 
    volumes:
      - ./config:/config
    ports:
      - 8056:80
    restart: unless-stopped
    networks:
      - {{ DOCKER_NETWORK }}
    healthcheck:
      test: curl --fail http://librespeed || exit 1
      interval: 1m
      timeout: 5s
      start_period: 20s
      retries: 2
    labels:
      # Enable traefik for container
      - "traefik.enable=true"
      - "traefik.http.routers.librespeed.entrypoints=http"
      # Setup HTTP entrypoint
      - "traefik.http.routers.librespeed.rule=Host(`librespeed.{{ DOMAIN }}`)"
      - "traefik.http.middlewares.librespeed-https-redirect.redirectscheme.scheme=https"
      # Redirect HTTP to HTTPS
      - "traefik.http.routers.librespeed.middlewares=librespeed-https-redirect"
      # Setup HTTPS entrypoint
      - "traefik.http.routers.librespeed-secure.entrypoints=https"
      - "traefik.http.routers.librespeed-secure.rule=Host(`librespeed.{{ DOMAIN }}`)"
      - "traefik.http.routers.librespeed-secure.tls=true"
      # Setup port forwarding to internal port
      - "traefik.http.routers.librespeed-secure.service=librespeed"
      - "traefik.http.services.librespeed.loadbalancer.server.port=80"
      # Use traefik network
      - "traefik.docker.network={{ DOCKER_NETWORK }}"
      # Add authelia
      - 'traefik.http.routers.librespeed-secure.middlewares=authelia@docker'

networks:
  {{ DOCKER_NETWORK }}:
    external: true
