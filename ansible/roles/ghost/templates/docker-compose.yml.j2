{% from 'traefik.yml.j2' import labels with context %}
---
version: '3.1'
services:
  ghost_db:
    image: mysql:8.0
    restart: unless-stopped
    container_name: ghost_db
    volumes:
      - ghost_db_data:/var/lib/mysql
    environment:
      MYSQL_ROOT_PASSWORD: {{ GHOST_DB_ROOT_PASSWORD }}
      MYSQL_USER: {{ GHOST_DB_USER }}
      MYSQL_PASSWORD: {{ GHOST_DB_PASSWORD }}
      MYSQL_DATABASE: {{ GHOST_DB }}
    networks:
      - {{ DOCKER_NETWORK }}

  ghost:
    image: ghost:alpine
    restart: unless-stopped
    container_name: ghost
    volumes:
      - ghost_data:/var/lib/ghost/content
    ports:
      - 2368:2368
    environment:
      url: https://blog.{{ DOMAIN }}
      database__client: mysql
      database__connection__host: ghost_db
      database__connection__user: {{ GHOST_DB_USER }}
      database__connection__password: {{ GHOST_DB_PASSWORD }}
      database__connection__database: {{ GHOST_DB }}
    networks:
      - {{ DOCKER_NETWORK }}
    labels:
      # Enable traefik for container
      - "traefik.enable=true"
      # Use traefik network
      - "traefik.docker.network={{ DOCKER_NETWORK }}"

      {# Generate labels(container_name, port, use_authelia) -#}
      {{ labels('blog', '2368', 'n') }}
    depends_on:
      - ghost_db

networks:
  {{ DOCKER_NETWORK }}:
    external: true
volumes:
  ghost_db_data:
  ghost_data:
