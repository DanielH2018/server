{% from 'traefik.yml.j2' import labels with context %}
---
version: '3.1'
services:
  ghost:
    image: ghost:alpine
    restart: unless-stopped
    container_name: ghost
    ports:
      - 2368:2368
    environment:
      - url=https://blog.{{ DOMAIN }}
    networks:
      - {{ DOCKER_NETWORK }}
    labels:
      # Enable traefik for container
      - "traefik.enable=true"
      # Use traefik network
      - "traefik.docker.network={{ DOCKER_NETWORK }}"

      {# Generate labels(container_name, port, use_authelia) -#}
      {{ labels('blog', '2368', 'y') }}

networks:
  {{ DOCKER_NETWORK }}:
    external: true
