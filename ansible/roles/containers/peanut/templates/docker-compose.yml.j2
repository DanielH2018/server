{% from 'traefik.yml.j2' import labels with context %}
{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
{% from 'healthcheck.yml.j2' import healthcheck %}
---
services:
  nut:
    container_name: nut
    build:
      context: .
      pull: true  # rebuilds must fetch the newest base, or the redeploy delivers nothing new
    restart: unless-stopped
    # USB access is granted via the device mapping below plus the udev rule
    # (99-nut-apc.rules, MODE=0666) installed by the role — no privileged/pid:host needed.
    security_opt:
      - no-new-privileges:true
    # entrypoint chowns /var/run/nut (CHOWN), then upsdrvctl/upsd/upsmon start as root
    # and drop to the `nut` user (SETUID/SETGID). USB node is MODE=0666 so no extra cap
    # is needed to open it. DAC_OVERRIDE: upsmon's root parent (kept root to raise FSD)
    # must write its pidfile into the nut-owned 0770 /run/nut — without it `upsmon -c fsd`
    # can't find the process and the on-battery shutdown chain silently breaks.
    cap_drop:
      - ALL
    cap_add:
      - CHOWN
      - SETUID
      - SETGID
      - DAC_OVERRIDE
    devices:
      - /dev/bus/usb:/dev/bus/usb
    environment:
      - TZ={{ tz }}
    networks:
      - internal
      # Plain bridge ONLY for the loopback publish below — `internal: true` networks
      # cannot publish ports. No other container joins it.
      - nut_host
      # Shared isolation net so Home Assistant's NUT integration can reach upsd:3493.
      - ups
    # Host-loopback upsd: the host runs its own upsmon in `secondary` mode against this
    # (see the role's nut-client tasks). The container CANNOT power off the host — the
    # old SHUTDOWNCMD nsenter needed pid:host + SYS_ADMIN we rightly don't grant — so
    # the host secondary is what actually runs `systemctl poweroff` when FSD is raised.
    ports:
      - "127.0.0.1:3493:3493"
    {{ healthcheck("[\"CMD-SHELL\", \"upsc " ~ (nut_ups_name | default('apc-ups')) ~ "@localhost battery.charge 2>/dev/null || exit 1\"]") }}
    labels:
      {{ kuma('nut', name='NUT') }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('0.50', '128M', '0.05', '16M') }}

  peanut:
    container_name: peanut
    image: brandawg93/peanut:latest
    restart: unless-stopped
    depends_on:
      # nut has a healthcheck (upsc battery.charge); gate on it so peanut doesn't start
      # before upsd is serving and show "no data" until its next poll on a recreate deploy.
      nut:
        condition: service_healthy
    volumes:
      - ./peanut-config:/config
    environment:
      - TZ={{ tz }}
      - WEB_USERNAME={{ peanut_username }}
      - WEB_PASSWORD={{ peanut_password }}
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    # Read-only rootfs: peanut (runs as non-root `node`) regenerates /app/config/auth.yaml
    # from WEB_USERNAME/PASSWORD at every boot — a dir ABSENT from the image (not the
    # ./peanut-config:/config mount), so tmpfs it (mode=1777 for the node uid). Persistent
    # state stays in the /config bind mount; auth.yaml is env-derived, fine to be ephemeral.
    read_only: true
    tmpfs:
      - /app/config:mode=1777
    {{ service_networks() }}
      - internal
    labels:
      {# Generate labels(container, port, docker_network, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          (container_item.networks | default([docker_network]))[0],
          container_item.use_authelia
        )
      }}
      {{ kuma(container_item.name) }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('0.50', '256M', '0.05', '32M') }}

{{ external_networks() }}
  internal:
    internal: true
  nut_host:
    driver: bridge
  ups:
    external: true
