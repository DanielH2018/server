MONITOR {{ nut_ups_name | default('apc-ups') }}@localhost 1 upsmon {{ nut_monitor_password }} primary
MINSUPPLIES 1
# This upsmon (container, primary) only RAISES FSD — it cannot power off the host:
# nsenter into host PID 1 needs pid:host + SYS_ADMIN, which the container rightly
# lacks (verified failing 2026-06-10). The HOST runs its own upsmon in `secondary`
# mode (role-installed nut-client over 127.0.0.1:3493) and performs the real
# `systemctl poweroff` when FSD propagates.
SHUTDOWNCMD "logger -t upsmon 'FSD raised — host-side secondary upsmon performs the actual poweroff'"
NOTIFYCMD /usr/sbin/upssched
POLLFREQ 5
POLLFREQALERT 5
HOSTSYNC 15
DEADTIME 15
POWERDOWNFLAG /etc/killpower

NOTIFYMSG ONLINE "UPS %s on line power"
NOTIFYMSG ONBATT "UPS %s on battery"
NOTIFYMSG LOWBATT "UPS %s battery is low"
NOTIFYMSG COMMBAD "UPS %s communication lost"
NOTIFYMSG COMMOK "UPS %s communication restored"
NOTIFYMSG SHUTDOWN "Auto-shutdown initiated on UPS %s"

NOTIFYFLAG ONLINE SYSLOG+EXEC
NOTIFYFLAG ONBATT SYSLOG+WALL+EXEC
NOTIFYFLAG LOWBATT SYSLOG+WALL+EXEC
NOTIFYFLAG COMMBAD SYSLOG
NOTIFYFLAG COMMOK SYSLOG
NOTIFYFLAG SHUTDOWN SYSLOG+WALL

RBWARNTIME 43200
NOCOMMWARNTIME 300
FINALDELAY 5
