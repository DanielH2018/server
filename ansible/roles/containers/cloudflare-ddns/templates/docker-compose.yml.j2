{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
services:
  ddns-proxied:
    image: favonia/cloudflare-ddns:latest
    container_name: cloudflare-ddns-proxied
    restart: unless-stopped
    read_only: true
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    environment:
      # Zone-edit token file-mounted (below), NOT inline, so it stays out of the container Env that
      # the read-only docker-proxy exposes to every monitoring-net neighbor (2026-07-15 review H1).
      - CLOUDFLARE_API_TOKEN_FILE=/run/secrets/cf_dns_token
      - DOMAINS={{ domain }}
      - PROXIED=true
      - IP6_PROVIDER=none
      # Dead-man's-switch: ping a Kuma push monitor after each successful update.
      # Internal http (same `monitoring` net) — keeps the heartbeat off public DNS
      # and out of the Authelia-gated public route. Token lives in secrets.yml.
      - UPTIMEKUMA=http://uptime-kuma:3001/api/push/{{ cloudflare_ddns_proxied_push_token }}
    volumes:
      - ./data/cf_dns_token:/run/secrets/cf_dns_token:ro
    {{ service_networks() }}
    labels:
      {{ kuma('cloudflare-ddns-proxied') }}
      {{ kuma('cloudflare-ddns-proxied-push', monitor_type='push', interval=300, push_token=cloudflare_ddns_proxied_push_token) }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('0.25', '64M', '0.05', '16M') }}
  ddns-direct:
    image: favonia/cloudflare-ddns:latest
    container_name: cloudflare-ddns-direct
    restart: unless-stopped
    read_only: true
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    environment:
      # Zone-edit token file-mounted (below), NOT inline, so it stays out of the container Env that
      # the read-only docker-proxy exposes to every monitoring-net neighbor (2026-07-15 review H1).
      - CLOUDFLARE_API_TOKEN_FILE=/run/secrets/cf_dns_token
      # Only terraria is live. valheim/minecraft are archived — publishing their A
      # records pointed unproxied home IP at nothing, needlessly exposing the raw IP.
      # Re-add a domain here when its game server is reactivated.
      - DOMAINS=terraria.{{ domain }}
      - PROXIED=false
      - IP6_PROVIDER=none
      # Dead-man's-switch: ping a Kuma push monitor after each successful update.
      # Internal http (same `monitoring` net) — keeps the heartbeat off public DNS
      # and out of the Authelia-gated public route. Token lives in secrets.yml.
      - UPTIMEKUMA=http://uptime-kuma:3001/api/push/{{ cloudflare_ddns_direct_push_token }}
    volumes:
      - ./data/cf_dns_token:/run/secrets/cf_dns_token:ro
    {{ service_networks() }}
    labels:
      {{ kuma('cloudflare-ddns-direct') }}
      {{ kuma('cloudflare-ddns-direct-push', monitor_type='push', interval=300, push_token=cloudflare_ddns_direct_push_token) }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('0.25', '64M', '0.05', '16M') }}

{{ external_networks() }}
