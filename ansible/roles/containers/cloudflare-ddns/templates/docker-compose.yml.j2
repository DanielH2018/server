version: '3.8'
services:
  ddns-proxied:
    image: favonia/cloudflare-ddns:latest
    container_name: cloudflare-ddns-proxied
    restart: always
    read_only: true
    cap_drop: [all]
    security_opt: [no-new-privileges:true]
    environment:
      - CF_API_TOKEN={{ CLOUDFLARE_DNS_TOKEN }}
      - DOMAINS={{ DOMAIN }}
      - PROXIED=true
      - IP6_PROVIDER=none
    networks:
      - {{ docker_network }}
  ddns-direct:
    image: favonia/cloudflare-ddns:latest
    container_name: cloudflare-ddns-direct
    restart: always
    read_only: true
    cap_drop: [all]
    security_opt: [no-new-privileges:true]
    environment:
      - CF_API_TOKEN={{ CLOUDFLARE_DNS_TOKEN }}
      - DOMAINS=valheim.{{ DOMAIN }},minecraft.{{ DOMAIN }}
      - PROXIED=false
      - IP6_PROVIDER=none
    networks:
      - {{ docker_network }}

networks:
  {{ docker_network }}:
    external: true
