{% from 'traefik.yml.j2' import labels with context %}
{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
---

services:
  wireguard:
    image: lscr.io/linuxserver/wireguard:latest
    container_name: wireguard
    hostname: wireguard
    # NET_ADMIN for the tunnel interface + routing/fwmark rules; NET_RAW because the
    # Mullvad mod's kill-switch installs iptables rules in the 'raw' table (initialising
    # it fails with "unable to initialize table 'raw'" without NET_RAW). Plus the LSIO s6
    # set to chown /config and drop privileges. SYS_MODULE not needed (module on host).
    cap_drop:
      - ALL
    cap_add:
      - NET_ADMIN
      - NET_RAW
      - CHOWN
      - SETUID
      - SETGID
      - FOWNER
      - DAC_OVERRIDE
    security_opt:
      - no-new-privileges:true
    environment:
      - PUID={{ puid }}
      - PGID={{ pgid }}
      - TZ={{ tz }}
      - DOCKER_MODS=linuxserver/mods:wireguard-mullvad
      # Mullvad private key + account file-mounted, NOT inline, so these tier-external creds stay out
      # of the container Env the read-only docker-proxy exposes to every neighbor (2026-07-15 review
      # L2). The LSIO base's init-envfile reads FILE__<VAR> from the file into <VAR> BEFORE the
      # wireguard-mullvad mod's install script reads it (s6 order init-envfile → init-os-end → ... →
      # init-mods → the mod). The rendered files are `| trim`med — init-envfile does NOT strip a
      # trailing newline (it only warns), and a newline would corrupt the key/account.
      - FILE__MULLVAD_PRIVATE_KEY=/run/secrets/mullvad_key
      - FILE__MULLVAD_ACCOUNT=/run/secrets/mullvad_account
      - MULLVAD_LOCATION=us-qas
      - LAN_NETWORKS=192.168.0.0/24,10.0.0.0/24,172.16.0.0/12
    volumes:
      - ./config:/config
      - ./mullvad-secrets/key:/run/secrets/mullvad_key:ro
      - ./mullvad-secrets/account:/run/secrets/mullvad_account:ro
    sysctls:
      - net.ipv4.conf.all.src_valid_mark=1
      - net.ipv6.conf.all.disable_ipv6=1
      - net.ipv6.conf.default.disable_ipv6=1
    healthcheck:
      # Probe real egress through the tunnel instead of Mullvad's detection API. The
      # kill-switch (iptables REJECT for non-wg0 traffic) means any successful external
      # request necessarily left via Mullvad, so reaching 1.1.1.1 proves the tunnel is
      # up AND leak-free — without depending on am.i.mullvad.net being reachable, whose
      # transient blips previously failed this check and triggered needless restarts
      # (which orphaned qBittorrent). 1.1.1.1 by IP avoids DNS; public so it routes via wg0.
      # Tolerant: retries 6 × interval 1m means only a sustained (~6 min) outage restarts
      # the tunnel, riding out brief blips while still recovering a genuinely-dead relay.
      test: |
        bash -c 'curl -fsm 10 https://1.1.1.1 >/dev/null || exit 1'
      interval: 1m
      timeout: 15s
      retries: 6
      start_period: 30s
    restart: unless-stopped
    {{ service_networks() }}
    labels:
      {# Generate labels(container, port, docker_network, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          (container_item.networks | default([docker_network]))[0],
          container_item.use_authelia
        )
      }}
      {{ kuma('wireguard') }}
      # Disable Watchtower
      - "com.centurylinklabs.watchtower.enable=false"
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('1.0', '256M', '0.05', '32M') }}
  qbittorrent:
    image: lscr.io/linuxserver/qbittorrent:latest
    container_name: qbittorrent
    network_mode: service:wireguard
    depends_on:
      wireguard:
        condition: service_healthy
    # Standard LSIO s6 set to chown /config + /data and drop to PUID/PGID. No
    # NET_ADMIN — networking is owned by the wireguard sidecar (shared netns), not here.
    cap_drop:
      - ALL
    cap_add:
      - CHOWN
      - SETUID
      - SETGID
      - FOWNER
      - DAC_OVERRIDE
    security_opt:
      - no-new-privileges:true
    environment:
      - PUID={{ puid }}
      - PGID={{ pgid }}
      - TZ={{ tz }}
      - UMASK_SET=022
      - WEBUI_PORT=8080
      - TORRENTING_PORT=6881
    volumes:
      - ./config:/config
      # torrents/ ONLY, mounted at the same in-container path as Sonarr/Radarr see it
      # (/data/torrents — they mount the whole data/ tree at /data, so paths agree).
      # qBittorrent only ever writes downloads here; the hardlink-import EXDEV concern
      # that unified the *arr mounts is theirs alone (link() happens inside sonarr/radarr,
      # whose single mount spans torrents/ AND media/). Scoping this mount keeps the
      # fleet's largest untrusted-input surface (arbitrary torrent payloads) from having
      # rw over the whole media/book library (2026-07-02 review M2).
      - /home/{{ sys_user }}/server/containers/data/torrents:/data/torrents
    restart: unless-stopped
    healthcheck:
      # Three signals, because each catches a failure the others miss:
      #   1. loopback WebUI (localhost:8080) — the qBittorrent process is up;
      #   2. egress to a public IP (1.1.1.1) — the netns is live and the Mullvad
      #      tunnel is up (the kill-switch permits egress only via wg0). This also
      #      detects an orphaned netns: if the wireguard sidecar is recreated,
      #      qBittorrent keeps serving 8080 in the now-dead netns (unreachable at
      #      wireguard:8080, so Sonarr/Radarr see "Connection refused") while a
      #      loopback-only probe stays green;
      #   3. DHT node count via the API — qBittorrent's *UDP* path actually works.
      # (3) closes a real blind spot: (1) and (2) are TCP-only, so if qBittorrent binds
      # its torrent socket to eth0 instead of wg0 (the binding is enforced in
      # tasks/main.yml), every UDP tracker/DHT/uTP packet is EPERM-rejected by the
      # kill-switch and downloads silently make zero progress while this check stays
      # green. A healthy node reaches hundreds of DHT nodes within start_period; <20
      # sustained means UDP is dead, so autoheal restarts it to rebind to wg0. By IP,
      # 1.1.1.1 avoids any DNS dependency; it is public so it routes via wg0.
      # NOTE: the shell '$' are doubled ($$) so Docker Compose does NOT interpolate
      # ${dht} / $(...) at parse time — they must reach the in-container shell verbatim.
      test: |
        bash -c 'curl -fsm 10 http://localhost:8080 >/dev/null && curl -fsm 10 https://1.1.1.1 >/dev/null && dht="$$(curl -fsm 10 http://localhost:8080/api/v2/transfer/info | grep -oE "dht_nodes[^0-9]+[0-9]+" | grep -oE "[0-9]+")" && [ "$${dht:-0}" -ge 20 ] || exit 1'
      interval: 1m
      timeout: 15s
      retries: 3
      # 150s (was 90s): DHT re-bootstraps from ~0 on every (re)start and needs ~1-2 min
      # to climb past the threshold, so give it headroom before failures count.
      start_period: 150s
    labels:
      {{ kuma('qbittorrent') }}
      # Disable Watchtower — a recreate loses the wg0 listen-interface bind (applied
      # post-deploy by tasks/main.yml, NOT on container start), which silently kills the
      # UDP/DHT path → zero download progress + an autoheal loop a plain restart can't fix.
      # Update deliberately via `deploy.yml --tags qbittorrent -e common_pull=always`
      # (re-pulls the :latest images AND re-applies the bind), like the wireguard sidecar —
      # never via watchtower. A plain redeploy does NOT pull: with the tag already present
      # locally, docker_compose_v2's default pull policy leaves it untouched.
      - "com.centurylinklabs.watchtower.enable=false"
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('2.0', '2048M', '0.10', '128M') }}

{{ external_networks() }}
