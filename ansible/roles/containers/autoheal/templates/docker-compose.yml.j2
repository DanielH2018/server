version: '3.8'
services:
  autoheal:
    restart: unless-stopped
    image: willfarrell/autoheal:latest
    tty: true
    container_name: autoheal
    environment:
      - AUTOHEAL_CONTAINER_LABEL=autoheal
    networks:
      - {{ docker_network }}
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock

networks:
  {{ docker_network }}:
    external: true
