version: '3.8'
services:
  autoheal:
    restart: unless-stopped
    image: willfarrell/autoheal:latest
    tty: true
    container_name: autoheal
    environment:
      - AUTOHEAL_CONTAINER_LABEL=autoheal
      - DOCKER_SOCK=tcp://docker-proxy:2375
    networks:
      - {{ docker_network }}

networks:
  {{ docker_network }}:
    external: true
