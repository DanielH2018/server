{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
services:
  autoheal:
    restart: unless-stopped
    image: willfarrell/autoheal:latest
    tty: true
    container_name: autoheal
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    environment:
      - AUTOHEAL_CONTAINER_LABEL=all
      # Default poll is 5s: each cycle fetches the full container list through the
      # proxy and parses it with jq — constant CPU churn on the Pi (Zero 2 W), where
      # the jq pass alone was visible in top under load (2026-06-11). 30s detection
      # latency for an unhealthy container is fine for this fleet.
      - AUTOHEAL_INTERVAL=30
      - DOCKER_SOCK=tcp://docker-proxy-lifecycle:2375
    healthcheck:
      # Interval-only override: `test` is deliberately omitted, so Docker inherits the
      # image's own probe (pgrep -f autoheal). The image bakes interval=5s — that's a
      # sh+pgrep exec (2 runc invocations) every 5s, the single largest source of
      # process churn on the Pi (2026-06-11). A self-pgrep doesn't need 5s cadence.
      interval: {{ container_healthcheck_interval | default('30s') }}
    {{ service_networks() }}
    labels:
      # Watchtower
      - "com.centurylinklabs.watchtower.depends-on:docker-proxy-lifecycle"
      {{ kuma(container_item.name) }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('0.25', '64M', '0.05', '16M') }}

{{ external_networks() }}
