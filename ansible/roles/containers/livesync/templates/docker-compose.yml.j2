{% from 'traefik.yml.j2' import labels with context %}
{% from 'autokuma.yml.j2' import labels as kuma with context %}
---
services:
  couchdb:
    image: couchdb:3
    # CouchDB entrypoint chowns /opt/couchdb/data then drops to the couchdb user via
    # su-exec — the standard DB-image privilege-drop set. Add FOWNER if it complains.
    cap_drop:
      - ALL
    cap_add:
      - CHOWN
      - SETUID
      - SETGID
      - DAC_OVERRIDE
    security_opt:
      - no-new-privileges:true
    container_name: livesync
    environment:
      - COUCHDB_USER=admin
      - COUCHDB_PASSWORD={{ livesync_db_password }}
    volumes:
      - ./couchdb-data:/opt/couchdb/data
      - ./couchdb-etc:/opt/couchdb/etc/local.d
    networks:
{% for net in container_item.networks | default([docker_network]) %}
      - {{ net }}
{% endfor %}
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "curl", "-s", "--max-time", "5", "http://localhost:5984/"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    labels:
      {# Generate labels(container, port, docker_network, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          (container_item.networks | default([docker_network]))[0],
          container_item.use_authelia
        )
      }}
      {{ kuma(container_item.name) }}

      ## Block Fauxton admin UI — put it behind Authelia
      - "traefik.http.routers.livesync-utils.rule=Host(`livesync.{{ domain }}`) && PathPrefix(`/_utils`)"
      - "traefik.http.routers.livesync-utils.entrypoints=https"
      - "traefik.http.routers.livesync-utils.tls=true"
      - "traefik.http.routers.livesync-utils.service=livesync"
      - "traefik.http.routers.livesync-utils.middlewares=authelia@docker"
      - "traefik.http.routers.livesync-utils.priority=200"
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    deploy:
      resources:
        limits:
          cpus: '1.0'
          memory: 1024M
        reservations:
          cpus: '0.10'
          memory: 128M

networks:
{% for net in container_item.networks | default([docker_network]) %}
  {{ net }}:
    external: true
{% endfor %}
