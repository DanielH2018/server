{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
{% from 'healthcheck.yml.j2' import healthcheck %}
---
services:
  couchdb:
    image: couchdb:3.5.2
    # CouchDB entrypoint chowns /opt/couchdb/data then drops to the couchdb user via
    # su-exec — the standard DB-image privilege-drop set. Add FOWNER if it complains.
    cap_drop:
      - ALL
    cap_add:
      - CHOWN
      - SETUID
      - SETGID
      - DAC_OVERRIDE
    security_opt:
      - no-new-privileges:true
    container_name: livesync
    environment:
      - COUCHDB_USER=admin
      - COUCHDB_PASSWORD={{ livesync_db_password }}
    volumes:
      - ./couchdb-data:/opt/couchdb/data
      - ./couchdb-etc:/opt/couchdb/etc/local.d
    {{ service_networks() }}
    restart: unless-stopped
    {{ healthcheck('["CMD", "curl", "-s", "--max-time", "5", "http://localhost:5984/"]') }}
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network={{ (container_item.networks | default([docker_network]))[0] }}"
      # Sync API: gated by a secret X-Sync-Token request header instead of Authelia (the
      # Obsidian LiveSync client uses non-interactive basic auth and can't pass 2FA). The
      # token-matching sync router is defined in traefik's config.yml.j2 (file provider,
      # mode 0600 — only the traefik process reads it), NOT as a label here, so the secret
      # stays OUT of Docker metadata: any container on the shared `apps` net can read every
      # container's labels via the docker-proxy (CONTAINERS=1), which would leak the token
      # from a label. This block only PUBLISHES the couchdb service (the file-provider sync
      # router references it cross-provider as livesync@docker) plus the public /_utils admin
      # router below; the high-ceiling rate-limit-livesync middleware is applied there too.
      # NOTE: livesync_sync_token is a shared secret, not per-device identity — rotate it if
      # a device is lost.
      - "traefik.http.services.livesync.loadbalancer.server.port={{ container_item.port }}"

      ## Fauxton admin UI — human access via Authelia 2FA (no token header needed).
      ## priority=200 so /_utils always wins over the token-gated sync router.
      ## PathPrefix(`/_utils/`) segment-anchors (a future CouchDB path like /_utilsXYZ can't inherit
      ## this router); Path(`/_utils`) keeps the bare browser entry working (CouchDB 301s it to
      ## /_utils/) — a trailing-slash prefix alone would drop the no-slash URL to the sync router.
      - "traefik.http.routers.livesync-utils.rule=(Host(`livesync.{{ domain }}`) || Host(`livesync.local.{{ domain }}`)) && (PathPrefix(`/_utils/`) || Path(`/_utils`))"
      - "traefik.http.routers.livesync-utils.entrypoints=https"
      - "traefik.http.routers.livesync-utils.tls=true"
      - "traefik.http.routers.livesync-utils.service=livesync"
      - "traefik.http.routers.livesync-utils.middlewares=rate-limit@file,authelia@docker"
      - "traefik.http.routers.livesync-utils.priority=200"
      # Disable watchtower update — pinned + Renovate-managed
      - "com.centurylinklabs.watchtower.enable=false"
      {{ kuma(container_item.name) }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('1.0', '1024M', '0.10', '128M') }}

{{ external_networks() }}
