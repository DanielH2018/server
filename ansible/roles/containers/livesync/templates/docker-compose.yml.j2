{% from 'traefik.yml.j2' import labels with context %}
{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
---
services:
  couchdb:
    image: couchdb:3
    # CouchDB entrypoint chowns /opt/couchdb/data then drops to the couchdb user via
    # su-exec — the standard DB-image privilege-drop set. Add FOWNER if it complains.
    cap_drop:
      - ALL
    cap_add:
      - CHOWN
      - SETUID
      - SETGID
      - DAC_OVERRIDE
    security_opt:
      - no-new-privileges:true
    container_name: livesync
    environment:
      - COUCHDB_USER=admin
      - COUCHDB_PASSWORD={{ livesync_db_password }}
    volumes:
      - ./couchdb-data:/opt/couchdb/data
      - ./couchdb-etc:/opt/couchdb/etc/local.d
    {{ service_networks() }}
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "curl", "-s", "--max-time", "5", "http://localhost:5984/"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network={{ (container_item.networks | default([docker_network]))[0] }}"
      # Sync API: gated by a secret request header instead of Authelia. The Obsidian
      # LiveSync client uses non-interactive basic auth and can't pass 2FA, so we
      # require an X-Sync-Token header (set in the plugin's custom-headers field on
      # each device). Only requests carrying the matching token match this router;
      # anything else matches NO router for this host and gets a 404 before reaching
      # CouchDB. The token lives in SOPS (livesync_sync_token); CouchDB's own
      # require_valid_user is the second layer (defence in depth). NOTE: this is a
      # shared secret, not per-device identity — rotate the token if a device is lost.
      - "traefik.http.routers.livesync.rule=(Host(`livesync.{{ domain }}`) || Host(`livesync.local.{{ domain }}`)) && Header(`X-Sync-Token`, `{{ livesync_sync_token }}`)"
      - "traefik.http.routers.livesync.entrypoints=https"
      - "traefik.http.routers.livesync.tls=true"
      - "traefik.http.routers.livesync.tls.certresolver=cloudflare"
      - "traefik.http.routers.livesync.tls.domains[0].main={{ domain }}"
      - "traefik.http.routers.livesync.tls.domains[0].sans=*.{{ domain }},*.local.{{ domain }}"
      - "traefik.http.routers.livesync.service=livesync"
      - "traefik.http.services.livesync.loadbalancer.server.port={{ container_item.port }}"

      ## Fauxton admin UI — human access via Authelia 2FA (no token header needed).
      ## priority=200 so /_utils always wins over the token-gated sync router.
      - "traefik.http.routers.livesync-utils.rule=Host(`livesync.{{ domain }}`) && PathPrefix(`/_utils`)"
      - "traefik.http.routers.livesync-utils.entrypoints=https"
      - "traefik.http.routers.livesync-utils.tls=true"
      - "traefik.http.routers.livesync-utils.service=livesync"
      - "traefik.http.routers.livesync-utils.middlewares=authelia@docker"
      - "traefik.http.routers.livesync-utils.priority=200"
      {{ kuma(container_item.name) }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    deploy:
      resources:
        limits:
          cpus: '1.0'
          memory: 1024M
        reservations:
          cpus: '0.10'
          memory: 128M

{{ external_networks() }}
