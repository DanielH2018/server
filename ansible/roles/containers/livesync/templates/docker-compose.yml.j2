{% from 'traefik.yml.j2' import labels with context %}
---
version: '3.8'
services:
  couchdb:
    image: couchdb:latest
    security_opt:
      - no-new-privileges:true
    container_name: livesync
    environment:
      - COUCHDB_USER=admin
      - COUCHDB_PASSWORD={{ livesync_db_password }}
    volumes:
      - ./couchdb-data:/opt/couchdb/data
      - ./couchdb-etc:/opt/couchdb/etc/local.d
    networks:
      - {{ docker_network }}
    restart: unless-stopped
    labels:
      # Enable traefik for container
      - "traefik.enable=true"
      # Use traefik network
      - "traefik.docker.network={{ docker_network }}"

      {# Generate labels(container_name, port, use_authelia) -#}
      {# Generate labels(container, port, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          container_item.use_authelia
        )
      }}

networks:
  {{ docker_network }}:
    external: true
