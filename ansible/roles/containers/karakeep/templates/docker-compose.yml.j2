{% from 'traefik.yml.j2' import labels with context %}
{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
---
services:
  karakeep:
    image: ghcr.io/karakeep-app/karakeep:release
    container_name: karakeep
    restart: unless-stopped
    environment:
      - TZ={{ tz }}
      - DATA_DIR=/data
      - MEILI_ADDR=http://karakeep-meilisearch:7700
      - MEILI_MASTER_KEY={{ karakeep_meili_master_key }}
      - BROWSER_WEB_URL=http://karakeep-chrome:9222
      - NEXTAUTH_URL=https://karakeep.{{ domain }}
      - NEXTAUTH_SECRET={{ karakeep_nextauth_secret }}
      - DISABLE_NEW_USERS_REGISTRATION=true
      - OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
      - OPENAI_API_KEY={{ karakeep_gemini_api_key }}
      - INFERENCE_TEXT_MODEL=gemini-2.5-flash-lite
      - INFERENCE_IMAGE_MODEL=gemini-2.5-flash-lite
      - INFERENCE_TAGS_ENABLED=true
    volumes:
      # Bind mount (under containers/karakeep/) instead of a named volume so the
      # bookmark library, archived snapshots, and db.db land in Kopia's backup
      # scope. karakeep-meilisearch's index stays a named volume — it's
      # rebuildable by reindexing from this data.
      - ./data:/data
    # Node app on a high port. Add CHOWN if it can't chown /data.
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    {{ service_networks() }}
      - internal
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://localhost:3000"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    depends_on:
      - karakeep-chrome
      - karakeep-meilisearch
    labels:
      {# Generate labels(container, port, docker_network, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          (container_item.networks | default([docker_network]))[0],
          container_item.use_authelia
        )
      }}
      {{ kuma(container_item.name) }}

      ## API Bypass (browser extension, mobile app, programmatic clients)
      # /api/v1 is protected by Bearer token (API key) so Authelia is not needed
      - "traefik.http.routers.karakeep-api.rule=Host(`karakeep.{{ domain }}`) && PathPrefix(`/api`)"
      - "traefik.http.routers.karakeep-api.entrypoints=https"
      - "traefik.http.routers.karakeep-api.tls=true"
      - "traefik.http.routers.karakeep-api.service=karakeep"
      - "traefik.http.routers.karakeep-api.priority=100"
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('2.0', '2048M', '0.10', '128M') }}

  karakeep-chrome:
    image: gcr.io/zenika-hub/alpine-chrome:124
    container_name: karakeep-chrome
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "wget", "-q", "--spider", "http://127.0.0.1:9222/json/version"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s
    command:
      - --no-sandbox
      - --disable-gpu
      - --disable-dev-shm-usage
      - --remote-debugging-address=0.0.0.0
      - --remote-debugging-port=9222
      - --hide-scrollbars
    # Chrome already runs with --no-sandbox, so it needs no SYS_ADMIN / sandbox caps.
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    networks:
      - internal
    labels:
      {{ kuma('karakeep-chrome') }}
    # Resource caps for blast-radius containment (M1). Headless Chrome can spike
    # memory, so size generously and tune from cAdvisor/Grafana.
    {{ resources('2.0', '2048M', '0.10', '128M') }}

  karakeep-meilisearch:
    image: getmeili/meilisearch:v1.37.0
    container_name: karakeep-meilisearch
    restart: unless-stopped
    environment:
      - MEILI_NO_ANALYTICS=true
      - MEILI_MASTER_KEY={{ karakeep_meili_master_key }}
    volumes:
      - karakeep_meili:/meili_data
    # Rust binary on a high port; data is a named volume. Add CHOWN if it can't chown /meili_data.
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    networks:
      - internal
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://127.0.0.1:7700/health"]
      interval: 30s
      timeout: 10s
      retries: 3
    labels:
      {{ kuma('karakeep-meilisearch') }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('1.0', '1024M', '0.10', '128M') }}

  karakeep-time-tagger:
    image: ghcr.io/astral-sh/uv:python3.12-bookworm-slim
    container_name: karakeep-time-tagger
    restart: unless-stopped
    environment:
      - TZ={{ tz }}
      - KARAKEEP_PYTHON_API_ENDPOINT=http://karakeep:3000/api/v1/
      - KARAKEEP_PYTHON_API_KEY={{ karakeep_python_api_key }}
    volumes:
      - ./time-tagger/script:/script:ro
      - ./time-tagger/uv-cache:/root/.cache/uv
    command: >-
      bash -c "uv pip install karakeep_python_api fire tqdm beautifulsoup4 loguru -q --system && while true; do python /script/karakeep-time-tagger.py --cache_file /tmp/bookmarks.temp --reset_all=True; sleep 900; done"
    # Python/uv worker running as root. Its uv cache (/root/.cache/uv) is a bind mount
    # owned by uid 1000, so root needs DAC_OVERRIDE to write it — without it `uv pip
    # install` fails with EACCES and the container crash-loops.
    cap_drop:
      - ALL
    cap_add:
      - DAC_OVERRIDE
    security_opt:
      - no-new-privileges:true
    networks:
      - internal
    depends_on:
      karakeep:
        condition: service_healthy
    labels:
      {{ kuma('karakeep-time-tagger') }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('0.50', '512M', '0.05', '64M') }}

volumes:
  karakeep_meili:

{{ external_networks() }}
  internal:
    internal: false
