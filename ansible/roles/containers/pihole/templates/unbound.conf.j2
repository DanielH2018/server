server:
    verbosity: 1
    do-ip6: no

    # Run 2 recursion threads instead of the image default of 1 so a burst of
    # cache-miss lookups resolves concurrently instead of serialising through one
    # thread and piling up in Pi-hole's dnsmasq forward queue (dns-forward-max=150,
    # the "Maximum number of concurrent DNS queries reached" warning). so-reuseport
    # defaults to yes, so each thread gets its own listening socket. NB: outgoing-range
    # (8192, from the base config) is PER THREAD — 2 threads need ~16k outgoing sockets,
    # so the compose service raises nofile to match (default ~8k only covers one thread).
    num-threads: 2

    # Set to 0 to use system default and avoid startup warnings
    so-sndbuf: 0

    # Ensure kernel buffer is large enough to not lose messages in traffic spikes
    # (requires CAP_NET_ADMIN or privileged)
    so-rcvbuf: 0

    # The netblock is given as an IP4 or IP6 address with /size appended for a
    # classless network block. The action can be deny, refuse, allow or allow_snoop.
    access-control: 127.0.0.0/8 allow
    access-control: 10.0.0.0/8 allow
    access-control: 172.16.0.0/12 allow
    access-control: 192.168.0.0/16 allow

    # Ensure privacy of local IP ranges
    private-address: 192.168.0.0/16
    private-address: 172.16.0.0/12
    private-address: 10.0.0.0/8
