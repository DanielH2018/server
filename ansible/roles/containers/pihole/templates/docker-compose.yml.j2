{% from 'traefik.yml.j2' import labels with context %}
---
version: "3.8"

services:
  stubby:
    image: mvance/stubby:latest
    container_name: stubby
    restart: unless-stopped
    volumes:
      - './data/stubby/:/opt/stubby/etc/stubby/'
    networks:
      - {{ DOCKER_NETWORK }}

  unbound:
    image: mvance/unbound:1.16.1-stubby
    container_name: unbound
    restart: unless-stopped
    depends_on:
      - stubby   
    networks:
      {{ DOCKER_NETWORK }}:
        ipv4_address: 172.18.0.255

  pihole:
    container_name: pihole
    image: pihole/pihole:latest
    restart: unless-stopped
    depends_on:
      - unbound
    networks:
      - {{ DOCKER_NETWORK }}
    environment:
      TZ: {{ TZ }}
      WEBPASSWORD: {{ PIHOLE_PASSWORD }}
      ServerIP: {{ SERVER_IP }}
      PIHOLE_DNS_: 172.18.0.255#5353
    volumes:
       - './data/etc-pihole/:/etc/pihole/'
       - './data/etc-dnsmasq.d/:/etc/dnsmasq.d/'
    cap_add:
      - NET_ADMIN
    labels:
      # Enable traefik for container
      - "traefik.enable=true"
      # Use traefik network
      - "traefik.docker.network={{ DOCKER_NETWORK }}"

      {# Generate labels(container, port, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          container_item.use_authelia
        )
      }}

networks:
  default:
    external:
      name: {{ DOCKER_NETWORK }}
  {{ DOCKER_NETWORK }}:
    external: true
