{% from 'traefik.yml.j2' import labels with context %}
{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
{% from 'healthcheck.yml.j2' import healthcheck %}
---


services:
  unbound:
    image: klutchell/unbound:latest
    container_name: unbound
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    # Starts as root to bind :53, then drops to the `unbound` user (username: "unbound"
    # in the image's unbound.conf). chroot is "" and so-rcv/sndbuf are 0, so it needs no
    # SYS_CHROOT/NET_ADMIN — only the bind cap plus the privilege-drop caps.
    cap_drop:
      - ALL
    cap_add:
      - NET_BIND_SERVICE
      - SETUID
      - SETGID
    # num-threads: 2 (unbound.conf) opens outgoing-range (8192) sockets PER THREAD,
    # so ~16k outgoing fds are needed; the image's default nofile (~8k) only covers
    # one thread. Raise it so the second thread doesn't hit fd starvation.
    ulimits:
      nofile:
        soft: 32768
        hard: 32768
    volumes:
      - './data/unbound/:/etc/unbound/custom.conf.d/'
    # drill-hc wrapper reduces exit codes to 0/1; timeout 30s — DNSSEC validation can be slow.
    {{ healthcheck("['CMD', 'drill-hc', '@127.0.0.1', 'dnssec.works']", timeout='30s') }}
    networks:
      - pihole_internal
    labels:
      # Keep :latest but pin against watchtower auto-updates — pihole depends_on this resolver
      # (service_healthy) and it's the LAN's only DNS upstream, so an unsupervised pull that
      # breaks unbound kills all resolution immediately (matches flaresolverr/crowdsec).
      - "com.centurylinklabs.watchtower.enable=false"
      {{ kuma('unbound') }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('0.50', '256M', '0.05', '32M') }}

  pihole:
    container_name: pihole
    image: pihole/pihole:2026.06.0
    restart: unless-stopped
    depends_on:
      unbound:
        condition: service_healthy
    ports:
      # Bind DNS/DHCP to the LAN interface only — not 0.0.0.0 — so the resolver
      # isn't reachable from untrusted networks (open-resolver / rogue-DHCP risk).
      - "{{ server_ip }}:53:53/tcp"
      - "{{ server_ip }}:53:53/udp"
      - "{{ server_ip }}:67:67/udp"
    {{ service_networks() }}
      - pihole_internal
    environment:
      TZ: {{ tz }}
      WEBPASSWORD: {{ pihole_password }}
      ServerIP: {{ server_ip }}
      FTLCONF_dns_upstreams: unbound
      FTLCONF_dns_listeningMode: all
      FTLCONF_misc_etc_dnsmasq_d: "true"
    volumes:
       - './data/etc-pihole/:/etc/pihole/'
       - './data/etc-dnsmasq.d/:/etc/dnsmasq.d/'
    security_opt:
      - no-new-privileges:true
    # FTL binds :53/:67/:80 (<1024 → NET_BIND_SERVICE), serves DHCP via raw sockets
    # (NET_RAW), and manages networking (NET_ADMIN). At startup FTL applies file caps to
    # its own binary so it can run as the non-root pihole user — that needs SETFCAP
    # (without it: "unable to set CAP_SETFCAP ... Cannot run as non-root"). The s6 init
    # chowns /etc/pihole and drops privileges (CHOWN/SETUID/SETGID/DAC_OVERRIDE); SYS_NICE
    # lets FTL set its scheduling priority. Add SYS_TIME only if Pi-hole NTP is enabled.
    # Highest-risk service (LAN DNS) — verify resolution + DHCP after deploy.
    cap_drop:
      - ALL
    cap_add:
      - NET_ADMIN
      - NET_BIND_SERVICE
      - NET_RAW
      - CHOWN
      - SETUID
      - SETGID
      - DAC_OVERRIDE
      - SYS_NICE
      - SETFCAP
    labels:
      # Disable watchtower update — pinned + Renovate-managed
      - "com.centurylinklabs.watchtower.enable=false"
      {# Generate labels(container, port, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          (container_item.networks | default([docker_network]))[0],
          container_item.use_authelia
        )
      }}
      {{ kuma(container_item.name) }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('1.0', '512M', '0.10', '64M') }}

{{ external_networks() }}
  # Not internal: Unbound performs recursive resolution and must reach the root
  # nameservers (outbound UDP/TCP :53). Don't flip to true — it breaks recursion.
  pihole_internal:
    internal: false
