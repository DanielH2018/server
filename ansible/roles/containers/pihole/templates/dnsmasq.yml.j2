address=/local.{{ domain }}/{{ server_ip }}
address=/local.{{ domain }}/::

# daniel-pi is LAN-only with no external vhost, so it gets a plain <host>.<domain> record
# WITHOUT the `.local` infix (that infix only exists on the server to distinguish local
# vs external access). Reach the Pi's LAN-bound services at daniel-pi.<domain>:<port>.
# IP via hostvars since the Pi isn't the host running Pi-hole. The server's own services
# are already covered by the *.local.<domain> wildcard above.
host-record=daniel-pi.{{ domain }},{{ hostvars['daniel-pi'].server_ip }}
