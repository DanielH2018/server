address=/local.{{ domain }}/{{ server_ip }}
address=/local.{{ domain }}/::

# daniel-pi is LAN-only. Use a private `.lan` TLD (resolves only here, via Pi-hole) instead
# of a <domain> subdomain: Traefik sets HSTS with stsIncludeSubdomains on the real domain,
# which force-upgrades any *.<domain> name to HTTPS and breaks the Pi's plain-HTTP services
# (SSL_ERROR_RX_RECORD_TOO_LONG). `.lan` sidesteps HSTS entirely. Reach the Pi's LAN-bound
# services at daniel-pi.lan:<port>. IP via hostvars since the Pi isn't the host running Pi-hole.
host-record=daniel-pi.lan,{{ hostvars['daniel-pi'].server_ip }}
