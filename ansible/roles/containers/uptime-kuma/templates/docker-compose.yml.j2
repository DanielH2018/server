{% from 'traefik.yml.j2' import labels with context %}
{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
{% from 'healthcheck.yml.j2' import healthcheck %}
---

services:
  uptime-kuma:
    image: louislam/uptime-kuma:2.4.0
    container_name: uptime-kuma
    volumes:
      - ./data:/app/data
    restart: unless-stopped
    cap_drop:
      - ALL
    cap_add:
      # Ping monitors (daniel-pi-host) need raw ICMP sockets; with cap_drop ALL the
      # ping binary fails with "operation not permitted" and the monitor can never
      # be up. NET_RAW is the narrow, standard grant for monitoring containers.
      - NET_RAW
    security_opt:
      - no-new-privileges:true
    {{ service_networks() }}
    labels:
      {# Generate labels(container, port, docker_network, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          (container_item.networks | default([docker_network]))[0],
          container_item.use_authelia
        )
      }}
      # Disable watchtower update — pinned + Renovate-managed
      - "com.centurylinklabs.watchtower.enable=false"
      {{ kuma(container_item.name) }}
      # AutoKuma-managed Discord notification (id: discord == kuma_notification_id); the kuma()
      # macro links every monitor to it via notification_name_list. Webhook in secrets.yml.
      # Defining notifications via labels is flagged experimental by AutoKuma.
      - "kuma.discord.notification.name=Homelab Alerts"
      - "kuma.discord.notification.active=true"
      - 'kuma.discord.notification.config={"type":"discord","discordWebhookUrl":"{{ monitor_discord_webhook_url }}","discordUsername":"Uptime Kuma"}'
      # daniel-pi monitors (static, defined here like the notification above): AutoKuma
      # only reads the SERVER's docker socket, so the kuma() labels rendered on the Pi's
      # own compose files are never seen. Probe the Pi's LAN-bound UIs over HTTP instead
      # (expose_mode: lan already publishes them on the Pi's LAN IP — no new exposure),
      # plus a ping for the host itself.
      - "kuma.daniel-pi-host.ping.name=Daniel Pi Host"
      - "kuma.daniel-pi-host.ping.hostname={{ hostvars['daniel-pi'].server_ip }}"
      - "kuma.daniel-pi-host.ping.interval=60"
      - "kuma.daniel-pi-host.ping.maxretries=2"
      - 'kuma.daniel-pi-host.ping.notification_name_list=["{{ kuma_notification_id }}"]'
      {{ kuma('daniel-pi-glances', name='Daniel Pi Glances', monitor_type='http',
              url='http://' ~ hostvars['daniel-pi'].server_ip ~ ':61208') }}
      {{ kuma('daniel-pi-dozzle', name='Daniel Pi Dozzle', monitor_type='http',
              url='http://' ~ hostvars['daniel-pi'].server_ip ~ ':8080') }}
      {{ kuma('daniel-pi-wg-easy', name='Daniel Pi WG Easy', monitor_type='http',
              url='http://' ~ hostvars['daniel-pi'].server_ip ~ ':51821') }}
      # Pi SD-card health: SD cards have no SMART, so a dying card only announces
      # itself via ext4 errors. The Pi's pi-sd-health.sh cron (optimize_pi role)
      # pushes errors_count every 5 min through the LAN-bypassed push API
      # (authelia: ^/api/push/ on this .local host); interval 600 = 2x the cron,
      # so the push watchdog also catches a dead cron/host.
      {{ kuma('daniel-pi-sd-health', name='Daniel Pi SD Health', monitor_type='push', interval=600, push_token=pi_sd_health_push_token) }}
      # Secret rotation: a daily server cron (secret-rotation-audit.sh, initial_setup) runs
      # scripts/secret_rotation.py audit --push — down when any secret is past its
      # per-tier rotation window OR an unregistered secret exists (run `sync`). interval
      # 90000s (25h) = 1 day + slack, so a dead audit cron also trips the push watchdog.
      {{ kuma('secret-rotation', name='Secret Rotation', monitor_type='push', interval=90000, push_token=secret_rotation_push_token) }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('0.50', '512M', '0.05', '64M') }}

  # AutoKuma lives in this stack so a redeploy of uptime-kuma (recreate: always)
  # also recreates autokuma, refreshing its Kuma Socket.IO session. It needs
  # uptime-kuma (API) and docker-proxy (read-only socket) reachable on this network.
  autokuma:
    image: ghcr.io/bigboot/autokuma:latest
    container_name: autokuma
    restart: unless-stopped
    # Run as 1000:1000 (owner of ./autokuma-data) so it can create its DB without
    # needing root + DAC_OVERRIDE — keeps cap_drop: [ALL] effective.
    user: "{{ puid }}:{{ pgid }}"
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    depends_on:
      uptime-kuma:
        condition: service_started
        # Recreating uptime-kuma invalidates AutoKuma's Socket.IO session (endless
        # "You are not logged in" sync errors). Deploys are recreate:auto (only the
        # changed service is recreated), so the old "same stack = recreated together"
        # assumption no longer holds — restart the sidecar with its dependency.
        restart: true
    environment:
      - AUTOKUMA__KUMA__URL=http://uptime-kuma:3001
      - AUTOKUMA__KUMA__USERNAME={{ uptime_kuma_username }}
      - AUTOKUMA__KUMA__PASSWORD={{ uptime_kuma_password }}
      - AUTOKUMA__DOCKER__HOSTS=tcp://docker-proxy:2375
      - AUTOKUMA__DB_PATH=/data/autokuma.db
    volumes:
      - ./autokuma-data:/data
    {{ service_networks() }}
    {{ healthcheck('["CMD", "bash", "-c", "cat /proc/1/comm | grep -q autokuma"]', timeout='5s', start_period='10s') }}
    labels:
      - "com.centurylinklabs.watchtower.depends-on=docker-proxy,uptime-kuma"
      {{ kuma('autokuma') }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('0.50', '256M', '0.05', '32M') }}

{{ external_networks() }}
