{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
{% from 'healthcheck.yml.j2' import healthcheck %}
---

services:
  mosquitto:
    # 2.1.x publishes ONLY -alpine variant tags (bare 2.1.2 does not exist — pull fails
    # "manifest unknown"); 2.1.2-alpine is digest-identical to the :2 channel tag it replaced.
    image: eclipse-mosquitto:2.1.2-alpine
    container_name: mosquitto
    user: "{{ puid }}:{{ pgid }}"
    environment:
      - TZ={{ tz }}
    volumes:
      - ./config:/mosquitto/config
      - ./data:/mosquitto/data
    restart: unless-stopped
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    # Read-only rootfs: `docker diff` is empty — runs as non-root 1000:1000 with all
    # persistent state on the ./config + ./data bind mounts (log_dest is stdout), so no
    # tmpfs is needed. Verified 2026-07-05.
    read_only: true
    {{ service_networks() }}
    # $$SYS stays doubled so Compose passes a literal $SYS to the broker (validate-hook won't catch it).
    {{ healthcheck("[\"CMD-SHELL\", \"mosquitto_sub -h localhost -p 1883 -u " ~ mqtt_username ~ " -P " ~ mqtt_password ~ " -t '$$SYS/broker/uptime' -C 1 -W 3 >/dev/null 2>&1 || exit 1\"]") }}
    labels:
      # Disable watchtower update — pinned + Renovate-managed
      - "com.centurylinklabs.watchtower.enable=false"
      {{ kuma(container_item.name, name='Mosquitto') }}
    # Resource caps for blast-radius containment (M1); broker is tiny — tune from Grafana.
    {{ resources('0.25', '64M', '0.02', '16M') }}

{{ external_networks() }}
