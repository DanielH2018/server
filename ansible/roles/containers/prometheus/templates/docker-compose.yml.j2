{% from 'traefik.yml.j2' import labels with context %}
{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'healthcheck.yml.j2' import healthcheck %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
---

services:
  node-exporter:
    image: prom/node-exporter:latest
    container_name: node-exporter
    hostname: node-exporter
    restart: unless-stopped
    # Read-only host exporter: runs root but only reads world-readable /host/proc + /host/sys,
    # so it needs no capabilities. Verify metrics still populate on deploy (probe metric 'node_load1').
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    # Read-only rootfs: `docker diff` shows only its bind mounts (/host/*, /rootfs, /textfile),
    # zero rootfs writes — no tmpfs needed.
    read_only: true
    volumes:
      - /proc:/host/proc:ro
      - /sys:/host/sys:ro
      - /:/rootfs:ro
      # Textfile collector: cron scripts drop *.prom gauges here (e.g. kopia-b2-usage.sh writes
      # kopia_b2_billable_bytes for the B2-usage trend graph). Dir is created by this role's tasks.
      - /var/lib/node-exporter-textfile:/textfile:ro
    command:
      - '--path.procfs=/host/proc'
      - '--path.rootfs=/rootfs'
      - '--path.sysfs=/host/sys'
      - '--collector.filesystem.mount-points-exclude=^/(sys|proc|dev|host|etc)($$|/)'
      - '--collector.textfile.directory=/textfile'
      # Collectors that are off by default but read the already-mounted /host/proc.
      # Back the Node Exporter Full panels for processes (PIDs/threads/states),
      # interrupts (IRQ) and TCP connection stats — empty otherwise.
      - '--collector.processes'
      - '--collector.interrupts'
      - '--collector.tcpstat'
    expose:
      - 9100
    {{ service_networks() }}
    {{ healthcheck('wget --no-verbose --tries=1 -O /dev/null http://localhost:9100/metrics || exit 1') }}
    labels:
      {{ kuma('node-exporter') }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('0.50', '256M', '0.05', '32M') }}

  cadvisor:
    image: ghcr.io/google/cadvisor:v0.53.0
    container_name: cadvisor
    # cAdvisor is the per-container stats exporter — it reads cgroup/usage data straight off the
    # host, so the broad access below is inherent to the job, not incidental: the read-only host
    # mounts (rootfs, /sys, docker state, cgroup tree) are where the metrics live, and SYS_PTRACE
    # gives per-container process/namespace visibility. That's why cadvisor is deliberately
    # CAP_DROP_EXEMPT (compose-validator allowlist) and can't be hardened further without blinding
    # the metrics. Docker itself is reached via the READ-ONLY docker-proxy (--docker tcp:2375 in
    # command), never a raw /var/run/docker.sock mount.
    cap_add:
      - SYS_PTRACE
    security_opt:
      - no-new-privileges:true
    # Read-only rootfs: `docker diff` shows only its bind mounts (/rootfs, /sys, docker
    # state) + in-memory stats (storage_duration=5m), zero rootfs writes — no tmpfs needed.
    read_only: true
    volumes:
      - /:/rootfs:ro
      - /sys:/sys:ro
      - /var/lib/docker/:/var/lib/docker:ro
      - /sys/fs/cgroup:/sys/fs/cgroup:ro
    command:
      - '--docker=tcp://docker-proxy:2375'
      - '--housekeeping_interval=60s'
      - '--storage_duration=5m'
      - '--store_container_labels=false'
      - '--docker_only=true'
      - '--disable_metrics=hugetlb,memory_numa,tcp,udp,referenced_memory,disk,diskIO,percpu,sched,process,cpu_topology,perf_event,advtcp'
    {{ service_networks() }}
    restart: unless-stopped
    labels:
      # Disable watchtower update — version-pinned (immutable tag)
      - "com.centurylinklabs.watchtower.enable=false"
      {{ kuma('cadvisor', name='cAdvisor') }}
    {{ resources('0.30', '1000M', '0.10', '100M') }}

  prometheus:
    image: prom/prometheus:latest
    container_name: prometheus
    restart: unless-stopped
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    volumes:
     - ./:/etc/prometheus/
     - prometheus_data:/prometheus
    command:
      # Overriding command replaces the image CMD, so restate the stock flags first.
      - '--config.file=/etc/prometheus/prometheus.yml'
      - '--storage.tsdb.path=/prometheus'
      # Explicit retention (default is only 15d). ~350M covered 15d here, so 90d of
      # trend history costs ~2G; the size cap is the backstop if series ever explode.
      - '--storage.tsdb.retention.time=90d'
      - '--storage.tsdb.retention.size=10GB'
    {{ service_networks() }}
    {{ healthcheck('wget --no-verbose --tries=1 --spider http://localhost:9090/ || exit 1') }}
    labels:
      {# Generate labels(container, port, docker_network, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          (container_item.networks | default([docker_network]))[0],
          container_item.use_authelia
        )
      }}
      {{ kuma(container_item.name) }}
    # Resource caps for blast-radius containment (M1). TSDB memory grows with
    # series count, so size generously and tune from cAdvisor/Grafana.
    {{ resources('2.0', '2048M', '0.25', '256M') }}

{{ external_networks() }}
volumes:
    prometheus_data:
