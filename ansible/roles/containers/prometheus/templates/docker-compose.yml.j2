{% from 'traefik.yml.j2' import labels with context %}
{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'healthcheck.yml.j2' import healthcheck %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
---

services:
  node-exporter:
    image: prom/node-exporter:latest
    container_name: node-exporter
    hostname: node-exporter
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    volumes:
      - /proc:/host/proc:ro
      - /sys:/host/sys:ro
      - /:/rootfs:ro
    command:
      - '--path.procfs=/host/proc'
      - '--path.rootfs=/rootfs'
      - '--path.sysfs=/host/sys'
      - '--collector.filesystem.mount-points-exclude=^/(sys|proc|dev|host|etc)($$|/)'
      # Collectors that are off by default but read the already-mounted /host/proc.
      # Back the Node Exporter Full panels for processes (PIDs/threads/states),
      # interrupts (IRQ) and TCP connection stats — empty otherwise.
      - '--collector.processes'
      - '--collector.interrupts'
      - '--collector.tcpstat'
    expose:
      - 9100
    {{ service_networks() }}
    {{ healthcheck('wget --no-verbose --tries=1 -O /dev/null http://localhost:9100/metrics || exit 1') }}
    labels:
      {{ kuma('node-exporter') }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    deploy:
      resources:
        limits:
          cpus: '0.50'
          memory: 256M
        reservations:
          cpus: '0.05'
          memory: 32M

  cadvisor:
    image: ghcr.io/google/cadvisor:v0.53.0
    container_name: cadvisor
    cap_add:
      - SYS_PTRACE
    security_opt:
      - no-new-privileges:true
    volumes:
      - /:/rootfs:ro
      - /sys:/sys:ro
      - /var/lib/docker/:/var/lib/docker:ro
      - /sys/fs/cgroup:/sys/fs/cgroup:ro
    command:
      - '--docker=tcp://docker-proxy:2375'
      - '--housekeeping_interval=60s'
      - '--storage_duration=5m'
      - '--store_container_labels=false'
      - '--docker_only=true'
      - '--disable_metrics=hugetlb,memory_numa,tcp,udp,referenced_memory,disk,diskIO,percpu,sched,process,cpu_topology,perf_event,advtcp'
    {{ service_networks() }}
    restart: unless-stopped
    labels:
      {{ kuma('cadvisor', name='cAdvisor') }}
    deploy:
      resources:
        limits:
          cpus: '0.30'        # Hard Limit: Capped at 30% of one core
          memory: 1000M        # Hard Limit: Max 1000MB RAM
        reservations:
          cpus: '0.10'        # Guarantees it at least 10%
          memory: 100M

  prometheus:
    image: prom/prometheus:latest
    container_name: prometheus
    restart: unless-stopped
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    volumes:
     - ./:/etc/prometheus/
     - prometheus_data:/prometheus
    {{ service_networks() }}
    {{ healthcheck('wget --no-verbose --tries=1 --spider http://localhost:9090/ || exit 1') }}
    labels:
      {# Generate labels(container, port, docker_network, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          (container_item.networks | default([docker_network]))[0],
          container_item.use_authelia
        )
      }}
      {{ kuma(container_item.name) }}
    # Resource caps for blast-radius containment (M1). TSDB memory grows with
    # series count, so size generously and tune from cAdvisor/Grafana.
    deploy:
      resources:
        limits:
          cpus: '2.0'
          memory: 2048M
        reservations:
          cpus: '0.25'
          memory: 256M

{{ external_networks() }}
volumes:
    prometheus_data:
