# my global config
global:
  scrape_interval:     1m
  evaluation_interval: 1m

# No Alertmanager: alerting is handled out-of-band by the monitor-bridge sidecar
# (Prometheus metrics -> Uptime Kuma push monitors -> Discord), not by Prometheus
# rules + Alertmanager. See ansible/roles/containers/monitor-bridge/.

scrape_configs:
  - job_name: 'prometheus'
    scrape_interval: 1m
    static_configs:
    - targets: ['localhost:9090']

#################################################################################################

  - job_name: 'traefik'
    scrape_interval: 15s
    static_configs:
      - targets: ['traefik:8080']

#################################################################################################

  - job_name: "node"
    scrape_interval: 1m
    static_configs:
    - targets: ["node-exporter:9100"]
    metric_relabel_configs:
      # Pin a single, consistent `instance` across ALL node metrics. The previous rule
      # sourced `instance` from the `nodename` label, which only exists on node_uname_info
      # — so it stripped `instance` off every other node metric and broke node dashboards
      # (panels filtering on instance="$node" matched nothing). A static replacement keeps
      # one stable host identity everywhere.
      - target_label: instance
        replacement: daniel-server

#################################################################################################

  - job_name: "cadvisor"
    scrape_interval: 1m
    static_configs:
    - targets: ["cadvisor:8080"]

#################################################################################################

  # Loki's own /metrics (ingestion rate, chunk-flush errors, request latencies) on its HTTP
  # port — Loki and Prometheus share the `monitoring` net. The failure CASES are already
  # caught out-of-band (monitor-bridge's loki_ingestion check + the Kuma /ready probe); this
  # adds the trendable HISTORY (ingestion/error graphs in Grafana) those point-in-time checks
  # don't retain.
  - job_name: "loki"
    scrape_interval: 1m
    static_configs:
    - targets: ["loki:3100"]

#################################################################################################

  # Promtail's own /metrics (per-target send failures, promtail_dropped_entries_total,
  # positions-file lag) on its :9080 server port — Promtail and Prometheus share `monitoring`.
  # The loki_ingestion bridge check only trips at ZERO lines; this surfaces PARTIAL log-shipping
  # loss (dropped/rate-limited entries) plus the trend history that point-in-time check can't retain.
  - job_name: "promtail"
    scrape_interval: 1m
    static_configs:
    - targets: ["promtail:9080"]

#################################################################################################

  # Uptime-Kuma's own /metrics (per-monitor up/down, response times, cert-days-remaining) —
  # Kuma and Prometheus share the `monitoring` net. The endpoint is API-key protected, sent as
  # HTTP Basic auth: blank username, password = the key (prometheus_kuma_api_key in SOPS).
  - job_name: "uptime-kuma"
    scrape_interval: 1m
    metrics_path: /metrics
    basic_auth:
      username: ""
      password: "{{ prometheus_kuma_api_key }}"
    static_configs:
    - targets: ["uptime-kuma:3001"]

#################################################################################################

  {# - job_name: 'netdata-scrape'
    scrape_interval: 1m
    metrics_path: '/api/v1/allmetrics'
    params:
      format: [prometheus]
    honor_labels: true
    static_configs:
      - targets: ['netdata:19999'] #}

#################################################################################################


  - job_name: "crowdsec_daniel-server"
    scrape_interval: 1m
    static_configs:
    - targets: ["crowdsec:6060"]
      labels:
        machine: 'daniel-server'

  - job_name: "terraria-stats"
    scrape_interval: 1m
    static_configs:
    - targets: ["terraria-stats:9420"]

  - job_name: "home-assistant"
    scrape_interval: 1m
    metrics_path: /api/prometheus
    authorization:
      credentials: "{{ prometheus_ha_token }}"
    static_configs:
      - targets: ["home-assistant:8123"]

#################################################################################################
