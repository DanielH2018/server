http:
 #region routers
  routers:
    dashboard:
      entryPoints:
        - https
      rule: "Host(`traefik.{{ domain }}`) || Host(`traefik.local.{{ domain }}`)"
      service: api@internal
      middlewares:
        # rate-limit is now applied per-router (it was removed from the https
        # entrypoint so the livesync router can opt into a higher ceiling).
        # default-headers is NOT repeated here — it's already applied globally on the
        # https entrypoint (traefik.yml.j2), so listing it again was a redundant no-op.
        - rate-limit
        - authelia
      tls: {}

    livesync:
      # Obsidian LiveSync sync API — defined HERE (traefik file provider, mode 0600, so only
      # the traefik process reads it) instead of as a Docker label on the couchdb container,
      # so the secret X-Sync-Token stays OUT of container metadata. Any container on the shared
      # `apps` network can read every container's labels via the docker-proxy (CONTAINERS=1),
      # which would have leaked the token from the old label form. A request must carry the
      # matching token or it matches NO router for the host and 404s before reaching CouchDB;
      # CouchDB's own require_valid_user is the second layer (defence in depth). The couchdb
      # service is referenced cross-provider (livesync@docker) — the role still publishes it via
      # its one remaining service label. Default (rule-length) priority is preserved from the old
      # label, so the priority=200 livesync-utils router still wins for /_utils.
      entryPoints:
        - https
      rule: "(Host(`livesync.{{ domain }}`) || Host(`livesync.local.{{ domain }}`)) && Header(`X-Sync-Token`, `{{ livesync_sync_token }}`)"
      service: livesync@docker
      middlewares:
        - rate-limit-livesync
      tls:
        certResolver: cloudflare
        domains:
          - main: "{{ domain }}"
            sans:
              - "*.{{ domain }}"
              - "*.local.{{ domain }}"

    homelab-mcp:
      # Read-only homelab MCP server (roles/containers/homelab-mcp). LAN-ONLY: matches only
      # mcp.local.<domain> (NO public mcp.<domain> router) AND requires the bearer token in the
      # Authorization header. Defined here (file provider, mode 0600) — not as a Docker label —
      # so the token stays out of container metadata (the livesync X-Sync-Token pattern). A
      # request without the exact token matches NO router for the host and 404s before the app;
      # the app re-checks the token too (defence in depth, for shared-net peers skipping Traefik).
      entryPoints:
        - https
      rule: "Host(`mcp.local.{{ domain }}`) && Header(`Authorization`, `Bearer {{ homelab_mcp_token }}`)"
      service: homelab-mcp@docker
      middlewares:
        - rate-limit
      tls:
        certResolver: cloudflare
        domains:
          - main: "{{ domain }}"
            sans:
              - "*.{{ domain }}"
              - "*.local.{{ domain }}"

#endregion
#region services
  services:
    # (Empty for now, as api@internal is built-in)

#endregion
  middlewares:
    # (HTTP→HTTPS redirection lives on the web entrypoint in traefik.yml — a
    # redirectScheme middleware here would be dead config.)
    default-headers:
      headers:
        customResponseHeaders:
          Permissions-Policy: "geolocation=(self), microphone=(), camera=(), fullscreen=(self), usb=()"
          # No global Content-Security-Policy here: Traefik's customResponseHeaders REPLACES the
          # backend's header, so a blanket CSP clobbers the stricter, per-app CSPs that apps like
          # FreshRSS and Homepage set themselves (FreshRSS even self-detects the weakened header and
          # warns of XSS exposure). Clickjacking is already covered by X-Frame-Options SAMEORIGIN
          # below. Set CSP per-app via a dedicated headers middleware where origins are known-good.
        referrerPolicy: "strict-origin-when-cross-origin"
        # No frameDeny: customFrameOptionsValue (SAMEORIGIN, below) takes precedence in Traefik,
        # so frameDeny:true was dead config that misrepresented the effective policy as DENY.
        # SAMEORIGIN is intentional (allows same-origin iframes).
        browserXssFilter: true
        contentTypeNosniff: true
        forceSTSHeader: true
        stsIncludeSubdomains: true
        # No `stsPreload` on purpose: the preload directive is only honoured by
        # browsers at max-age >= 1 year (31536000s), so at 180 days it's a no-op
        # that advertises an intent we can't fulfil. Preloading is also a hard-to-
        # reverse commitment that would force HTTPS on every *.{{ domain }} subdomain
        # baked into browsers — not worth it for a homelab. Keep HSTS without preload.
        stsSeconds: 15552000
        customFrameOptionsValue: SAMEORIGIN
        customRequestHeaders:
          X-Forwarded-Proto: https

    # Per-app Content-Security-Policy — the concrete case the default-headers note above points at
    # ("Set CSP per-app via a dedicated headers middleware where origins are known-good"). There's
    # deliberately no GLOBAL CSP because customResponseHeaders REPLACES the backend header, which
    # would clobber apps that self-set a stricter one (freshrss, homepage). karakeep sends none of
    # its own and renders untrusted saved web pages/snapshots into an authenticated session, so it
    # gets one here. Permissive-but-real: it's a Next.js app that needs 'unsafe-inline'/'unsafe-eval',
    # so inline-script INJECTION isn't blocked — but loading EXTERNAL scripts, plugin objects
    # (object-src none), <base> hijacking, cross-origin exfil via fetch/websocket/form-post, and
    # clickjacking (frame-ancestors) all are. Attached to karakeep's MAIN router only, via the
    # labels() macro's extra_middlewares arg (the /api bypass router serves JSON — a CSP there does
    # nothing). img-src allows https: so cached-page/favicon art isn't broken; tighten to
    # `'self' data: blob:` if karakeep is confirmed to proxy all its images same-origin.
    csp-karakeep:
      headers:
        customResponseHeaders:
          Content-Security-Policy: >-
            default-src 'self'; base-uri 'self'; object-src 'none';
            script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline';
            img-src 'self' data: blob: https:; font-src 'self' data:;
            connect-src 'self'; media-src 'self' data: blob:; frame-src 'self' blob:;
            worker-src 'self' blob:; manifest-src 'self'; frame-ancestors 'self';
            form-action 'self'

    crowdsec:
      plugin:
        bouncer:
          enabled: true
          crowdsecLapiKey: "{{ crowdsec_bouncer_api_key }}"
          crowdsecLapiHost: "crowdsec:8080"
          crowdsecMode: stream
          updateIntervalSeconds: 60
          # AppSec Component — inline L7 WAF (see crowdsec-acquis.yaml.j2). stream mode above is the
          # reactive ban-list (bans an IP after a pattern of log lines); this inspects each request
          # inline BEFORE the backend, so a first-hit malicious payload (CVE string / SQLi / path
          # traversal) is blocked, not merely banned-after-the-fact. crowdsec:7422 is the appsec
          # acquisition listener on the shared `proxy` net. UnreachableBlock:false = FAIL OPEN: an
          # appsec-broker/crowdsec hiccup keeps the edge serving (defers to the ban-list) instead of
          # 500ing the fleet — the add-on must not become a new edge SPOF. FailureBlock keeps its
          # secure default (a rule-eval error on a request blocks that one request).
          crowdsecAppsecEnabled: true
          crowdsecAppsecHost: "crowdsec:7422"
          crowdsecAppsecUnreachableBlock: false

    rate-limit:
      rateLimit:
        average: 300
        burst: 150
        period: 1m

    # CouchDB / Obsidian LiveSync only. Replication is extremely chatty (_changes,
    # _revs_diff, _bulk_docs, per-chunk reads), so it gets a much higher ceiling than
    # the shared `rate-limit` default. Applied per-router on the livesync sync router
    # (rate-limit-livesync@file) — see roles/containers/livesync. Keyed on source IP
    # like the default limiter (Traefik's rateLimit default sourceCriterion).
    rate-limit-livesync:
      rateLimit:
        average: 6000
        burst: 600
        period: 1m

    authelia:
      forwardAuth:
        address: "http://authelia:9091/api/authz/forward-auth"
        trustForwardHeader: true
        authResponseHeaders:
          - "Remote-User"
          - "Remote-Groups"
          - "Remote-Name"
          - "Remote-Email"
        maxResponseBodySize: 1048576

tls:
  stores:
    default:
      defaultGeneratedCert:
        resolver: cloudflare
        domain:
          main: "{{ domain }}"
          sans:
            - "*.{{ domain }}"
            - "*.local.{{ domain }}"
  options:
    default:
      minVersion: 'VersionTLS12'
      cipherSuites:
        - 'TLS_ECDHE_ECDSA_WITH_AES_128_GCM_SHA256'
        - 'TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256'
        - 'TLS_ECDHE_ECDSA_WITH_AES_256_GCM_SHA384'
        - 'TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384'
        - 'TLS_ECDHE_ECDSA_WITH_CHACHA20_POLY1305'
        - 'TLS_ECDHE_RSA_WITH_CHACHA20_POLY1305'
