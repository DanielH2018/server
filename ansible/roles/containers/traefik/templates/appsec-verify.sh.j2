#!/bin/bash
# Watchdog for the CrowdSec AppSec inline WAF (config.yml.j2 `crowdsecAppsecEnabled` + the `appsec`
# acquisition source in crowdsec-acquis.yaml.j2). The bouncer fails OPEN
# (`crowdsecAppsecUnreachableBlock: false`), so if the appsec engine stops loading its config/rulesets
# — a bad `cscli collections upgrade`, a hub rename dropping appsec-virtual-patching/appsec-generic-
# rules, a broken appsec-default config — the edge silently degrades to ban-list-only with NO signal:
# Scrape Targets only catches a TOTAL crowdsec death (the container stays up + `cscli lapi status`
# healthy). This asserts the live agent has >=1 ENABLED appsec-config AND >=1 ENABLED appsec-rule
# loaded — both traffic-independent (unlike the cs_appsec_* request counters, which read zero on a
# quiet homelab and would false-page). Writes {"ts","ok","msg"} to STATE every run; monitor-bridge's
# `appsec` check reads it (:ro bind mount) and pushes the "CrowdSec AppSec" Kuma monitor on a failed
# assert or staleness. Runs as root (docker exec). `set -uo` (not -euo) so a failed assert is captured
# + reported, not swallowed by an early exit (docker-user-verify / cloudflare-ip-drift / kopia idiom).
set -uo pipefail

# shellcheck source=/dev/null
source /usr/local/lib/traefik-lib.sh
STATE=/var/lib/crowdsec-appsec/state.json
write_state() { traefik_write_state "$STATE" crowdsec-appsec-verify "$@"; } # ok msg

# DEFER a TOTAL crowdsec outage to the monitors that already own it — the crowdsec container's own
# Kuma monitor and Prometheus Scrape Targets (crowdsec:6060). This check owns ONLY the fail-open-
# while-crowdsec-is-UP blind spot (a silently-broken appsec engine); paging here on crowdsec death
# too would triple-page one root cause and misdirect, and this every-15-min cron could false-page in
# the crowdsec-still-starting window after the weekly reboot. Mirrors check_ups' NUT-down defer
# (same commit). `cscli lapi status` is exactly crowdsec's OWN healthcheck gate, so "crowdsec healthy"
# and "this check runs its asserts" stay in lockstep. write ok + exit 0 so the monitor stays green.
if ! docker exec crowdsec cscli lapi status >/dev/null 2>&1; then
  write_state true "crowdsec unreachable — deferring to Scrape Targets + the crowdsec monitor"
  exit 0
fi

CONFIGS=$(docker exec crowdsec cscli appsec-configs list -o json 2>/dev/null \
  | jq '[.["appsec-configs"][]? | select(.status == "enabled")] | length' 2>/dev/null)
if [ -z "$CONFIGS" ]; then
  write_state false "cscli appsec-configs list failed though LAPI is up (appsec query error)"
  exit 1
fi
if [ "$CONFIGS" -lt 1 ]; then
  write_state false "no enabled appsec-configs — inline WAF not loaded, edge is ban-list-only"
  exit 1
fi

# Count ENABLED appsec-rules (symmetric with the appsec-configs filter above). `appsec-rules list`
# doesn't expose inband-vs-outofband (that's an appsec-config assignment, not a rule property), so
# `status == "enabled"` — a loaded, non-disabled rule — is the closest traffic-independent proxy for
# "the WAF is actually armed"; the old unfiltered count also counted any installed-but-disabled rule.
RULES=$(docker exec crowdsec cscli appsec-rules list -o json 2>/dev/null \
  | jq '[.["appsec-rules"][]? | select(.status == "enabled")] | length' 2>/dev/null)
if [ -z "$RULES" ]; then
  write_state false "cscli appsec-rules list failed though LAPI is up (appsec query error)"
  exit 1
fi
if [ "$RULES" -lt 1 ]; then
  write_state false "0 enabled appsec-rules loaded — WAF config present but not enforcing"
  exit 1
fi

write_state true "$CONFIGS appsec-configs enabled, $RULES enabled rules loaded"
