#!/bin/bash
# Weekly drift check: is the hardcoded cloudflare_ips allowlist (group_vars/all.yml) still equal to
# Cloudflare's PUBLISHED ranges? That list gates BOTH Traefik's forwardedHeaders.trustedIPs AND the
# DOCKER-USER origin-lock DROP (docker-user-rules.sh), so if Cloudflare adds a range a client
# arriving on it is silently DROPped at the edge firewall with no log trail (reads like a random
# regional outage). Cloudflare changes these ~once per several years, so this is a low-frequency
# safety net; it ALERTS on drift, it never auto-applies a fetched list to a firewall.
#
# Reporting: writes {"ts","ok","msg"} to STATE on EVERY run; monitor-bridge's `cloudflare_drift`
# check reads it (:ro bind mount) and pushes the "Cloudflare IP Drift" Kuma monitor — a failed fetch
# or a mismatch alerts. `set -uo` (not -euo) so a curl error is captured + reported, not swallowed by
# an early exit (same idiom as crowdsec-update-home-allowlist / the kopia crons).
set -uo pipefail

STATE=/var/lib/cloudflare-ip-drift/state.json

write_state() { # ok msg
  # jq, not printf: a stray control char in msg would make hand-built JSON invalid -> monitor-bridge
  # reads "state unparseable" (false DOWN). Matches crowdsec-update-home-allowlist / the kopia crons.
  jq -nc --argjson ts "$(date +%s)" --argjson ok "$1" --arg msg "$2" \
    '{ts: $ts, ok: $ok, msg: $msg}' > "$STATE"
  logger -t cloudflare-ip-drift "$1: $2"
}

# The expected set: the cloudflare_ips baked in at template time (group_vars/all.yml), one CIDR/line.
EXPECTED=$(cat <<'CFIPS' | sort
{% for ip in cloudflare_ips %}
{{ ip }}
{% endfor %}
CFIPS
)

if ! LIVE_V4=$(curl -sf --max-time 15 https://www.cloudflare.com/ips-v4); then
  write_state false "failed to fetch Cloudflare ips-v4"
  exit 1
fi
if ! LIVE_V6=$(curl -sf --max-time 15 https://www.cloudflare.com/ips-v6); then
  write_state false "failed to fetch Cloudflare ips-v6"
  exit 1
fi

LIVE=$(printf '%s\n%s\n' "$LIVE_V4" "$LIVE_V6" | sed '/^[[:space:]]*$/d' | sort)

if [ "$LIVE" = "$EXPECTED" ]; then
  write_state true "cloudflare_ips matches upstream ($(printf '%s\n' "$EXPECTED" | grep -c .) CIDRs)"
  exit 0
fi

# Drift: name what changed (added upstream = missing from our list; removed upstream = stale in ours).
ADDED=$(comm -23 <(printf '%s\n' "$LIVE") <(printf '%s\n' "$EXPECTED") | tr '\n' ' ')
REMOVED=$(comm -13 <(printf '%s\n' "$LIVE") <(printf '%s\n' "$EXPECTED") | tr '\n' ' ')
write_state false "cloudflare_ips DRIFTED from upstream — added:[${ADDED}] stale:[${REMOVED}] — update group_vars/all.yml + redeploy traefik"
exit 1
