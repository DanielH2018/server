api:
  dashboard: true
  insecure: false
  debug: false
ping: {}

entryPoints:
  http:
    address: ":80"
    forwardedHeaders:
      trustedIPs:
{% for ip in cloudflare_ips %}
        - "{{ ip }}"
{% endfor %}
        - "10.0.0.0/8"
        - "192.168.0.0/16"
        - "172.16.0.0/12"
        - "127.0.0.1/32"
    http:
      redirections:
        entryPoint:
          to: https
          scheme: https
      middlewares:
        - crowdsec@file
        # No rate-limit here: this entrypoint only 301s to https, and rate-limit is a single
        # per-IP bucket — counting the redirect too would double-charge each initial page load
        # against the per-router limiter on https. crowdsec@file still guards port 80.
  https:
    address: ":443"
    forwardedHeaders:
      trustedIPs:
{% for ip in cloudflare_ips %}
        - "{{ ip }}"
{% endfor %}
        - "10.0.0.0/8"
        - "192.168.0.0/16"
        - "172.16.0.0/12"
        - "127.0.0.1/32"
    http:
      middlewares:
        - crowdsec@file
        # rate-limit is NOT applied entrypoint-wide on https: it's attached per-router
        # (rate-limit@file via the shared labels() macro + each hand-rolled router) so
        # the livesync sync router can opt into the higher rate-limit-livesync ceiling.
        # An entrypoint-level middleware can't be loosened for a single router.
        - default-headers@file
  # Game-server entrypoints — re-enable alongside the published ports in the
  # compose template when Terraria/Minecraft are deployed again.
  terraria:
    address: ":7777"
  # minecraft:
  #   address: ":25565"
  ping:
    address: ":8082"

metrics:
  prometheus:
    addEntryPointsLabels: true
    addRoutersLabels: true
    addServicesLabels: true

serversTransport:
  insecureSkipVerify: false

providers:
  docker:
    endpoint: "tcp://docker-proxy:2375"
    exposedByDefault: false
  file:
    filename: /config.yml
    watch: true  # Added watch: true so you can edit config.yml without restarting Traefik

certificatesResolvers:
  cloudflare:
    acme:
      email: "{{ email }}"
      storage: acme.json
      dnsChallenge:
        provider: cloudflare
        resolvers:
          - "9.9.9.9:53"
          - "149.112.112.112:53"

log:
  filePath: "/var/log/traefik/traefik.log"
  format: json
  level: INFO
accessLog:
  filePath: "/var/log/traefik/access.log"
  format: json
  fields:
    defaultMode: keep
    names:
      StartUTC: drop

experimental:
  plugins:
    bouncer:
      moduleName: "github.com/maxlerebourg/crowdsec-bouncer-traefik-plugin"
      version: "v1.4.6"
