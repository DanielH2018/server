#!/bin/bash
# Watchdog for the DOCKER-USER origin lock (docker-user-rules.sh). The seed/re-assert units write no
# state, so without this a lock that got FLUSHED after boot — a docker network reload, a manual
# iptables -F, or a Docker engine upgrade that seeds a preempting terminal RETURN — would be invisible
# until an external scan found the origin open on 80/443. Reads the LIVE chain and asserts the terminal
# DROP for :80 and :443 is present (and that a RETURN allow precedes it, so we're not black-holing the
# origin), then writes {"ts","ok","msg"} to STATE every run. monitor-bridge's `docker_user` check reads
# it (:ro bind mount) and pushes the "DOCKER-USER Origin Lock" Kuma monitor on a failed assert or
# staleness (cron broken / never ran). Runs as root — iptables needs CAP_NET_ADMIN. `set -uo` (not
# -euo) so a failed assert is captured + reported, not swallowed by an early exit (kopia/crowdsec idiom).
set -uo pipefail

STATE=/var/lib/docker-user-rules/state.json

write_state() { # ok msg
  # jq (not printf) so a stray control char can't make hand-built JSON invalid. Temp + atomic rename,
  # chmod'ing the temp 0644 BEFORE the mv: this root cron writes a root-owned file, and the non-root
  # monitor-bridge container (UID 1000, :ro bind) reads it every 300s with no retry — so a mid-truncate
  # read would page a false "state unparseable" DOWN, and the swapped-in file must be world-readable
  # the instant it appears (a plain `>` truncates in place and would also expose the half-written file).
  jq -nc --argjson ts "$(date +%s)" --argjson ok "$1" --arg msg "$2" \
    '{ts: $ts, ok: $ok, msg: $msg}' > "$STATE.tmp" \
    && chmod 0644 "$STATE.tmp" && mv -f "$STATE.tmp" "$STATE"
  logger -t docker-user-verify "$1: $2"
}

if ! iptables -L DOCKER-USER -n >/dev/null 2>&1; then
  write_state false "DOCKER-USER chain missing — origin lock NOT applied"
  exit 1
fi

MISSING=
iptables -C DOCKER-USER -p tcp --dport 80 -j DROP 2>/dev/null || MISSING="$MISSING :80"
iptables -C DOCKER-USER -p tcp --dport 443 -j DROP 2>/dev/null || MISSING="$MISSING :443"
if [ -n "$MISSING" ]; then
  write_state false "terminal DROP missing for$MISSING — origin reachable direct (Cloudflare/CrowdSec bypass)"
  exit 1
fi

# `iptables -C` only proves a rule EXISTS, not that it's REACHABLE: an unconditional `-A DOCKER-USER
# -j RETURN` seeded AHEAD of our appended DROPs (what a future Docker engine could add if it ever
# recreates the chain — the scenario named in this script's header) would shadow them dead while the
# -C checks above still pass. The apply script NEVER emits a bare RETURN (its allows are all
# -s/--dport-qualified), so a whole-line `-A DOCKER-USER -j RETURN` in the live chain means the DROPs
# are being pre-empted — the exact origin bypass this watchdog exists for, which -C alone can't see.
if iptables -S DOCKER-USER | grep -qxF -- '-A DOCKER-USER -j RETURN'; then
  write_state false "unconditional RETURN shadows the DROP — origin reachable direct (Cloudflare/CrowdSec bypass); re-check after a Docker upgrade"
  exit 1
fi

# A DROP with no preceding RETURN allow would black-hole the origin (incl. Cloudflare). The apply
# script inserts a 10.0.0.0/8 LAN RETURN for BOTH ports, so assert both — a one-port divergence
# shouldn't read as fully applied.
RETURN_MISSING=
iptables -C DOCKER-USER -p tcp --dport 80 -s 10.0.0.0/8 -j RETURN 2>/dev/null || RETURN_MISSING="$RETURN_MISSING :80"
iptables -C DOCKER-USER -p tcp --dport 443 -s 10.0.0.0/8 -j RETURN 2>/dev/null || RETURN_MISSING="$RETURN_MISSING :443"
if [ -n "$RETURN_MISSING" ]; then
  write_state false "RETURN allow missing for$RETURN_MISSING — origin would be black-holed"
  exit 1
fi

write_state true "origin lock applied (DROP :80/:443 present + not shadowed, RETURN allows present)"
