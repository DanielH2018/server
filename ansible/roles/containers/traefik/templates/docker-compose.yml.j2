{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'resources.yml.j2' import resources %}
{% from 'healthcheck.yml.j2' import healthcheck %}
services:
  crowdsec:
    image: crowdsecurity/crowdsec:latest
    restart: unless-stopped
    container_name: crowdsec
    # Runs as root. DAC_OVERRIDE (read+write bypass) covers reading /var/log/auth.log
    # (mode 640, owned uid107:adm) AND writing into /etc/crowdsec (root dir owned by uid
    # 1000). SETUID/SETGID are required because the LAPI plugin broker forks the
    # notification plugin and drops it to the 'nobody' user — without them it fails with
    # "fork/exec notification-http: operation not permitted". DB is a root-owned volume.
    cap_drop:
      - ALL
    cap_add:
      - DAC_OVERRIDE
      - SETUID
      - SETGID
    security_opt:
      - no-new-privileges:true
    environment:
      GID: "${GID-{{ pgid }}}"
      COLLECTIONS: "crowdsecurity/linux crowdsecurity/traefik LePresidente/authelia"
    volumes:
      - ./crowdsec-config:/etc/crowdsec:rw
      - crowdsec-db:/var/lib/crowdsec/data/
      - /var/log/traefik:/var/log/traefik/:ro
      - /var/log/auth.log:/var/log/auth.log:ro
      - /var/log/authelia:/var/log/authelia/:ro
    # `cscli version` exits 0 as soon as the binary runs — before LAPI is listening on :8080 — so
    # traefik's `depends_on: service_healthy` could register the crowdsec@file bouncer during a
    # brief fail-open WAF window on every recreate. `cscli lapi status` round-trips the local API
    # (reads the agent creds, pings LAPI) and exits non-zero until LAPI accepts, so the gate now
    # means "WAF is ready".
    {{ healthcheck('["CMD", "cscli", "lapi", "status"]', start_period='20s') }}
    networks:
      - {{ (container_item.networks | default([docker_network]))[0] }}
      # Join monitoring so Prometheus can scrape the CrowdSec metrics endpoint
      # (crowdsec:6060, already bound 0.0.0.0). Without this the crowdsec scrape target
      # is permanently down and the Grafana CrowdSec dashboards have no data.
      - monitoring
    labels:
      # Keep :latest but pin against watchtower auto-updates — traefik depends_on this agent
      # (service_healthy) and traefik-init gates the boot restart on its health, so an
      # unsupervised pull that breaks crowdsec would block the edge's next start
      # (matches flaresolverr/unbound, the other health-gating :latest sidecars).
      - "com.centurylinklabs.watchtower.enable=false"
      {{ kuma('crowdsec') }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('1.0', '1024M', '0.10', '128M') }}

  traefik:
    image: traefik:v3.7.4
    container_name: traefik
    restart: unless-stopped
    depends_on:
      crowdsec:
        condition: service_healthy
    # Static Go binary that binds :80/:443 (<1024) → NET_BIND_SERVICE. Runs as root but
    # acme.json is 0600 owned by uid 1000, so root needs DAC_OVERRIDE to read it at start
    # and rewrite it on cert renewal — without it TLS breaks. Verify: a site loads over HTTPS.
    cap_drop:
      - ALL
    cap_add:
      - NET_BIND_SERVICE
      - DAC_OVERRIDE
    security_opt:
      - no-new-privileges:true
    networks:
      - proxy
      - monitoring
      - media
      - apps
      - kopia
    ports:
      # Bind v4-only (0.0.0.0). Docker does NOT manage ip6tables here (daemon
      # Experimental:false, no ip6tables key), so a bare "80:80" makes docker-proxy
      # also listen on [::] — and that v6 path bypasses the DOCKER-USER "Cloudflare-only
      # origin" allowlist (which is iptables/v4-only). LAN *.local is already forced to
      # v4 (dnsmasq AAAA=::) and no AAAA is published, so v4-only publish loses nothing.
      - 0.0.0.0:80:80
      - 0.0.0.0:443:443
      # Raw-TCP game-server entrypoints bypass the CrowdSec + rate-limit chain
      # (no HTTP middleware on TCP routers) — only publish when the server is live.
      - 0.0.0.0:7777:7777/tcp  # terraria
      # - 0.0.0.0:25565:25565/tcp  # minecraft (still archived)
    environment:
      - CF_API_EMAIL={{ email }}
      - CF_DNS_API_TOKEN={{ cloudflare_dns_token }}
      # TZ (not an /etc/localtime mount): the image ships zoneinfo, so this gives access logs +
      # CrowdSec decision logs the homelab's America/Chicago like every other container (host is
      # UTC). Downstream-safe — promtail ships traefik lines on ingestion time (no timestamp
      # stage) and CrowdSec parses the RFC3339-with-offset `time` field in absolute terms.
      - TZ={{ tz }}
    volumes:
      - ./data/traefik.yml:/traefik.yml:ro
      - ./data/acme.json:/acme.json
      - ./data/dynamic:/dynamic:ro
      - /var/log/traefik:/var/log/traefik
    {{ healthcheck('["CMD", "traefik", "healthcheck"]') }}
    labels:
      # Disable watchtower update — pinned + Renovate-managed
      - "com.centurylinklabs.watchtower.enable=false"
      {{ kuma('traefik') }}
    # Resource caps for blast-radius containment (M1). Traefik is the ingress
    # edge — keep headroom so it stays responsive; tune from cAdvisor/Grafana.
    {{ resources('2.0', '1024M', '0.25', '256M') }}

networks:
  proxy:
    external: true
  monitoring:
    external: true
  media:
    external: true
  apps:
    external: true
  kopia:
    external: true

volumes:
  crowdsec-db:
    name: crowdsec-db
