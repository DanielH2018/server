[Unit]
Description=Wait for docker-proxy AND crowdsec to be healthy before starting Traefik
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
# Gate the boot-time Traefik restart on BOTH docker-proxy (the provider) and crowdsec (the
# WAF LAPI) being healthy. Compose `depends_on: crowdsec: service_healthy` is enforced only by
# `docker compose up`, NOT by the restart policy or this `docker restart`, so without the second
# wait Traefik would restart ~5-10s into boot while crowdsec LAPI is still starting (its
# healthcheck has start_period=20s); in stream mode the bouncer plugin then boots with an empty
# decision cache and fails OPEN until its first LAPI sync — a ~30-60s window every reboot where
# previously-banned IPs pass. Waiting for crowdsec `cscli lapi status` healthy closes it.
ExecStart=/bin/bash -c '\
  until docker ps \
    --filter "name=docker-proxy" \
    --filter "health=healthy" \
    --format "{% raw %}{{.Names}}{% endraw %}" \
    | grep -q "docker-proxy"; \
  do sleep 2; done && \
  until docker ps \
    --filter "name=crowdsec" \
    --filter "health=healthy" \
    --format "{% raw %}{{.Names}}{% endraw %}" \
    | grep -q "^crowdsec$"; \
  do sleep 2; done && \
  docker restart traefik'
TimeoutStartSec=300

[Install]
WantedBy=multi-user.target
