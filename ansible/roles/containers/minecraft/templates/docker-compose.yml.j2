{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
services:
  minecraft:
    image: itzg/minecraft-server:latest
    container_name: minecraft
    {{ service_networks() }}
    environment:
      EULA: "true"
      TYPE: FABRIC
      ENABLE_RCON: "false"
      VIEW_DISTANCE: 15
      MEMORY: 16G
      CONSOLE: "false"
      #ENABLE_AUTOPAUSE: "TRUE"
      tz: {{ tz }}
      VERSION: "1.21.10"
      ENABLE_COMMAND_BLOCK: "true"
      SPAWN_PROTECTION: 0
      ALLOW_FLIGHT: "TRUE"
      # DittoHippo11 # Sophie
      # CurrentlyBroke # IDK
      # PoutyPicklez # Anna
      # handel6619 # Nick
      # LordAlpaca57 # Marco
      WHITELIST: |
        DBoy13
        hannahcevs
        CryingPie
        Hei_Jman
        PoutyPicklez
        handel6619
        LordAlpaca57
        V1RuSWasNotTaken
        Haovk
        DittoHippo11
        CurrentlyBroke
        deathknightmm
    volumes:
      - ./data:/data
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    labels:
      - "traefik.enable=true"
      - "traefik.tcp.routers.minecraft.entrypoints=minecraft"
      - "traefik.tcp.routers.minecraft.rule=HostSNI(`*`)"
      - "traefik.tcp.services.minecraft.loadbalancer.server.port=25565"
      {{ kuma(container_item.name) }}
    restart: unless-stopped
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    # memory must exceed the 16G JVM heap (MEMORY env) plus off-heap/GC overhead.
    {{ resources('6.0', '20480M', '1.0', '4096M') }}

{{ external_networks() }}
