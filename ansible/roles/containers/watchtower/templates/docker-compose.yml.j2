{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}

services:
  watchtower:
    image: nickfedor/watchtower:latest
    container_name: watchtower
    user: {{ puid }}:{{ pgid }}
    restart: unless-stopped
    # Go binary that only talks to the lifecycle socket-proxy over TCP; needs no caps.
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    # SCOPE (deliberate): the auth-critical edge — traefik and authelia, both on `:latest` —
    # is intentionally NOT opted out of auto-updates (unlike crowdsec/docker-proxy/portainer/
    # qbittorrent, which carry `com.centurylinklabs.watchtower.enable=false`). The theoretical
    # risk is a breaking upstream `:latest` locking us out of the SSO front door. Accepted: the
    # COOLDOWN_DELAY soak below only pulls images built >1 week ago (filters fresh breakage), and
    # a self-updating homelab is worth the rare lockout risk. To change, add the enable=false
    # label to traefik/authelia — but only revisit if a bad `:latest` actually bites.
    environment:
      DOCKER_HOST: tcp://docker-proxy-lifecycle:2375
      WATCHTOWER_CLEANUP: true
      WATCHTOWER_SCHEDULE: "0 0 4 * * *"
      WATCHTOWER_INCLUDE_RESTARTING: true
      # Cooldown: skip image updates until they've been built >1 week (supply-chain/bug soak).
      WATCHTOWER_COOLDOWN_DELAY: 1w
      DOCKER_API_VERSION: 1.44
    {{ service_networks() }}
    labels:
      # Watchtower
      - "com.centurylinklabs.watchtower.depends-on:docker-proxy-lifecycle"
      {{ kuma(container_item.name) }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('0.50', '256M', '0.05', '16M') }}

{{ external_networks() }}
