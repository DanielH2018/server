{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}

services:
  watchtower:
    image: nickfedor/watchtower:latest
    container_name: watchtower
    user: {{ puid }}:{{ pgid }}
    restart: unless-stopped
    # Go binary that only talks to the lifecycle socket-proxy over TCP; needs no caps.
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    # SCOPE: watchtower auto-updates the `:latest` long tail (mostly stateless leaf services).
    # The critical/stateful tier — traefik, authelia, kopia, pihole, the *arr suite
    # (sonarr/radarr/bazarr/prowlarr), jellyfin, livesync (couchdb), uptime-kuma, and
    # mosquitto — is pinned to explicit version tags and carries
    # `com.centurylinklabs.watchtower.enable=false`, so Renovate manages it instead:
    # updates land as PRs through CI + the host health gate (version-diffed and revertable),
    # with majors held for manual review. The COOLDOWN_DELAY soak below still filters fresh
    # breakage on everything watchtower does pull, and Renovate mirrors it with a 7-day
    # minimumReleaseAge. (crowdsec dashboard/docker-proxy/portainer/qbittorrent also carry
    # enable=false for their own reasons.)
    environment:
      DOCKER_HOST: tcp://docker-proxy-lifecycle:2375
      WATCHTOWER_CLEANUP: true
      WATCHTOWER_SCHEDULE: "0 0 4 * * *"
      WATCHTOWER_INCLUDE_RESTARTING: true
      # Cooldown: skip image updates until they've been built >1 week (supply-chain/bug soak).
      WATCHTOWER_COOLDOWN_DELAY: 1w
      DOCKER_API_VERSION: 1.44
    {{ service_networks() }}
    labels:
      # Watchtower
      - "com.centurylinklabs.watchtower.depends-on=docker-proxy-lifecycle"
      {{ kuma(container_item.name) }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('0.50', '256M', '0.05', '16M') }}

{{ external_networks() }}
