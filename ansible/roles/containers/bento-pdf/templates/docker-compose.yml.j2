{% from 'traefik.yml.j2' import labels with context %}
{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
{% from 'healthcheck.yml.j2' import healthcheck %}
---

services:
  bento-pdf:
    image: ghcr.io/alam00000/bentopdf:latest
    container_name: bento-pdf
    restart: unless-stopped
    {{ healthcheck('["CMD", "wget", "-q", "--spider", "http://localhost:8080/"]', start_period='15s') }}
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    # Read-only rootfs: nginx-unprivileged (UID 101) writes only its temp dirs + pidfile —
    # tmpfs them with mode=1777 or mkdir under the root-owned default tmpfs EPERMs. The
    # entrypoint's in-place /etc/nginx edits (ipv6-listen/noindex) fail-soft and are cosmetic
    # for this baked-config static SPA (throwaway-verified it still serves 200); nothing to persist.
    read_only: true
    tmpfs:
      - /var/cache/nginx:mode=1777
      - /etc/nginx/tmp:mode=1777
    {{ service_networks() }}
    labels:
      {# Generate labels(container, port, docker_network, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          (container_item.networks | default([docker_network]))[0],
          container_item.use_authelia
        )
      }}
      {{ kuma(container_item.name) }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('0.50', '256M', '0.05', '32M') }}

{{ external_networks() }}
