{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
services:
  recyclarr:
    # Pinned + Renovate-managed (was :latest/watchtower — the unsupervised v8 major
    # jump removed include templates and silently killed the nightly sync, 2026-06-10).
    image: ghcr.io/recyclarr/recyclarr:8.3.2
    container_name: recyclarr
    user: {{ puid }}:{{ pgid }}
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "pgrep", "-f", "supercronic"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 15s
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    {{ service_networks() }}
    environment:
      - TZ={{ tz }}
    volumes:
      - ./recyclarr/config:/config
    labels:
      # Disable watchtower update — pinned + Renovate-managed
      - "com.centurylinklabs.watchtower.enable=false"
      {{ kuma(container_item.name) }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('0.50', '256M', '0.05', '16M') }}

{{ external_networks() }}
