# Recyclarr v8 config — guide-backed quality profiles (trash_id).
#
# MIGRATION NOTE (2026-06-10): the v7 `include: - template:` directives died when
# upstream removed all include templates in the v8 config-templates branch (the
# :latest image auto-updated to v8 and every nightly sync failed with
# "Unable to find include template"). trash_ids below come from the official v8
# starter templates (`recyclarr config create -t web-1080p` etc.).
#
# Deliberately NOT managed here: the "Anime" profile in Sonarr (the operator's
# own — 10 series use it). The guide's "[Anime] Remux-1080p" profiles were
# deleted from both arrs at some point; re-adding them is an opt-in
# (`- trash_id: 20e0fc959f1f1704bed501f23bdae76f` sonarr /
#  `722b624f9af1e492284c4bc842153a38` radarr).
sonarr:
  my-sonarr:
    base_url: http://sonarr:8989  # Internal docker hostname or IP
    api_key: {{ sonarr_api_key }}
    delete_old_custom_formats: true

    # The sliders in Settings > Quality (was: sonarr-quality-definition-series)
    quality_definition:
      type: series

    quality_profiles:
      # WEB (1080p) — same profile name the v7 template created, so this syncs
      # onto the existing profile rather than creating a duplicate.
      - trash_id: 72dae194fc92bf828f32cde7744e51a1  # WEB-1080p
        reset_unmatched_scores:
          enabled: true

radarr:
  my-radarr:
    base_url: http://radarr:7878
    api_key: {{ radarr_api_key }}
    delete_old_custom_formats: true

    # (was: radarr-quality-definition-movie)
    quality_definition:
      type: movie

    quality_profiles:
      # HD Bluray + WEB — name matches the existing profile (see sonarr note).
      - trash_id: d1d67249d3890e49bc12e275d989a7e9  # HD Bluray + WEB
        reset_unmatched_scores:
          enabled: true
