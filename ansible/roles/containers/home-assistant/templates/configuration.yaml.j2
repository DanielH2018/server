# Configure a default setup of Home Assistant (frontend, api, etc)
default_config:

# Entity friendly-name / icon overrides (templated — see customize.yaml.j2).
homeassistant:
  customize: !include customize.yaml

http:
  use_x_forwarded_for: true
  # Trust the whole Docker bridge range (RFC1918 172.16/12) so HA honors
  # X-Forwarded-For from Traefik regardless of which bridge subnet it connects
  # from — matches the trusted-proxy ranges in the authelia and traefik configs.
  trusted_proxies:
    - 172.16.0.0/12

# Repo-managed YAML-mode dashboard, registered ALONGSIDE the default storage-mode
# "Overview" dashboard. No top-level `mode:`, so the default stays UI-editable; only
# `smart-home` is file-defined (templates/dashboards/smart-home.yaml.j2). Built-in cards
# only, so no `resources:` are needed.
lovelace:
  dashboards:
    smart-home:
      mode: yaml
      title: Smart Home
      icon: mdi:home-automation
      show_in_sidebar: true
      filename: dashboards/smart-home.yaml
