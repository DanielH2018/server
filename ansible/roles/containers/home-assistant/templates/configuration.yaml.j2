# Configure a default setup of Home Assistant (frontend, api, etc)
default_config:

# Entity friendly-name / icon overrides (templated — see customize.yaml.j2).
homeassistant:
  customize: !include customize.yaml

# Automations + scenes are Ansible-managed static files (role files/automations.yaml,
# files/scenes.yaml), copied to ./config and version-controlled. The HA UI editors still
# open, but edits are NOT persistent — git is the source of truth; redeploy to change.
automation: !include automations.yaml
scene: !include scenes.yaml
# Reusable scripts: bedroom_apply_natural (the "natural lighting state" dispatcher used by
# Tap Dial button 4 + the morning reset) and its bedroom_set_natural_brightness helper.
script: !include scripts.yaml

# Helper: manual-off override. When on, presence will NOT auto-turn-on the bedroom lights.
# Set by the Tap Dial when you turn the lights off; cleared on manual-on or the morning reset.
input_boolean:
  bedroom_manual_off:
    name: Bedroom manual off override
    icon: mdi:lightbulb-off
  # Manual-fan override. When on, the temperature automation will NOT drive the fan. Set when the
  # fan is changed by hand; cleared by Tap Dial button 3 or the morning reset.
  bedroom_fan_manual:
    name: Bedroom fan manual override
    icon: mdi:fan-off

# Helper: the fan LEVEL script.bedroom_apply_fan last commanded (0-9). bedroom_fan_manual_detect
# ignores a fan change whose level matches this (= our own command's cloud echo) and only flags a
# mismatch as a real manual change — the DREO push integration echoes our commands back parent-less,
# so the change-context alone can't tell them apart.
input_number:
  bedroom_fan_expected_level:
    name: Bedroom fan expected level
    min: 0
    max: 9
    step: 1
    mode: box
    icon: mdi:fan-chevron-up

# Adaptive Lighting (HACS integration) — sun-tracking color temp + brightness for the bedroom
# group while it is on. Installed via HACS into custom_components/ (Kopia-backed, like dreo).
# A full HA restart (this deploy recreates the container) loads the integration; a YAML
# "Quick Reload" is NOT enough for a newly added custom component. Creates the master switch
# switch.bedroom_adaptive_lighting_bedroom (AL device-prefixes the name "Adaptive Lighting:
# Bedroom"); the Tap Dial button-4 reset targets that exact entity_id.
adaptive_lighting:
  - name: "Bedroom"
    lights:
      - light.bedroom_lights
    min_brightness: 1
    max_brightness: 100
    min_color_temp: 2200
    max_color_temp: 4500
    sleep_brightness: 1
    sleep_color_temp: 2200
    take_over_control: true
    detect_non_ha_changes: false
    transition: 45

# Air-quality thresholds — built-in `threshold` binary-sensors give native hysteresis (on above
# upper+hysteresis, off below upper-hysteresis), which IS the "alert once + recovery, no bounce"
# lifecycle consumed by the bedroom_air_quality_alert automation (files/automations.yaml).
# Source = the bedroom AirGradient ONE. Thresholds are STARTING POINTS — tune to the observed
# baseline, especially the VOC/NOx *index* sensors (Sensirion indices drift per environment).
# Adding a pollutant = one more block here + add its binary_sensor to the automation trigger list.
binary_sensor:
  - platform: threshold
    name: "Bedroom CO2 high"          # -> binary_sensor.bedroom_co2_high
    entity_id: sensor.bedroom_airgradient_one_carbon_dioxide
    upper: 1200                        # alerts >= 1300 ppm, clears <= 1100 ppm
    hysteresis: 100
  - platform: threshold
    name: "Bedroom PM2.5 high"        # -> binary_sensor.bedroom_pm2_5_high
    entity_id: sensor.bedroom_airgradient_one_pm2_5
    upper: 35                          # alerts >= 40 ug/m3, clears <= 30 ug/m3
    hysteresis: 5
  - platform: threshold
    name: "Bedroom VOC high"          # -> binary_sensor.bedroom_voc_high
    entity_id: sensor.bedroom_airgradient_one_voc_index
    upper: 250                         # alerts >= 275, clears <= 225 (index)
    hysteresis: 25
  - platform: threshold
    name: "Bedroom NOx high"          # -> binary_sensor.bedroom_nox_high
    entity_id: sensor.bedroom_airgradient_one_nox_index
    upper: 50                          # alerts >= 60, clears <= 40 (index)
    hysteresis: 10

http:
  use_x_forwarded_for: true
  # Trust the whole Docker bridge range (RFC1918 172.16/12) so HA honors
  # X-Forwarded-For from Traefik regardless of which bridge subnet it connects
  # from — matches the trusted-proxy ranges in the authelia and traefik configs.
  trusted_proxies:
    - 172.16.0.0/12

# Lovelace dashboard defined from YAML (ui-lovelace.yaml), shown in the sidebar as "Bedroom".
# Uses the `dashboards:` form, NOT the legacy top-level `mode: yaml` (deprecated, removed in
# HA 2026.8). Built-in cards only, so no `resource_mode: yaml` is needed.
# NOTE: HA has no config option for the *landing* dashboard — to open straight to this one,
# set it as default in the UI: Settings → Dashboards → (Bedroom) ⋮ → "Set as default for
# everyone" (persists in HA's .storage). Without that, HA opens its auto-generated areas view.
lovelace:
  dashboards:
    lovelace:
      mode: yaml
      filename: ui-lovelace.yaml
      title: Bedroom
      icon: mdi:bed
      show_in_sidebar: true
