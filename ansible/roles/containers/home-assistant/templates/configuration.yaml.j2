# Configure a default setup of Home Assistant (frontend, api, etc)
default_config:

# Entity friendly-name / icon overrides (templated — see customize.yaml.j2).
homeassistant:
  customize: !include customize.yaml
  # Instance URLs so the Google Cast receiver on the Nest Hub Max can reach the HA frontend when
  # casting a dashboard (cast.show_lovelace_view). Resolved from HA's secrets.yaml, which Ansible
  # generates from SOPS (external_url = Cloudflare public host, internal_url = LAN/WireGuard host).
  # They live in secrets.yaml because this file is copied verbatim — the domain var cannot be
  # inlined here (the HA-config validator rejects Ansible markers in configuration.yaml).
  external_url: !secret external_url
  internal_url: !secret internal_url

# Frontend theme — a compact dark theme PINNED to the Bedroom dashboard (ui-lovelace.yaml.j2 sets
# `theme: nest_dark` on the view) so it renders dark when cast to the Nest Hub. The cast receiver
# runs with NO logged-in user, so it ignores the app/browser dark-mode profile and would otherwise
# show light; pinning an explicit theme to the view forces dark regardless of device/user. Static
# color values only (no HA Jinja), so it is safe in this verbatim-copied file; one `frontend:` key,
# compatible with default_config. Tune the hex values to taste.
frontend:
  themes:
    nest_dark:
      primary-color: "#2196f3"
      accent-color: "#ff9800"
      primary-background-color: "#0f0f0f"
      secondary-background-color: "#1a1a1a"
      card-background-color: "#1e1e1e"
      ha-card-background: "#1e1e1e"
      divider-color: "rgba(255, 255, 255, 0.10)"
      primary-text-color: "#e8e8e8"
      secondary-text-color: "#9aa0a6"
      text-primary-color: "#e8e8e8"
      disabled-text-color: "#6b6b6b"
      app-header-background-color: "#1e1e1e"
      app-header-text-color: "#e8e8e8"
      state-icon-color: "#c4c8cc"
      paper-item-icon-color: "#c4c8cc"

# Automations + scenes are Ansible-managed static files (role files/automations.yaml,
# files/scenes.yaml), copied to ./config and version-controlled. The HA UI editors still
# open, but edits are NOT persistent — git is the source of truth; redeploy to change.
automation: !include automations.yaml
scene: !include scenes.yaml
# Reusable scripts: bedroom_apply_natural (the "natural lighting state" dispatcher used by
# Tap Dial button 4 + the morning reset) and its bedroom_set_natural_brightness helper.
script: !include scripts.yaml

# Helper: manual-off override. When on, presence will NOT auto-turn-on the bedroom lights.
# Set by the Tap Dial when you turn the lights off; cleared on manual-on or the morning reset.
input_boolean:
  bedroom_manual_off:
    name: Bedroom manual off override
    icon: mdi:lightbulb-off
  # Manual-fan override. When on, the temperature automation will NOT drive the fan. Set when the
  # fan is changed by hand; cleared by Tap Dial button 3 or the morning reset.
  bedroom_fan_manual:
    name: Bedroom fan manual override
    icon: mdi:fan-off
  # Sleep mode. Set by the bedtime routine (script.bedroom_bedtime); caps bedroom_apply_fan to Low
  # for a quiet night (still temperature-responsive, NOT frozen). Cleared by the morning reset.
  bedroom_sleep_mode:
    name: Bedroom sleep mode
    icon: mdi:power-sleep

# Helper: the fan LEVEL script.bedroom_apply_fan last commanded (0-9). bedroom_fan_manual_detect
# ignores a fan change whose level matches this (= our own command's cloud echo) and only flags a
# mismatch as a real manual change — the DREO push integration echoes our commands back parent-less,
# so the change-context alone can't tell them apart.
input_number:
  bedroom_fan_expected_level:
    name: Bedroom fan expected level
    min: 0
    max: 9
    step: 1
    mode: box
    icon: mdi:fan-chevron-up
  # The color temperature the auto-lighting path (bedroom_set_natural_brightness) last set, so
  # bedroom_color_track can tell its own auto color from a manual scene/slider pick (expected-value
  # pattern, like bedroom_fan_expected_level).
  bedroom_light_expected_color_temp:
    name: Bedroom light expected color temp
    min: 2000
    max: 6600
    step: 1
    unit_of_measurement: K
    mode: box

# Heartbeat helper — the `ha_heartbeat` automation (files/automations.yaml) stamps this with now()
# every minute, so its last_changed is fresh ONLY while the automation scheduler is executing.
# monitor-bridge polls it over the apps net (check_ha_heartbeat) and pushes a Kuma monitor down when
# it goes stale — catching a wedged-but-running HA the container healthcheck (HTTP :8123) can't see.
# Excluded from the recorder below (it changes every minute, zero history value). See the
# 2026-06-19 spec in docs/superpowers/specs/.
input_datetime:
  ha_heartbeat:
    name: HA heartbeat
    has_date: true
    has_time: true
    icon: mdi:heart-pulse

# Fan-dial mode timer — its `active` state IS "the dial controls the fan" (Tap Dial button-4 hold
# toggles it; bedroom_tap_dial_control's dial_rotate branches read it). 5-min SLIDING window: each
# dial turn restarts it (timer.start), and it auto-reverts to light control on expiry. No `restore:`
# — idle after an HA restart is intended, so a deploy can't strand the dial in fan mode. No separate
# input_boolean: the timer IS the source of truth, which is why restart-safety is free.
timer:
  bedroom_fan_dial:
    name: Bedroom fan-dial mode
    duration: "00:05:00"
    icon: mdi:fan-chevron-up

# Adaptive Lighting (HACS integration) — sun-tracking color temp + brightness for the bedroom
# group while it is on. Installed via HACS into custom_components/ (Kopia-backed, like dreo).
# A full HA restart (this deploy recreates the container) loads the integration; a YAML
# "Quick Reload" is NOT enough for a newly added custom component. Creates the master switch
# switch.bedroom_adaptive_lighting_bedroom (AL device-prefixes the name "Adaptive Lighting:
# Bedroom"); the Tap Dial button-4 reset targets that exact entity_id.
adaptive_lighting:
  - name: "Bedroom"
    lights:
      - light.bedroom_lights
    min_brightness: 1
    max_brightness: 100
    min_color_temp: 2200
    max_color_temp: 4500
    sleep_brightness: 1
    sleep_color_temp: 2200
    take_over_control: true
    detect_non_ha_changes: false
    transition: 45

# Air-quality thresholds — built-in `threshold` binary-sensors give native hysteresis (on above
# upper+hysteresis, off below upper-hysteresis), which IS the "alert once + recovery, no bounce"
# lifecycle consumed by the bedroom_threshold_alert automation (files/automations.yaml).
# Source = the bedroom AirGradient ONE. Thresholds are STARTING POINTS — tune to the observed
# baseline, especially the VOC/NOx *index* sensors (Sensirion indices drift per environment).
# Adding a pollutant = one more block here + add its binary_sensor to the automation trigger list.
binary_sensor:
  - platform: threshold
    name: "Bedroom CO2 high"          # -> binary_sensor.bedroom_co2_high
    entity_id: sensor.bedroom_airgradient_one_carbon_dioxide
    upper: 1000                        # alerts >= 1100 ppm, clears <= 900 ppm
    hysteresis: 100
  - platform: threshold
    name: "Bedroom PM2.5 high"        # -> binary_sensor.bedroom_pm2_5_high
    entity_id: sensor.bedroom_airgradient_one_pm2_5
    upper: 35                          # alerts >= 40 ug/m3, clears <= 30 ug/m3
    hysteresis: 5
  - platform: threshold
    name: "Bedroom VOC high"          # -> binary_sensor.bedroom_voc_high
    entity_id: sensor.bedroom_airgradient_one_voc_index
    upper: 250                         # alerts >= 275, clears <= 225 (index)
    hysteresis: 25
  - platform: threshold
    name: "Bedroom NOx high"          # -> binary_sensor.bedroom_nox_high
    entity_id: sensor.bedroom_airgradient_one_nox_index
    upper: 50                          # alerts >= 60, clears <= 40 (index)
    hysteresis: 10
  # SEVERE air-quality tier — a higher cutoff per pollutant that fires its OWN edge when air gets
  # genuinely unhealthy. Feeds the `airqualitysevere` category of bedroom_threshold_alert, the only
  # alerts that PIERCE DND/sleep with sound (the moderate ones above are routine). Escalation-aware:
  # a gradual CO2 climb trips the moderate sensor first (routine nudge), then these (critical wake).
  # Cutoffs are STARTING POINTS (join the ~2026-06-25 tuning pass).
  - platform: threshold
    name: "Bedroom CO2 severe"        # -> binary_sensor.bedroom_co2_severe
    entity_id: sensor.bedroom_airgradient_one_carbon_dioxide
    upper: 2000                        # alerts >= 2100 ppm, clears <= 1900 ppm
    hysteresis: 100
  - platform: threshold
    name: "Bedroom PM2.5 severe"      # -> binary_sensor.bedroom_pm2_5_severe
    entity_id: sensor.bedroom_airgradient_one_pm2_5
    upper: 100                         # alerts >= 105 ug/m3, clears <= 95
    hysteresis: 5
  - platform: threshold
    name: "Bedroom VOC severe"        # -> binary_sensor.bedroom_voc_severe
    entity_id: sensor.bedroom_airgradient_one_voc_index
    upper: 400                         # alerts >= 425, clears <= 375 (index)
    hysteresis: 25
  - platform: threshold
    name: "Bedroom NOx severe"        # -> binary_sensor.bedroom_nox_severe
    entity_id: sensor.bedroom_airgradient_one_nox_index
    upper: 200                         # alerts >= 210, clears <= 190 (index)
    hysteresis: 10
  # Low-battery thresholds — the LOWER-bound mirror of the air-quality ones above. A `lower`
  # threshold is `on` (low) when value <= lower-hysteresis and `off` (recovered) when >= lower+
  # hysteresis. Battery drain is monotonic (only jumps up on replacement), so flapping is a
  # non-issue. Consumed by the bedroom_threshold_alert automation (files/automations.yaml).
  # Starting points — tune per device. Adding a battery = one block here + add it to the automation.
  - platform: threshold
    name: "Bedroom FP300 battery low"     # -> binary_sensor.bedroom_fp300_battery_low
    entity_id: sensor.aqara_fp300_battery
    lower: 20                             # alerts <= 15%, clears >= 25%
    hysteresis: 5
  - platform: threshold
    name: "Bedroom Tap Dial battery low"  # -> binary_sensor.bedroom_tap_dial_battery_low
    entity_id: sensor.0x001788010f0ccda4_battery
    lower: 20                             # alerts <= 15%, clears >= 25%
    hysteresis: 5
  # Humidity comfort — two-sided, so TWO one-sided sensors (high = mold risk, low = winter-dry).
  # Both feed the humidity category of bedroom_threshold_alert. Starting points — tune with the
  # air-quality thresholds (~2026-06-25 baseline pass).
  - platform: threshold
    name: "Bedroom humidity high"     # -> binary_sensor.bedroom_humidity_high
    entity_id: sensor.bedroom_airgradient_one_humidity
    upper: 60                          # alerts >= 63%, clears <= 57% (mold)
    hysteresis: 3
  - platform: threshold
    name: "Bedroom humidity low"      # -> binary_sensor.bedroom_humidity_low
    entity_id: sensor.bedroom_airgradient_one_humidity
    lower: 30                          # alerts <= 27%, clears >= 33% (winter-dry)
    hysteresis: 3
  # Outdoor air quality (source = Open-Meteo sensor.outdoor_pm2_5, files/rest.yaml). Two tiers like
  # the indoor air-quality sensors: moderate (high) and the wildfire/"unhealthy" cutoff (severe).
  # Feed the airqualityoutdoor / airqualityoutdoorsevere categories of bedroom_threshold_alert AND
  # the smoke guard in the window advisor. Starting points — tune with the indoor ones (~2026-06-25).
  - platform: threshold
    name: "Outdoor PM2.5 high"        # -> binary_sensor.outdoor_pm2_5_high
    entity_id: sensor.outdoor_pm2_5
    upper: 35                          # alerts >= 40, clears <= 30 µg/m³ (US AQI "moderate"+)
    hysteresis: 5
  - platform: threshold
    name: "Outdoor PM2.5 severe"      # -> binary_sensor.outdoor_pm2_5_severe
    entity_id: sensor.outdoor_pm2_5
    upper: 100                         # alerts >= 105, clears <= 95 µg/m³ (wildfire / "unhealthy")
    hysteresis: 5

# Template sensors are a STATIC copy'd file (files/templates.yaml), included here — same reason as
# automations/scenes/scripts: their HA Jinja expressions would be mangled by Ansible's templater if
# they lived inline in this .j2 (configuration.yaml IS rendered by Ansible; even a brace pair in a
# comment breaks it). Currently holds sensor.bedroom_wake_start (watch alarm minus 15 min).
template: !include templates.yaml

# UPS energy (kWh) for the Energy dashboard. The dashboard only accepts energy sensors
# (device_class: energy, state_class: total/total_increasing) — the NUT integration gives load %
# only. sensor.ups_power (files/templates.yaml) converts that to watts; this Riemann-sum
# `integration` sensor accumulates it into kWh and auto-stamps device_class: energy + state_class:
# total, making it eligible. method: left because the UPS load is a step function (holds a value
# until it changes); max_sub_interval keeps the integral accruing while the load sits steady (else
# it only re-integrates on a source change and a constant load would under-count). No HA Jinja
# expressions here, so it can live inline in this verbatim-copied file. Add it to the Energy dashboard via the UI
# (Settings → Dashboards → Energy → Individual devices → UPS Energy) — that step is .storage-only.
sensor:
  - platform: integration
    source: sensor.ups_power
    name: "UPS Energy"
    unique_id: ups_energy
    unit_prefix: k
    unit_time: h
    method: left
    max_sub_interval: "00:05:00"
    round: 3

# Outdoor air quality (Open-Meteo, no key) — git-managed REST sensor. Copy'd (files/rest.yaml),
# not inline, because its value_templates use value_json / state_attr that Ansible would mangle.
# Feeds the outdoor PM2.5 threshold alerts (below) and the window advisor (files/automations.yaml).
rest: !include rest.yaml

# Recorder hygiene: default_config enables the recorder with defaults (SQLite, keep 10 days, record
# everything); a top-level recorder: block customizes it without disabling default_config. Trim the
# highest-churn, lowest-value entities so the DB stays lean — faster history queries + faster startup
# recovery after the (benign) unclean-shutdown WAL replay. Chosen from the ACTUAL top-churn entities in
# home-assistant_v2.db; none are needed for restore or any automation (those read LIVE state, not
# history): sun.sun is recomputed on boot, pm0_3 is an unused fine-particle count (alerts + dashboard
# use pm2_5/pm10), linkquality/last_seen are Zigbee diagnostics. UPS load/voltage and the
# automation/script domains are the next candidates if the DB is still large — kept for now
# (dashboarded / useful in the logbook). Tune from the observed DB size over time.
recorder:
  exclude:
    entities:
      - sun.sun
      - sensor.bedroom_airgradient_one_pm0_3
      # Heartbeat helper — rewritten every minute by the ha_heartbeat automation; the live
      # last_changed is all monitor-bridge reads, so its history is pure churn.
      - input_datetime.ha_heartbeat
    entity_globs:
      - sensor.*_linkquality
      - sensor.*_last_seen

http:
  use_x_forwarded_for: true
  # Trust the whole Docker bridge range (RFC1918 172.16/12) so HA honors
  # X-Forwarded-For from Traefik regardless of which bridge subnet it connects
  # from — matches the trusted-proxy ranges in the authelia and traefik configs.
  trusted_proxies:
    - 172.16.0.0/12
  # Brute-force defense for the internet-facing login. Authelia is intentionally OFF on this route
  # (it breaks the companion app), so HA's own login is the last gate — CrowdSec + per-router
  # rate-limit front it, this hardens the gate itself. Auto-bans an IP after 5 failed logins (writes
  # config/ip_bans.yaml; delete a line to unban). Bans the REAL client IP, not Cloudflare/Traefik:
  # Cloudflare puts it in X-Forwarded-For, Traefik trusts the CF ranges
  # (forwardedHeaders.trustedIPs=cloudflare_ips) and forwards it, and use_x_forwarded_for honors it.
  # Only FAILED password logins count — valid long-lived tokens, the companion app, and webhooks are
  # unaffected. NOT a substitute for MFA: enrol TOTP in HA (Profile → Multi-factor Authentication).
  ip_ban_enabled: true
  login_attempts_threshold: 5

# Lovelace dashboard defined from YAML (ui-lovelace.yaml), shown in the sidebar as "Bedroom".
# Uses the `dashboards:` form, NOT the legacy top-level `mode: yaml` (deprecated, removed in
# HA 2026.8). Built-in cards only, so no `resource_mode: yaml` is needed.
# NOTE: HA has no config option for the *landing* dashboard — to open straight to this one,
# set it as default in the UI: Settings → Dashboards → (Bedroom) ⋮ → "Set as default for
# everyone" (persists in HA's .storage). Without that, HA opens its auto-generated areas view.
lovelace:
  dashboards:
    lovelace:
      mode: yaml
      filename: ui-lovelace.yaml
      title: Bedroom
      icon: mdi:bed
      show_in_sidebar: true

# Google Assistant (smart-home / cloud-to-cloud) — "Hey Google" voice control of HA entities via a
# self-hosted Google Cloud project (NOT Nabu Casa). Google reaches HA at the public fulfillment URL
# https://home-assistant.<domain>/api/google_assistant (Authelia is off on this route, so no bypass
# needed). report_state pushes live state to Google's HomeGraph, signed by the service account;
# re-sync exposed devices with the google_assistant.request_sync service (no api_key needed).
# Secrets come from HA's secrets.yaml (Ansible-generated from the SOPS google_assistant_service_account
# JSON): project_id + the service account's client_email/private_key. Exposure is CURATED —
# expose_by_default is off, so ONLY the entities flagged `expose: true` below are visible to Google.
# Add a device = another entity_config entry with `expose: true`, then say "Hey Google, sync my devices".
google_assistant:
  project_id: !secret google_assistant_project_id
  service_account:
    client_email: !secret google_assistant_sa_client_email
    private_key: !secret google_assistant_sa_private_key
  report_state: true
  expose_by_default: false
  entity_config:
    light.bedroom_lights:
      name: Bedroom Lights
      expose: true
    fan.tower_fan:
      name: Bedroom Fan
      expose: true

# Google Cast (Nest Hub Max) is intentionally NOT configured here. The `cast` integration is
# config-entry / UI-only in modern HA — a YAML `cast:` block is rejected ("does not support YAML
# setup"). Because HA is bridge-networked and can't discover Cast devices over mDNS, the Hub is added
# by IP in the integration's options: Settings -> Devices & Services -> Google Cast -> Configure ->
# Known hosts = 10.0.0.137 (the Hub's reserved lease). This is a one-time .storage step, like the
# Energy dashboard. external_url/internal_url (in the homeassistant: block above) let the cast
# receiver reach HA. Full runbook: SETUP.md §11.
