# Home Assistant secrets file — GENERATED by Ansible from SOPS (ansible/vars/secrets.yml).
# Resolved by HA's native !secret lookups in configuration.yaml. DO NOT edit the deployed copy;
# it is overwritten on every deploy. This file is Ansible-rendered (unlike configuration.yaml.j2,
# which is copied verbatim), so the domain var and SOPS-derived values live HERE, never inline in
# configuration.yaml.
#
# The Google service-account fields are derived from the single SOPS secret
# `google_assistant_service_account` (the full downloaded JSON). Each value is emitted with
# `| to_json` so the multi-line PEM private key becomes one properly-escaped YAML double-quoted
# scalar (the format HA expects: "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n").
{% set ga = google_assistant_service_account | from_json %}
google_assistant_project_id: {{ ga.project_id | to_json }}
google_assistant_sa_client_email: {{ ga.client_email | to_json }}
google_assistant_sa_private_key: {{ ga.private_key | to_json }}

# Instance URLs so the Google Cast receiver on the Nest Hub Max can reach the HA frontend.
# external_url = Cloudflare-proxied public host; internal_url = LAN/WireGuard host. Both are
# covered by the *.{{ domain }} / *.local.{{ domain }} wildcard cert.
external_url: {{ ('https://home-assistant.' ~ domain) | to_json }}
internal_url: {{ ('https://home-assistant.local.' ~ domain) | to_json }}
