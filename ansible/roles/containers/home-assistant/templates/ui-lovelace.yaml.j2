# Managed by Ansible (roles/containers/home-assistant) — ROOT YAML-mode dashboard.
# This file IS the Home Assistant landing page (lovelace: mode: yaml). Edit here + deploy
# (recreates HA), or for a faster loop edit the rendered file and use
# Developer Tools → YAML → "Reload Lovelace" to apply without an HA restart.
# Built-in cards only (no HACS resources required).
title: Home
views:
  - title: Bedroom
    path: bedroom
    icon: mdi:bed
    cards:
      # ── APC UPS ──────────────────────────────────────────────────────────
      - type: vertical-stack
        cards:
          - type: horizontal-stack
            cards:
              - type: gauge
                entity: sensor.apc_ups_battery_charge
                name: Battery
                unit: "%"
                min: 0
                max: 100
                severity:
                  green: 60
                  yellow: 30
                  red: 0
              - type: gauge
                entity: sensor.apc_ups_load
                name: Load
                unit: "%"
                min: 0
                max: 100
                severity:
                  green: 0
                  yellow: 60
                  red: 85
          - type: entities
            title: APC UPS
            icon: mdi:power-plug
            entities:
              # NUT disables most sensors by default (disabled_by: integration); only
              # enabled apc_ups sensors are used here. Runtime was enabled in the UI
              # 2026-06-17 (disabled by default) — keep it enabled or this row breaks.
              - entity: sensor.apc_ups_status
                name: Status
              - entity: sensor.apc_ups_battery_runtime
                name: Runtime
              - entity: sensor.apc_ups_input_voltage
                name: Input Voltage
      # ── DREO Tower Fan (DR-HTF024S) ──────────────────────────────────────
      - type: vertical-stack
        cards:
          - type: tile
            entity: fan.tower_fan
            name: Tower Fan
            features:
              - type: fan-speed
          - type: entities
            title: Tower Fan
            icon: mdi:fan
            entities:
              - entity: sensor.tower_fan_temperature
                name: Temperature
              - entity: switch.tower_fan_display_auto_off
                name: Display Auto-Off
              - entity: switch.tower_fan_panel_sound
                name: Panel Sound
      # ── Aqara FP300 presence sensor (essentials only) ────────────────────
      - type: glance
        title: Aqara FP300
        columns: 2
        entities:
          - entity: binary_sensor.aqara_fp300_presence
            name: Presence
          - entity: sensor.aqara_fp300_temperature
            name: Temperature
          - entity: sensor.aqara_fp300_illuminance
            name: Illuminance
          - entity: sensor.aqara_fp300_battery
            name: Battery
