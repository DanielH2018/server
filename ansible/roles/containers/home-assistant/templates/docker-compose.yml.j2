{% from 'traefik.yml.j2' import labels with context %}
{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'healthcheck.yml.j2' import healthcheck %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
---

services:
  home-assistant:
    # Pinned (was :latest) — HA is stateful with monthly, occasionally-breaking releases, so updates
    # go through Renovate PRs (the /linuxserver/ regex manager tracks the X.Y.Z-lsNN tag) not
    # watchtower, like jellyfin/the *arr stack. Bump deliberately; don't float on :latest.
    image: lscr.io/linuxserver/homeassistant:2026.6.3-ls221
    container_name: home-assistant
    environment:
      - PUID={{ puid }}
      - PGID={{ pgid }}
      - TZ={{ tz }}
      - DOCKER_MODS=linuxserver/mods:homeassistant-hacs
    volumes:
      - ./config:/config
    restart: unless-stopped
    # NOTE: no stop_grace_period override. HA under the LSIO/s6 image does NOT exit on SIGTERM — a
    # timed `docker stop` hit the FULL grace and exited 137 (SIGKILL) at both 30s and 90s, so HA is
    # effectively hung on shutdown (HA core / the dreo cloud_push integration never completes its
    # stop). A longer grace therefore can't avoid the "could not validate that the sqlite3 database
    # was shutdown cleanly" warning on the next boot — it only slows every deploy's recreate. The
    # warning is benign: SQLite WAL auto-recovers (HA's recovery pass succeeds). Verified 2026-06-18.
    # LSIO image: cap_drop ALL plus the s6 privilege-drop set. No NET_BIND_SERVICE —
    # HA binds high port 8123, not :80. Verify on deploy (docker logs home-assistant)
    # — add back caps if it fails to start.
    cap_drop:
      - ALL
    cap_add:
      - CHOWN
      - SETUID
      - SETGID
      - FOWNER
      - DAC_OVERRIDE
    security_opt:
      - no-new-privileges:true
    {{ service_networks() }}
    # HA is a slow first-booter: the LSIO image does a one-time "fixing python package
    # permissions" pass, then HA core starts before :8123 binds — past the default 30s.
    # start_period 120s keeps autoheal (AUTOHEAL_CONTAINER_LABEL=all) from restarting it
    # mid-boot. Warm reboots are much faster.
    {{ healthcheck('curl --fail -s http://localhost:8123/ || exit 1', start_period='120s') }}
    labels:
      # Disable watchtower auto-update — HA was silently in the watch-all :latest pool; it belongs in
      # the pinned + Renovate-managed critical/stateful tier (see the image comment above).
      - "com.centurylinklabs.watchtower.enable=false"
      {# Generate labels(container, port, docker_network, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          (container_item.networks | default([docker_network]))[0],
          container_item.use_authelia
        )
      }}
      {{ kuma(container_item.name) }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    # mem 1536M: HA + HACS + recorder + integrations idles at ~810M (79% of the old 1024M cap) —
    # too thin to absorb a recorder purge / integration reload. Bumped 2026-06-18 from live
    # measurement (host has 20G free; still a ceiling, not a reservation, so HA uses only what it needs).
    {{ resources('1.0', '1536M', '0.10', '256M') }}

{{ external_networks() }}
