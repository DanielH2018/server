{# DREO tower fan (DR-HTF024S): percentage <-> discrete-level conversion. The SINGLE source of
   truth for the fan's level math — imported by BOTH bedroom_apply_fan (files/scripts.yaml) and
   bedroom_fan_manual_detect (files/automations.yaml) so the round-trip can never drift between them.
   The fan exposes FAN_LEVELS discrete speeds; the DREO integration math.ceil()s a requested % up to
   the next level, so to land ON a level we send the midpoint of its % range.
   HA loads custom_templates/*.jinja at startup; this deploy recreates the container (full restart),
   so edits take effect on deploy. Live edit: Developer Tools -> Actions ->
   homeassistant.reload_custom_templates. #}
{% set FAN_LEVELS = 9 %}

{# Reported % -> level (0..FAN_LEVELS). round is banker's (Python round), matching the rest of HA. #}
{%- macro pct_to_level(pct) -%}
{{ (pct | float(0) * FAN_LEVELS / 100) | round | int }}
{%- endmacro -%}

{# Level (0..FAN_LEVELS) -> the % to SEND so the integration's ceil lands exactly on it: the
   midpoint of the level's range ((L-0.5)/FAN_LEVELS*100) ceils to L. 0 = off. #}
{%- macro level_to_pct(level) -%}
{{ (((level | int - 0.5) * 100 / FAN_LEVELS) | round | int) if (level | int) > 0 else 0 }}
{%- endmacro -%}

{# Temperature(°F) + current level + caps -> target DREO level (0..9). The single source of truth
   for the fan curve, extracted verbatim from bedroom_apply_fan so it can be unit-tested: the
   (t-71)/1.3 ideal curve, the ±0.7-level hysteresis deadband, the 22:00-06:00 night cap, and the
   sleep-mode seasonal floor + L5 ceiling. Entity reads (indoor temp, current %, clock, sleep flag,
   outdoor temp) stay in the caller. TUNE the curve here: the 71 offset sets the start temp; the
   /1.3 divisor sets the slope (bigger = gentler). Tested in tests/test_fan_macros.py. #}
{%- macro fan_target_level(temp_f, cur_level, is_night, sleep, outdoor_temp_f=-999) -%}
{%- set t = temp_f | float(-1) -%}
{%- set cl = cur_level | int(0) -%}
{%- set ideal = ((t - 71) / 1.3) if t >= 0 else 0 -%}
{%- set want = 0 if (t < 0 or ideal < 0.3)
   else ((ideal | round | int) if (cl == 0 or ideal > cl + 0.7 or ideal < cl - 0.7) else cl) -%}
{%- if sleep | bool -%}
{#- Bedtime/sleep: a seasonal FLOOR (guaranteed white noise) keyed off OUTDOOR temp, with the indoor
    curve free to climb up to a fixed L5 ceiling on a hot night — outdoor sets the season, indoor
    modulates within [floor, ceiling]. Missing/unavailable outdoor (-999 default) falls into the
    winter band (quiet L2 floor = the old sleep behavior). TUNE the 45/68°F bands, the 2/3/4 floors,
    and the 5 ceiling here; every floor is <= the ceiling so the clamp never inverts. -#}
{%- set ot = outdoor_temp_f | float(-999) -%}
{%- set floor = 4 if ot >= 68 else (3 if ot >= 45 else 2) -%}
{%- set ceiling = 5 -%}
{{- [[want, floor] | max, ceiling] | min | int -}}
{%- else -%}
{%- set cap = (4 if (is_night | bool) else 9) | int -%}
{{- [want, cap] | min | int -}}
{%- endif -%}
{%- endmacro -%}

{# Current level + delta -> new level, clamped to 0..FAN_LEVELS (0 = off). Used by
   script.bedroom_fan_nudge for the Tap Dial fan-dial mode (dial = +/-1 fan level). Pure clamp —
   the bounds are the tunable bit. Tested in tests/test_fan_macros.py. #}
{%- macro fan_nudge_level(cur_level, delta) -%}
{{ [[ (cur_level | int(0)) + (delta | int(0)), 0 ] | max, FAN_LEVELS] | min | int }}
{%- endmacro -%}
