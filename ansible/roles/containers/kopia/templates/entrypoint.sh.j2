#!/bin/sh
# Idempotent startup: connect B2 repo via S3-compatible API, add server user, start server.
set -e

# Migrate from the deprecated native B2 provider to S3-compatible.
# `repository disconnect` only removes the local config file, not the remote data.
if /usr/bin/kopia repository status 2>/dev/null | grep -q "Storage type:.*b2"; then
    echo "Migrating from B2 native to S3-compatible provider..."
    /usr/bin/kopia repository disconnect
fi

# Connect to existing repository, or create it on first run.
if ! /usr/bin/kopia repository status 2>/dev/null; then
    echo "Connecting to repository..."
    if ! /usr/bin/kopia repository connect s3 \
        --bucket="${KOPIA_B2_BUCKET}" \
        --endpoint="${KOPIA_B2_ENDPOINT}" \
        --access-key="${KOPIA_B2_KEY_ID}" \
        --secret-access-key="${KOPIA_B2_APPLICATION_KEY}" 2>/dev/null; then
        echo "Repository not found in bucket, creating..."
        /usr/bin/kopia repository create s3 \
            --bucket="${KOPIA_B2_BUCKET}" \
            --endpoint="${KOPIA_B2_ENDPOINT}" \
            --access-key="${KOPIA_B2_KEY_ID}" \
            --secret-access-key="${KOPIA_B2_APPLICATION_KEY}"
    fi
fi

# Set snapshot schedule and retention (idempotent — safe to run on every start).
# Exclusions are handled by .kopiaignore in the snapshot source directory.
# Retention: 7 dailies + 4 weeklies + 3 monthlies, nothing annual. hourly/annual/latest
# are pinned explicitly because unset tiers inherit kopia's global defaults (hourly 48,
# monthly 24, annual 3, latest 10), which silently widened retention before. latest 3
# (not 0) briefly protects manual/verification snapshots that fit no calendar bucket.
# keep-monthly 3 (added 2026-06-24, supersedes the 2026-06-12 no-monthly choice): 4 weeklies
# gave only a ~28d recovery horizon, so a slow corruption / unnoticed-for-a-month event was
# unrecoverable. The snapshot source is config-only (media is excluded), which dedupes
# heavily, so a few monthlies cost little on the B2 free tier; the b2_usage monitor backstops.
if /usr/bin/kopia repository status 2>/dev/null; then
    /usr/bin/kopia policy set /data/home/ubuntu/server/containers \
        --snapshot-interval 24h \
        --keep-latest 3 \
        --keep-hourly 0 \
        --keep-daily 7 \
        --keep-weekly 4 \
        --keep-monthly 3 \
        --keep-annual 0

    # Maintenance (blob GC) explicitly owned + enabled. Without an owner running FULL
    # maintenance, expired snapshots are dropped only logically while their blobs linger
    # in B2 — the bucket grows unbounded and the b2_usage monitor only catches the symptom
    # weeks later. Idempotent and matches kopia's create-time defaults, so it's a no-op on
    # this install but pins the intent and re-claims ownership after a fresh-host reconnect.
    /usr/bin/kopia maintenance set \
        --owner me \
        --enable-full true --full-interval 24h \
        --enable-quick true --quick-interval 1h
fi

exec /usr/bin/kopia server start \
    --disable-csrf-token-checks \
    --insecure \
    --without-password \
    --address=0.0.0.0:51515 \
    --allow-extremely-dangerous-unauthenticated-server-on-the-network
