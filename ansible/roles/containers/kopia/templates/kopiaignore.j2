# Goal: restore server settings not managed by Ansible.
# Exclude anything regeneratable, downloadable, or too large to justify storing.

# ── Backup tools ────────────────────────────────────────────────────────────
kopia/

# ── SQLite sidecar files (match at any depth) ────────────────────────────────
# A WAL is only meaningful with an atomic FS snapshot (kopia's file walk isn't one);
# the main .sqlite file alone restores consistent-as-of-last-checkpoint. Backing WALs
# up is pure churn — n8n's stuck 405M WAL re-uploaded ~400M/night (found 2026-06-12).
*.sqlite-wal
*.sqlite-shm

# ── Generic regeneratable dirs (match at any depth) ─────────────────────────
cache/
logs/
transcodes/
tmp/

# ── Game servers ──────────────────────────────────────────────────────────────
# Server binaries are re-downloadable; NOTE the world saves inside are NOT backed
# up anywhere as a result (operator-accepted 2026-06-10 — the service is retired,
# the dir is kept as the only copy of the worlds).
valheim/


# ── Jellyfin ─────────────────────────────────────────────────────────────────
# data* covers the metadata cache DB; metadata/ covers downloaded artwork;
# plugins/ covers plugin binaries — all re-fetchable from TVDB/TMDB/catalog.
jellyfin/config/data*/
jellyfin/config/metadata/
jellyfin/config/plugins/

# ── Media stack ───────────────────────────────────────────────────────────────
# Anchored with a leading slash so this excludes ONLY the top-level media library
# (containers/data/, ~27G). A bare "data/" matches a dir named data at ANY depth,
# which silently dropped service state — n8n/data, karakeep/data, grafana/data,
# portainer/data, traefik/data — from the backup. Game/regeneratable */data dirs
# (valheim, uptime-kuma, jellyfin) stay excluded via their own rules.
/data/
sonarr/config/MediaCover/
radarr/config/MediaCover/
bazarr/config/cache/
prowlarr/config/Definitions/
tdarr/transcode_cache/

# ── Metrics & monitoring (regenerate from live services) ─────────────────────
# (prometheus's TSDB lives in the prometheus_data named volume — outside
# containers/ and Kopia's scope entirely, so it needs no entry here.)
# NB: the bind dir is influxdb2 (InfluxDB v2 layout) — a bare "influxdb/" never
# matched and the TSDB was silently backed up until 2026-06-10.
scrutiny/influxdb2/

# ── App-specific caches ───────────────────────────────────────────────────────
# Reinstallable VS Code extensions live in BOTH paths (this image's --extensions-dir
# is config/extensions; .local/share is code-server's data dir). 2026-06-10's "fix"
# (fb5857e) swapped the top-level exclude for the .local one — snapshot diffs prove
# the old pattern DID match: extensions/ (788M) re-entered the backup that night and
# auto-update churn then bled ~0.8GB/day of unique content into B2. Keep both lines.
code-server/config/extensions/
code-server/config/.local/share/code-server/extensions/
code-server/config/.cache/
uptime-kuma/data*/
freshrss/config/www/freshrss/data/cache/
karakeep/time-tagger/uv-cache/
# Reinstallable Grafana plugins; grafana.db + provisioned dashboards stay backed up.
grafana/data/plugins/
# Tdarr's internal DB backup zips — the live DB2/ is backed up directly, so these
# are backups-of-a-backup. (DB2/ itself KEPT by operator choice 2026-06-12.)
tdarr/server/Tdarr/Backups/
# Cloned TRaSH-guides repos, re-fetched by every nightly recyclarr sync.
recyclarr/recyclarr/config/resources/

# ── Pi-hole: keep config (pihole.toml, custom lists, *_backups), drop the bulk ──
# pihole-FTL.db is DNS query HISTORY (432M, rewritten constantly — poor dedup);
# gravity*.db + listsCache are rebuilt from config by `pihole -g`.
pihole/data/etc-pihole/pihole-FTL.db*
pihole/data/etc-pihole/gravity.db
pihole/data/etc-pihole/gravity_old.db
pihole/data/etc-pihole/listsCache/
