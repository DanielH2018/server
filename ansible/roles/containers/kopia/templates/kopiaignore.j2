# Goal: restore server settings not managed by Ansible.
# Exclude anything regeneratable, downloadable, or too large to justify storing.

# ── Backup tools ────────────────────────────────────────────────────────────
kopia/

# ── Generic regeneratable dirs (match at any depth) ─────────────────────────
cache/
logs/
transcodes/
tmp/

# ── Game servers ──────────────────────────────────────────────────────────────
# Server binaries are re-downloadable; NOTE the world saves inside are NOT backed
# up anywhere as a result (operator-accepted 2026-06-10 — the service is retired,
# the dir is kept as the only copy of the worlds).
valheim/


# ── Jellyfin ─────────────────────────────────────────────────────────────────
# data* covers the metadata cache DB; metadata/ covers downloaded artwork;
# plugins/ covers plugin binaries — all re-fetchable from TVDB/TMDB/catalog.
jellyfin/config/data*/
jellyfin/config/metadata/
jellyfin/config/plugins/

# ── Media stack ───────────────────────────────────────────────────────────────
# Anchored with a leading slash so this excludes ONLY the top-level media library
# (containers/data/, ~27G). A bare "data/" matches a dir named data at ANY depth,
# which silently dropped service state — n8n/data, karakeep/data, grafana/data,
# portainer/data, traefik/data — from the backup. Game/regeneratable */data dirs
# (valheim, uptime-kuma, jellyfin) stay excluded via their own rules.
/data/
sonarr/config/MediaCover/
radarr/config/MediaCover/
bazarr/config/cache/
prowlarr/config/Definitions/
tdarr/transcode_cache/

# ── Metrics & monitoring (regenerate from live services) ─────────────────────
# (prometheus's TSDB lives in the prometheus_data named volume — outside
# containers/ and Kopia's scope entirely, so it needs no entry here.)
# NB: the bind dir is influxdb2 (InfluxDB v2 layout) — a bare "influxdb/" never
# matched and the TSDB was silently backed up until 2026-06-10.
scrutiny/influxdb2/

# ── App-specific caches ───────────────────────────────────────────────────────
code-server/config/extensions*/
uptime-kuma/data*/
freshrss/config/www/freshrss/data/cache/
karakeep/time-tagger/uv-cache/
