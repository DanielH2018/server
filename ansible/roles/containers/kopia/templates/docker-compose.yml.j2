{% from 'traefik.yml.j2' import labels with context %}
{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
{% from 'healthcheck.yml.j2' import healthcheck %}
---

services:
  kopia:
    image: kopia/kopia:0.23.1
    container_name: kopia
    hostname: kopia
    restart: unless-stopped
    # Runs as root. Needs DAC_OVERRIDE (read+write bypass) for two reasons: it reads an
    # RO backup source full of 0600 files owned by uid 1000, AND it writes its own state
    # dirs (config/cache/logs/rclone bind mounts) which are owned by uid 1000, not root.
    # DAC_READ_SEARCH alone is insufficient — the repo connect can't write its cache and
    # the entrypoint restart-loops. Verified: with DAC_OVERRIDE the server starts healthy.
    cap_drop:
      - ALL
    cap_add:
      - DAC_OVERRIDE
    security_opt:
      - no-new-privileges:true
    entrypoint: /scripts/entrypoint.sh
    environment:
      - KOPIA_PASSWORD={{ kopia_password }}
      - KOPIA_B2_KEY_ID={{ kopia_b2_key_id }}
      - KOPIA_B2_APPLICATION_KEY={{ kopia_b2_application_key }}
      - KOPIA_B2_BUCKET={{ kopia_b2_bucket }}
      - KOPIA_B2_ENDPOINT={{ kopia_b2_endpoint }}
      - TZ={{ tz }}
    volumes:
      - ./config:/app/config
      - ./cache:/app/cache
      - ./logs:/app/logs
      - ./rclone:/app/rclone
      - ./scripts:/scripts:ro
      - /home/{{ sys_user }}/server/containers:/data/home/{{ sys_user }}/server/containers:ro
    {{ healthcheck("[\"CMD-SHELL\", \"curl -so /dev/null -w '%{http_code}' http://localhost:51515/ | grep -qE '^(200|401)'\"]") }}
    {{ service_networks() }}
    labels:
      # Disable watchtower update — pinned + Renovate-managed
      - "com.centurylinklabs.watchtower.enable=false"
      {# Generate labels(container, port, docker_network, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          (container_item.networks | default([docker_network]))[0],
          container_item.use_authelia
        )
      }}
      {{ kuma(container_item.name) }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('4.0', '2048M', '0.10', '128M') }}

{{ external_networks() }}
