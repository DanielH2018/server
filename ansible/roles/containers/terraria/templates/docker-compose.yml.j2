{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'healthcheck.yml.j2' import healthcheck %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
---

services:
  terraria:
    image: beardedio/terraria:vanilla-latest
    container_name: terraria
    cap_drop:
      - ALL
    cap_add:
      # PID 1 runs as root and writes into the uid-1000-owned ./config bind mount. The main
      # world save overwrites an existing root-owned .wld (owner bits suffice), but rotating
      # the .wld.bak/.bak2 backups unlink+renames directory entries — which a non-owner root
      # needs DAC_OVERRIDE for. Without it every world-save FATAL-crashed on the backup step
      # (39 restarts / 11 days, in-app backups frozen) while startup itself looked fine — which
      # is exactly why the earlier boot-only "add back if startup fails" check missed it. Same
      # recipe as kopia/traefik/wireguard (root writing a uid-1000 dir it doesn't own).
      - DAC_OVERRIDE
    security_opt:
      - no-new-privileges:true
    ports:
      # Deliberately published on ALL interfaces — a bare `ports:` publish binds dual-stack
      # (IPv4 0.0.0.0 AND IPv6 [::]), NOT scoped to {{ server_ip }} like the pihole/jellyfin
      # LAN-discovery ports: this is the game server's join port and is meant to be reachable
      # from every interface (LAN + any router forward, either address family). A raw-TCP game
      # protocol can't use the HTTP CrowdSec/rate-limit chain anyway.
      - "7778:7777/tcp"
    volumes:
      # Worlds + config + banlist all live in /config (run.sh symlinks Terraria's
      # Worlds dir here), so this bind mount is the entire persistent state — and it's
      # in Kopia's containers/ backup scope. The image's app dir (/vanilla, the WORKDIR
      # holding run.sh + binaries) is deliberately NOT mounted: it carries no user state
      # and persisting it would pin stale binaries across image updates.
      - ./config:/config
    restart: unless-stopped
    stdin_open: true # specific to this image to allow console commands
    tty: true        # specific to this image to allow console commands
    # Liveness = a LISTEN socket on 7777 in the kernel table, NOT a connect probe.
    # Terraria's binary protocol logs every accepted socket as "<ip> is connecting...",
    # so a /dev/tcp connect (the grafana-style probe) would spam the game console
    # ~2400x/day. Reading /proc/net/tcp for local port 1E61 (hex 7777), remote :0000,
    # state 0A (LISTEN) confirms the server is actually serving the port — stronger
    # than pidof — with zero connection noise. start_period 120s covers the ~74s
    # world-load before the port binds (else autoheal would restart it mid-load);
    # a first-boot world *generation* can exceed this but is a rare one-time event.
    {{ healthcheck("[\"CMD\", \"bash\", \"-c\", \"grep -q ':1E61 [0-9A-F]*:0000 0A ' /proc/net/tcp\"]", start_period='120s') }}
    {{ service_networks() }}
    labels:
      - "traefik.enable=true"
      - "traefik.tcp.routers.terraria.entrypoints=terraria"
      - "traefik.tcp.routers.terraria.rule=HostSNI(`*`)"
      - "traefik.tcp.services.terraria.loadbalancer.server.port=7777"
      {{ kuma(container_item.name) }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('2.0', '2048M', '0.25', '512M') }}

{{ external_networks() }}
