{% from 'traefik.yml.j2' import labels with context %}
{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'healthcheck.yml.j2' import healthcheck %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
---

services:
  healthchecks:
    image: lscr.io/linuxserver/healthchecks:latest
    container_name: healthchecks
    environment:
      - PUID={{ puid }}
      - PGID={{ pgid }}
      - SITE_ROOT=https://healthchecks.{{ domain }}
      - SITE_NAME=Home Server healthchecks
      - DEFAULT_FROM_EMAIL={{ email }}
      # Include the .local. host so WireGuard access (Traefik routes both) doesn't 400.
      - ALLOWED_HOSTS=localhost,healthchecks.{{ domain }},healthchecks.local.{{ domain }} #optional
      - EMAIL_HOST=smtp.gmail.com
      - EMAIL_PORT=587
      - EMAIL_HOST_USER={{ healthchecks_smtp_user }}
      - EMAIL_HOST_PASSWORD={{ healthchecks_smtp_password }}
      - EMAIL_USE_TLS=True
      - SUPERUSER_EMAIL={{ email }}
      - SUPERUSER_PASSWORD={{ healthchecks_password }}
      - REGISTRATION_OPEN=False
    volumes:
      - ./config:/config
    cap_drop:
      - ALL
    cap_add:
      - SETGID
      - SETUID
      - CHOWN
    security_opt:
      - no-new-privileges:true
    {{ service_networks() }}
    # -sL follows the "/" 302 (Django login redirect) to a real 200 — `curl --fail` treats a bare
    # 302 as success, so without -L the check greens on an up-but-broken app that still 302s (the
    # DB isn't even touched to serve the redirect). -o /dev/null discards the body.
    {{ healthcheck('curl --fail -sL http://localhost:8000/ -o /dev/null || exit 1') }}
    restart: unless-stopped
    labels:
      {# Generate labels(container, port, docker_network, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          (container_item.networks | default([docker_network]))[0],
          container_item.use_authelia
        )
      }}
      {{ kuma(container_item.name) }}

      ## Ping Bypass (Public)
      # Trailing slash anchors to the /ping/ path SEGMENT (pings are /ping/<uuid>): a bare
      # PathPrefix(`/ping`) also matches sibling paths like /pingXYZ, extending this public
      # no-Authelia bypass to them.
      - "traefik.http.routers.healthchecks-ping.rule=(Host(`healthchecks.{{ domain }}`) || Host(`healthchecks.local.{{ domain }}`)) && PathPrefix(`/ping/`)"
      - "traefik.http.routers.healthchecks-ping.entrypoints=https"
      - "traefik.http.routers.healthchecks-ping.tls=true"
      - "traefik.http.routers.healthchecks-ping.service=healthchecks"
      # rate-limit moved off the https entrypoint to per-router; re-acquire the default.
      - "traefik.http.routers.healthchecks-ping.middlewares=rate-limit@file"
      # Priority must be higher than the UI router so Traefik matches this first
      - "traefik.http.routers.healthchecks-ping.priority=100"
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('0.50', '512M', '0.05', '64M') }}

{{ external_networks() }}
