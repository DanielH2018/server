{% from 'traefik.yml.j2' import labels with context %}
{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
{% from 'healthcheck.yml.j2' import healthcheck %}
---
services:
  # Dedicated socket proxy for Portainer only. Portainer needs write (POST) and
  # exec (EXEC) access to manage containers; keeping those powerful permissions on
  # a private 1:1 network here keeps them off the shared docker-proxy, which is
  # reachable from the proxy/monitoring/apps networks.
  #
  # ACCEPTED SECURITY TRADE-OFF: POST + EXEC on the Docker API are effectively
  # root-on-host (EXEC = "Console" into any container). This is inherent to running
  # Portainer for container management; the risk is accepted and contained by:
  #   - portainer_internal (internal: true) — only Portainer can reach this proxy;
  #     it is deliberately NOT on the proxy/monitoring/apps networks.
  #   - Portainer's own admin login + Authelia 2FA in front of the UI (server host).
  #   - socket mounted :ro, proxy is read_only + no-new-privileges + cap_drop ALL.
  docker-proxy-portainer:
    image: lscr.io/linuxserver/socket-proxy:latest
    container_name: docker-proxy-portainer
    environment:
      - CONTAINERS=1
      - SERVICES=1
      - TASKS=1
      - POST=1        # Write ops (create/start/stop) — required by Portainer
      - EXEC=1        # Container "Console" access — required by Portainer
      - INFO=1
      - VERSION=1
      - PING=1
      - IMAGES=1
      - VOLUMES=1
      - NETWORKS=1
      - EVENTS=1
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
    read_only: true
    tmpfs:
      - /run
    restart: unless-stopped
    # LSIO socket-proxy is haproxy on a high port (2375) — already read_only + tmpfs.
    # Empty add; if haproxy can't drop to its user, add [SETUID, SETGID]. Verify on deploy.
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    networks:
      - portainer_internal
    healthcheck:
      test: ["CMD-SHELL", "wget -qO /dev/null http://localhost:2375/version || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 10s
    labels:
      # Disable watchtower update
      - "com.centurylinklabs.watchtower.enable=false"
      {{ kuma('docker-proxy-portainer') }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('0.50', '128M', '0.05', '16M') }}

  portainer:
    # Pinned (was the mutable `alpine` LTS channel tag): portainer is stateful (own BoltDB
    # under ./data) so it belongs to the Renovate-managed tier, not watchtower's auto-update
    # pool. Pin digest-verified against the image that was actually running (the OCI version
    # label is absent on this image — a Hub tag digest match is the only reliable check).
    image: portainer/portainer-ce:2.43.0-alpine
    container_name: portainer
    restart: unless-stopped
    # Go binary on a high port; /data is root-owned and it performs no privileged ops.
    # Verify on deploy (docker logs portainer) — add back caps if it fails.
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    ports:
      # Intentional break-glass access: lets us reach Portainer on the LAN even if
      # Traefik / Authelia / CrowdSec are down. Not forwarded externally.
      # Bound to the host's LAN IP only (not 0.0.0.0) to keep it off other interfaces.
      - "{{ server_ip }}:9000:9000"
    {{ service_networks() }}
      - portainer_internal
    volumes:
      # Portainer's clock stays UTC by design (not the homelab's America/Chicago): the
      # portainer-ce:alpine image ships NO zoneinfo, so a TZ env can't resolve a zone, and the
      # host's /etc/localtime is itself UTC — so this mount yields UTC too. Reaching CDT would need
      # a custom tzdata build, not worth it for an admin UI's timestamps. Left explicit + documented
      # so the localtime-vs-TZ review doesn't re-flag it (see traefik, which DOES have zoneinfo).
      - /etc/localtime:/etc/localtime:ro
      - ./data:/data
      # 0600 file-mount of the mutual portainer-agent shared secret, exported by the entrypoint
      # wrapper below — keeps AGENT_SECRET out of the docker-proxy-readable Env (see its note).
      - ./secrets/portainer_agent_secret:/run/secrets/portainer_agent_secret:ro
    environment:
      # Portainer 2.43.0+ REQUIRES full scheme://host[:port] origins and FATAL-crashes on a bare
      # domain ("invalid trusted origin: must be scheme://host or scheme://host:port" — verified
      # live 2026-07-06 on the 2.39.4→2.43.0 Renovate bump, which the gitops health gate rolled
      # back). This INVERTS the pre-2.43 rule (2.39.4 crash-looped on a full origin and needed the
      # bare domain). Two origins, comma-separated: the Traefik/Authelia path (portainer.<domain>)
      # and the break-glass :9000 LAN path (see the ports mapping above). Keep them full-scheme.
      TRUSTED_ORIGINS: "https://portainer.{{ domain }},http://{{ server_ip }}:9000"
    # AGENT_SECRET is the MUTUAL shared secret that authenticates to daniel-pi's root-equivalent
    # portainer-agent (the agent rejects secret-less requests, so the server must present the SAME
    # value the Pi agent has). Inlined as an env it lands in portainer's Config.Env, which the shared
    # read-only docker-proxy exposes to every proxy/monitoring-net neighbor (2026-07-16 review M1) — a
    # pivot to root-equivalent Docker on the Pi. Portainer CE has no AGENT_SECRET_FILE, so this
    # entrypoint wrapper exports it from the 0600 file-mount and execs portainer (the autokuma/
    # scrutiny-web pattern). `$$(cat …)` strips a trailing newline; `exec "$$@"` keeps portainer as
    # PID 1; `$$` doubled so Compose doesn't interpolate. Only affects agent-type environments.
    entrypoint:
      - /bin/sh
      - -c
      - 'export AGENT_SECRET="$$(cat /run/secrets/portainer_agent_secret)"; exec "$$@"'
      - --
    command: ["/portainer", "-H", "tcp://docker-proxy-portainer:2375"]
    depends_on:
      docker-proxy-portainer:
        condition: service_healthy
    {{ healthcheck('wget --no-verbose --tries=1 --spider http://localhost:9000/ || exit 1') }}
    labels:
      # Disable watchtower update — pinned + Renovate-managed
      - "com.centurylinklabs.watchtower.enable=false"
      {# Generate labels(container, port, docker_network, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          (container_item.networks | default([docker_network]))[0],
          container_item.use_authelia
        )
      }}
      {{ kuma(container_item.name) }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('1.0', '512M', '0.10', '64M') }}
{{ external_networks() }}
  portainer_internal:
    internal: true
