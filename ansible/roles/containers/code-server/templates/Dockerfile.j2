FROM lscr.io/linuxserver/code-server:latest

# 1. Install System Dependencies
RUN apt-get update && apt-get install -y \
    git \
    python3 \
    python3-pip \
    python3-venv \
    docker.io \
    texlive-full \
    curl \
    && curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/* \
    && ln -s /usr/bin/python3 /usr/bin/python

# 2. Create the Virtual Environment
# Place it in /opt/venv so it is NOT overwritten by your ./config volume mount
ENV VIRTUAL_ENV=/opt/venv
RUN python3 -m venv $VIRTUAL_ENV

# 3. Update the PATH
ENV PATH="$VIRTUAL_ENV/bin:$PATH"

# 4. Install Python Packages
RUN pip install --no-cache-dir \
    uv \
    pandas \
    requests \
    ruff \
    google-genai \
    ty \
    structlog \
    python-dotenv

# 5. Install Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# 6. Fix Python venv Permissions
RUN chown -R {{ puid }}:{{ pgid }} $VIRTUAL_ENV

# 7. Download proprietary VS Code Marketplace extensions (not available on Open VSX)
RUN mkdir -p /opt/vsix && \
    PROPRIETARY_EXTS=" \
        ms-python.vscode-pylance \
    " && \
    for ext in $PROPRIETARY_EXTS; do \
        publisher=$(echo "$ext" | cut -d. -f1) && \
        name=$(echo "$ext" | cut -d. -f2) && \
        version=$(curl -fsSL -X POST \
            -H "Content-Type: application/json" \
            -H "Accept: application/json;api-version=7.2-preview.1" \
            -d "{\"filters\":[{\"criteria\":[{\"filterType\":7,\"value\":\"${ext}\"}]}],\"flags\":1}" \
            "https://marketplace.visualstudio.com/_apis/public/gallery/extensionquery?api-version=7.2-preview.1" | \
            python3 -c "import sys,json; print(json.load(sys.stdin)['results'][0]['extensions'][0]['versions'][0]['version'])") && \
        curl -fsSL --compressed -A "VSCode/1.95.0" -o "/opt/vsix/${name}.vsix" \
            "https://marketplace.visualstudio.com/_apis/public/gallery/publishers/${publisher}/vsextensions/${name}/${version}/vspackage" && \
        echo "Downloaded ${ext} ${version}"; \
    done

# 8. Install startup script to load proprietary extensions into the config volume
COPY proprietary-extensions.sh /custom-cont-init.d/10-proprietary-extensions.sh
RUN chmod +x /custom-cont-init.d/10-proprietary-extensions.sh
