{% from 'traefik.yml.j2' import labels with context %}
---
version: "3.8"
services:
  code-server:
    build: .
    image: my-code-server:latest
    container_name: code-server
    environment:
      PUID: {{ puid }}
      PGID: {{ pgid }}
      TZ: {{ tz }}
      PASSWORD: {{ code_server_password }}
      SUDO_PASSWORD: {{ code_server_sudo_password }}
      EXTENSIONS_GALLERY: '{"serviceUrl": "https://marketplace.visualstudio.com/_apis/public/gallery", "itemUrl": "https://marketplace.visualstudio.com/items"}'
      VSCODE_EXTENSION_IDS: ms-azuretools.vscode-docker|ms-python.python|ms-python.vscode-pylance|charliermarsh.ruff|GitHub.copilot|GitHub.copilot-chat|astral-sh.ty|google.geminicodeassist
    volumes:
      - ./config:/config
      - /var/run/docker.sock:/var/run/docker.sock
    restart: unless-stopped
    networks:
      - {{ docker_network }}
    healthcheck:
      test: curl --fail -s http://localhost:8443/healthz/ || exit 1
      start_period: 1m
      interval: 30s
      timeout: 10s
      retries: 6
    labels:
      # Enable traefik for container
      - "traefik.enable=true"
      # Use traefik network
      - "traefik.docker.network={{ docker_network }}"

      {# Generate labels(container, port, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          container_item.use_authelia
        )
      }}

networks:
  {{ docker_network }}:
    external: true
