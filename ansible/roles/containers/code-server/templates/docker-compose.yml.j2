{% from 'traefik.yml.j2' import labels with context %}
{% from 'autokuma.yml.j2' import labels as kuma with context %}
---

services:
  code-server:
    build: .
    image: my-code-server:latest
    container_name: code-server
    environment:
      PUID: {{ puid }}
      PGID: {{ pgid }}
      TZ: {{ tz }}
      PASSWORD: {{ code_server_password }}
      SUDO_PASSWORD: {{ code_server_sudo_password }}
      EXTENSIONS_GALLERY: '{"serviceUrl": "https://open-vsx.org/vscode/gallery", "itemUrl": "https://open-vsx.org/vscode/item"}'
      DOCKER_HOST: tcp://docker-proxy:2375
    volumes:
      - ./config:/config
    restart: unless-stopped
    cap_drop:
      - ALL
    cap_add:
      - SETGID
      - SETUID
      - CHOWN
      - DAC_OVERRIDE
    security_opt:
      - no-new-privileges:true
    networks:
{% for net in container_item.networks | default([docker_network]) %}
      - {{ net }}
{% endfor %}
    healthcheck:
      test: curl --fail -s http://localhost:8443/healthz/ || exit 1
      start_period: 1m
      interval: 30s
      timeout: 10s
      retries: 6
    labels:
      {# Generate labels(container, port, docker_network, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          (container_item.networks | default([docker_network]))[0],
          container_item.use_authelia
        )
      }}
      {{ kuma(container_item.name) }}
      # Watchtower
      - "com.centurylinklabs.watchtower.depends-on:docker-proxy"
    # Resource caps for blast-radius containment (M1). Dev env can run builds, so
    # size generously and tune from cAdvisor/Grafana.
    deploy:
      resources:
        limits:
          cpus: '4.0'
          memory: 4096M
        reservations:
          cpus: '0.10'
          memory: 256M

networks:
{% for net in container_item.networks | default([docker_network]) %}
  {{ net }}:
    external: true
{% endfor %}
