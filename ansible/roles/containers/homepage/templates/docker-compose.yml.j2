{% from 'traefik.yml.j2' import labels with context %}
---
version: "3.8"
services:
  dockerproxy:
    image: lscr.io/linuxserver/socket-proxy:latest
    container_name: dockerproxy
    environment:
      - CONTAINERS=1 # Allow access to viewing containers
      - SERVICES=1 # Allow access to viewing services (necessary when using Docker Swarm)
      - TASKS=1 # Allow access to viewing tasks (necessary when using Docker Swarm)
      - POST=0 # Disallow any POST operations (effectively read-only)
    networks:
      - {{ docker_network }}
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro # Mounted as read-only
    read_only: true
    tmpfs:
      - /run
    restart: unless-stopped

  homepage:
    image: ghcr.io/gethomepage/homepage:latest
    container_name: homepage
    environment:
      - puid={{ puid }}
      - pgid={{ pgid }}
      - tz={{ tz }}
      - HOMEPAGE_ALLOWED_HOSTS=homepage.{{ DOMAIN }}
    restart: unless-stopped
    networks:
      - {{ docker_network }}
    volumes:
      - ./config:/app/config
      - ./icons:/app/public/icons
    labels:
      # Enable traefik for container
      - "traefik.enable=true"
      # Use traefik network
      - "traefik.docker.network={{ docker_network }}"

      {# Generate labels(container, port, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          container_item.use_authelia
        )
      }}

networks:
  {{ docker_network }}:
    external: true
    