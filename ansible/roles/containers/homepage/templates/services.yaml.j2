- Media:
    - Jellyfin:
        href: https://jellyfin.[REMOVED_KEY]
        icon: jellyfin.png
        description: Mediaserver
        server: my-docker
        container: jellyfin
        widget:
          type: jellyfin
          url: http://jellyfin:8096
          key: {{ jellyfin_api_key }}
    - Sonarr:
        icon: sonarr.png
        href: https://sonarr.[REMOVED_KEY]/
        description: Series management
        server: my-docker
        container: sonarr
        widget:
            type: sonarr
            fields: ["wanted", "queued"]
            url: http://sonarr:8989
            key: {{ sonarr_api_key }}
    - Radarr:
        icon: radarr.png
        href: https://radarr.[REMOVED_KEY]/
        description: Movie management
        server: my-docker
        container: radarr
        widget:
          type: radarr
          fields: ["wanted", "queued"]
          url: http://radarr:7878
          key: {{ radarr_api_key }}
    - qBittorrent:
        icon: qbittorrent.png
        href: https://qBittorrent.[REMOVED_KEY]
        description: Download management
        server: my-docker
        container: qbittorrent
        widget:
            type: qbittorrent
            url: http://wireguard:8080
            username: {{ qbittorrent_username }}
            password: {{ qbittorrent_password }}

- Services:
    - Portainer:
        icon: portainer.png
        href: https://portainer.[REMOVED_KEY]
        description: Container management
        server: my-docker
        container: portainer
        widget:
          type: portainer
          url: http://portainer:9000
          env: 2
          key: {{ portainer_api_key }}
    - Pihole:
        icon: pi-hole.png
        href: https://pihole.[REMOVED_KEY]/admin
        description: DNS Ad Blocker
        server: my-docker
        container: pihole
        widget:
          type: pihole
          url: http://pihole:80
          version: 6
          key: {{ pihole_api_key }}
    - Traefik:
        icon: traefik.png
        href: https://traefik.[REMOVED_KEY]/dashboard/
        description: Reverse Proxy
        server: my-docker
        container: traefik
        widget:
            type: traefik
            url: "http://traefik:8888"
            headers:
                host: "traefik-internal"
    - Uptime-Kuma:
        icon: uptime-kuma.png
        href: https://uptime-kuma.[REMOVED_KEY]/
        description: Container Monitoring
        server: my-docker
        container: uptime-kuma
        widget:
            type: uptimekuma
            url: http://uptime-kuma:3001
            slug: containers
    - Beszel:
        icon: beszel.png
        href: http://beszel.[REMOVED_KEY]/
        description: Container Monitoring
        server: my-docker
        container: beszel
        widget:
            type: beszel
            url: http://beszel:8090
            username: {{ email }} # email
            password: {{ beszel_password }}
            systemId: {{ beszel_system }} # optional
            version: 2
    - Scrutiny:
        icon: scrutiny.png
        href: http://scrutiny.[REMOVED_KEY]/
        description: Drive Monitoring
        server: my-docker
        container: scrutiny
        widget:
            type: scrutiny
            url: http://scrutiny:8080
    - FreshRSS:
        icon: freshrss.png
        href: https://freshrss.[REMOVED_KEY]/
        description: RSS Link Aggregator
        server: my-docker
        container: freshrss
        widget:
            type: freshrss
            url: http://freshrss:80
            username: {{ freshrss_username }}
            password: {{ FRESHRSS_PASSWORD }}
    - Speedtest:
        icon: speedtest-tracker.png
        href: https://speedtest.[REMOVED_KEY]/
        description: Internet tracking
        server: my-docker
        container: speedtest
        widget:
            type: speedtest
            url: http://speedtest:80

- Monitoring:
    - CPU Usage:
        href: http://glances.[REMOVED_KEY]/
        description: CPU Monitoring
        server: my-docker
        container: glances
        widget:
            type: glances
            url: http://glances:61208
            version: 4
            metric: cpu
    - Memory Usage:
        href: http://glances.[REMOVED_KEY]/
        description: Memory Monitoring
        server: my-docker
        container: glances
        widget:
            type: glances
            url: http://glances:61208
            version: 4
            metric: memory
            diskUnits: bytes
    - Network Usage:
        href: http://glances.[REMOVED_KEY]/
        description: Network Monitoring
        server: my-docker
        container: glances
        widget:
            type: glances
            url: http://glances:61208
            version: 4
            metric: network:eth0
    - Top Processes:
        href: http://glances.[REMOVED_KEY]/
        description: Process Monitoring
        server: my-docker
        container: glances
        widget:
            type: glances
            url: http://glances:61208
            version: 4
            metric: process
    - CPU Temp:
        href: http://glances.[REMOVED_KEY]/
        description: CPU Temperature Monitoring
        server: my-docker
        container: glances
        widget:
            type: glances
            url: http://glances:61208
            version: 4
            metric: sensor:Package id 0
    - Disk I/O:
        href: http://glances.[REMOVED_KEY]/
        description: Disk I/O Monitoring
        server: my-docker
        container: glances
        widget:
            type: glances
            url: http://glances:61208
            version: 4
            metric: disk:nvme0n1

- Tracking:
    - Crypto:
        widget:
            type: coinmarketcap
            currency: USD # Optional
            symbols: [BTC, ETH, DOGE]
            key: {{ coinmarket_api_key }}
            defaultinterval: 24h # Optional
