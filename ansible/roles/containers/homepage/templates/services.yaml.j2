
- Calendar:
    - Calendar:
        widget:
          type: calendar
          firstDayInWeek: sunday
          view: monthly
          maxEvents: 10
          showTime: true
          timezone: {{ tz }}
          integrations:
            - type: ical
              url: {{ calendar_1 }}
              name: Daniel
              color: indigo
              params:
                showName: true
            - type: ical
              url: {{ calendar_2 }}
              name: Hannah
              color: emerald
              params:
                showName: true
            - type: ical
              url: {{ calendar_3 }}
              name: Holidays
              color: purple
              params:
                showName: true
- Media:
    - Jellyfin:
        href: https://jellyfin.{{ domain }}
        icon: jellyfin.png
        description: Mediaserver
        server: my-docker
        container: jellyfin
        widget:
          type: jellyfin
          url: http://jellyfin:8096
          key: {{ jellyfin_api_key }}
    - Sonarr:
        icon: sonarr.png
        href: https://sonarr.{{ domain }}/
        description: Series management
        server: my-docker
        container: sonarr
        widget:
            type: sonarr
            fields: ["wanted", "queued"]
            url: http://sonarr:8989
            key: {{ sonarr_api_key }}
    - Radarr:
        icon: radarr.png
        href: https://radarr.{{ domain }}/
        description: Movie management
        server: my-docker
        container: radarr
        widget:
          type: radarr
          fields: ["wanted", "queued"]
          url: http://radarr:7878
          key: {{ radarr_api_key }}
    - qBittorrent:
        icon: qbittorrent.png
        href: https://qBittorrent.{{ domain }}
        description: Download management
        server: my-docker
        container: qbittorrent
        widget:
            type: qbittorrent
            url: http://wireguard:8080
            username: {{ qbittorrent_username }}
            password: {{ qbittorrent_password }}

- Services:
    - Portainer:
        icon: portainer.png
        href: https://portainer.{{ domain }}
        description: Container management
        server: my-docker
        container: portainer
        widget:
          type: portainer
          url: http://portainer:9000
          env: 1
          key: {{ portainer_api_key }}
    - Pihole:
        icon: pi-hole.png
        href: https://pihole.{{ domain }}/admin
        description: DNS Ad Blocker
        server: my-docker
        container: pihole
        widget:
          type: pihole
          url: http://pihole:80
          version: 6
          key: {{ pihole_api_key }}
    - Crowdsec:
        icon: crowdsec.png
        href: https://crowdsec.{{ domain }}/
        description: Crowdsec
        server: my-docker
        container: crowdsec
        widget:
            type: crowdsec
            url: "http://crowdsec:8080"
            username: {{ crowdsec_username }}
            password: "{{ crowdsec_password }}"
            limit24h: true
    - Uptime-Kuma:
        icon: uptime-kuma.png
        href: https://uptime-kuma.{{ domain }}/
        description: Container Monitoring
        server: my-docker
        container: uptime-kuma
        widget:
            type: uptimekuma
            url: http://uptime-kuma:3001
            slug: containers
    - Tdarr:
        icon: tdarr.png
        href: http://tdarr.{{ domain }}/
        description: Media Transcoding
        server: my-docker
        container: tdarr
        widget:
            type: tdarr
            url: http://tdarr:8265

    - Scrutiny:
        icon: scrutiny.png
        href: http://scrutiny.{{ domain }}/
        description: Drive Monitoring
        server: my-docker
        container: scrutiny
        widget:
            type: scrutiny
            url: http://scrutiny:8080
    - FreshRSS:
        icon: freshrss.png
        href: https://freshrss.{{ domain }}/
        description: RSS Link Aggregator
        server: my-docker
        container: freshrss
        widget:
            type: freshrss
            url: http://freshrss:80
            username: {{ freshrss_username }}
            password: {{ freshrss_password }}
    - Speedtest:
        icon: speedtest-tracker.png
        href: https://speedtest.{{ domain }}/
        description: Internet tracking
        server: my-docker
        container: speedtest
        widget:
            type: speedtest
            url: http://speedtest:80

- Monitoring:
    - CPU Usage:
        href: http://glances.{{ domain }}/
        description: CPU Monitoring
        server: my-docker
        container: glances
        widget:
            type: glances
            url: http://glances:61208
            version: 4
            metric: cpu
    - Memory Usage:
        href: http://glances.{{ domain }}/
        description: Memory Monitoring
        server: my-docker
        container: glances
        widget:
            type: glances
            url: http://glances:61208
            version: 4
            metric: memory
            diskUnits: bytes
    - Network Usage:
        href: http://glances.{{ domain }}/
        description: Network Monitoring
        server: my-docker
        container: glances
        widget:
            type: glances
            url: http://glances:61208
            version: 4
            metric: network:eth0
    - Top Processes:
        href: http://glances.{{ domain }}/
        description: Process Monitoring
        server: my-docker
        container: glances
        widget:
            type: glances
            url: http://glances:61208
            version: 4
            metric: process
    - CPU Temp:
        href: http://glances.{{ domain }}/
        description: CPU Temperature Monitoring
        server: my-docker
        container: glances
        widget:
            type: glances
            url: http://glances:61208
            version: 4
            metric: sensor:Package id 0
    - Disk I/O:
        href: http://glances.{{ domain }}/
        description: Disk I/O Monitoring
        server: my-docker
        container: glances
        widget:
            type: glances
            url: http://glances:61208
            version: 4
            metric: disk:nvme0n1

- Tracking:
    - Crypto:
        widget:
            type: coinmarketcap
            currency: USD # Optional
            symbols: [BTC, ETH, DOGE]
            key: {{ coinmarket_api_key }}
            defaultinterval: 24h # Optional
