{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
{% from 'healthcheck.yml.j2' import healthcheck %}
---
services:
  ical-proxy:
    build:
      context: .
      pull: true  # rebuilds must fetch the newest python base
    container_name: ical-proxy
    restart: unless-stopped
    {{ healthcheck('["CMD", "bash", "-c", "echo > /dev/tcp/127.0.0.1/5000"]', start_period='10s') }}
    environment:
      - GOOGLE_ICS_URL={{ calendar_1 }}
      - GOOGLE_ICS_URL_2={{ calendar_2 }}
      - OBSIDIAN_GIST_URL={{ calendar_4 }}
      - REFRESH_INTERVAL=900   # 15 minutes in seconds
      - PYTHONDONTWRITEBYTECODE=1
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    # Read-only rootfs: `docker diff` shows only .pyc bytecode (killed by
    # PYTHONDONTWRITEBYTECODE below); app.py caches calendars in memory, never on disk.
    read_only: true
    tmpfs:
      - /tmp
    {{ service_networks() }}
    labels:
      {{ kuma('ical-proxy') }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('0.50', '128M', '0.05', '16M') }}

{{ external_networks() }}
