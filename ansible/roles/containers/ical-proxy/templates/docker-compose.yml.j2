{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
---
services:
  ical-proxy:
    build: .   # path to the folder you created
    container_name: ical-proxy
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "bash", "-c", "echo > /dev/tcp/127.0.0.1/5000"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s
    environment:
        - GOOGLE_ICS_URL={{ calendar_1 }}
        - GOOGLE_ICS_URL_2={{ calendar_2 }}
        - OBSIDIAN_GIST_URL={{ calendar_4 }}
        - REFRESH_INTERVAL=900   # 15 minutes in seconds
    cap_drop:
        - ALL
    security_opt:
        - no-new-privileges:true
    {{ service_networks() }}
    labels:
      {{ kuma('ical-proxy') }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    deploy:
      resources:
        limits:
          cpus: '0.50'
          memory: 128M
        reservations:
          cpus: '0.05'
          memory: 16M

{{ external_networks() }}
