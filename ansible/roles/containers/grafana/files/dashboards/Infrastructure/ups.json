{
  "uid": "ups-power-battery",
  "title": "UPS — Power & Battery",
  "tags": ["homelab", "power", "ups"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-7d", "to": "now" },
  "panels": [
    { "id": 1, "type": "row", "title": "Battery & Runway", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 } },
    { "id": 2, "type": "gauge", "title": "Battery charge",
      "description": "monitor-bridge check_ups pages below 50% (a deep discharge on battery).",
      "datasource": { "type": "prometheus", "uid": "EGdsQqhVk" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [
        { "color": "red", "value": null }, { "color": "yellow", "value": 50 }, { "color": "green", "value": 90 } ] } },
        "overrides": [] },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 1 },
      "targets": [ { "refId": "A", "expr": "hass_sensor_battery_percent{entity=\"sensor.apc_ups_battery_charge\"}", "legendFormat": "charge",
        "datasource": { "type": "prometheus", "uid": "EGdsQqhVk" } } ] },
    { "id": 3, "type": "stat", "title": "Estimated runtime",
      "description": "Runway at the current load. monitor-bridge check_ups pages below 5 min (aged battery or a discharge nearing shutdown).",
      "datasource": { "type": "prometheus", "uid": "EGdsQqhVk" },
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [
        { "color": "red", "value": null }, { "color": "yellow", "value": 300 }, { "color": "green", "value": 600 } ] } },
        "overrides": [] },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 1 },
      "targets": [ { "refId": "A", "expr": "hass_sensor_duration_s{entity=\"sensor.apc_ups_battery_runtime\"}", "legendFormat": "runtime",
        "datasource": { "type": "prometheus", "uid": "EGdsQqhVk" } } ] },
    { "id": 8, "type": "stat", "title": "Replace-battery self-test",
      "description": "NUT's RB (Replace Battery) verdict via HA binary_sensor.apc_ups_replace_battery. monitor-bridge check_ups pages on this — the earliest UPS signal, it can trip while charge/runtime still read fine.",
      "datasource": { "type": "prometheus", "uid": "EGdsQqhVk" },
      "fieldConfig": { "defaults": {
        "mappings": [ { "type": "value", "options": {
          "0": { "text": "OK", "color": "green" }, "1": { "text": "REPLACE", "color": "red" } } } ],
        "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } },
        "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "targets": [ { "refId": "A", "expr": "hass_binary_sensor_state{entity=\"binary_sensor.apc_ups_replace_battery\"}", "legendFormat": "replace-battery",
        "datasource": { "type": "prometheus", "uid": "EGdsQqhVk" } } ] },
    { "id": 4, "type": "timeseries", "title": "Battery runtime (trend)",
      "description": "Full-charge runway decaying over weeks/months is the aging-battery signal check_ups' floor eventually trips — widen the range to spot slow decay.",
      "datasource": { "type": "prometheus", "uid": "EGdsQqhVk" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 },
        "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 300 } ] } },
        "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 9 },
      "targets": [ { "refId": "A", "expr": "hass_sensor_duration_s{entity=\"sensor.apc_ups_battery_runtime\"}", "legendFormat": "runtime",
        "datasource": { "type": "prometheus", "uid": "EGdsQqhVk" } } ] },
    { "id": 5, "type": "row", "title": "Mains & Load", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 } },
    { "id": 6, "type": "timeseries", "title": "Input voltage",
      "description": "Mains voltage into the UPS — a drop toward 0 means it's on battery (an outage/brownout).",
      "datasource": { "type": "prometheus", "uid": "EGdsQqhVk" },
      "fieldConfig": { "defaults": { "unit": "volt", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "targets": [ { "refId": "A", "expr": "hass_sensor_voltage_v{entity=\"sensor.apc_ups_input_voltage\"}", "legendFormat": "input voltage",
        "datasource": { "type": "prometheus", "uid": "EGdsQqhVk" } } ] },
    { "id": 7, "type": "timeseries", "title": "Load",
      "description": "UPS output load — higher load shortens the estimated runtime above.",
      "datasource": { "type": "prometheus", "uid": "EGdsQqhVk" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "targets": [ { "refId": "A", "expr": "hass_sensor_unit_percent{entity=\"sensor.apc_ups_load\"}", "legendFormat": "load",
        "datasource": { "type": "prometheus", "uid": "EGdsQqhVk" } } ] }
  ]
}
