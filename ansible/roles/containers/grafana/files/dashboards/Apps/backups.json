        "uid": "EGdsQqhVk"
      },
      "description": "Billable bytes in the Backblaze B2 bucket (includes hidden file versions, the way B2 bills) vs the 10 GB free-tier cap, with the monitor-bridge 7-day linear projection. The cap (red) and 85% alert line (orange) are drawn as thresholds.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
