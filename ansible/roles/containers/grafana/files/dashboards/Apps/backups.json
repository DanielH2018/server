          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "EGdsQqhVk"
          },
          "expr": "predict_linear(kopia_b2_billable_bytes[7d], 7 * 86400)",
          "legendFormat": "7d projection",
          "range": true,
          "refId": "B"
        }
