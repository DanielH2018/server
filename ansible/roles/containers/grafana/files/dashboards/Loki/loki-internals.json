{
  "uid": "homelab-loki-internals",
  "title": "Loki — Internals",
  "description": "Loki's own /metrics (scraped into Prometheus, job=loki): ingestion rate, request rate/latency/errors and chunk flushes. The trend history the monitor-bridge loki_ingestion check + /ready probe don't retain.",
  "tags": ["loki", "homelab"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Log Lines Ingested / sec",
      "datasource": { "type": "prometheus", "uid": "EGdsQqhVk" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(rate(loki_distributor_lines_received_total[$__rate_interval]))", "legendFormat": "lines/s", "datasource": { "type": "prometheus", "uid": "EGdsQqhVk" } }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Bytes Ingested / sec",
      "datasource": { "type": "prometheus", "uid": "EGdsQqhVk" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(rate(loki_distributor_bytes_received_total[$__rate_interval]))", "legendFormat": "bytes/s", "datasource": { "type": "prometheus", "uid": "EGdsQqhVk" } }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Request Rate by Route",
      "datasource": { "type": "prometheus", "uid": "EGdsQqhVk" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(rate(loki_request_duration_seconds_count[$__rate_interval])) by (route)", "legendFormat": "{{route}}", "datasource": { "type": "prometheus", "uid": "EGdsQqhVk" } }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Request p99 Latency by Route",
      "datasource": { "type": "prometheus", "uid": "EGdsQqhVk" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.99, sum(rate(loki_request_duration_seconds_bucket[$__rate_interval])) by (le, route))", "legendFormat": "{{route}}", "datasource": { "type": "prometheus", "uid": "EGdsQqhVk" } }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "5xx Errors / sec by Route",
      "datasource": { "type": "prometheus", "uid": "EGdsQqhVk" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 60 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(rate(loki_request_duration_seconds_count{status_code=~\"5..\"}[$__rate_interval])) by (route)", "legendFormat": "{{route}}", "datasource": { "type": "prometheus", "uid": "EGdsQqhVk" } }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Chunks Flushed / sec",
      "datasource": { "type": "prometheus", "uid": "EGdsQqhVk" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(rate(loki_ingester_chunks_flushed_total[$__rate_interval]))", "legendFormat": "chunks/s", "datasource": { "type": "prometheus", "uid": "EGdsQqhVk" } }
      ]
    }
  ]
}
