{% from 'traefik.yml.j2' import labels with context %}
{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'healthcheck.yml.j2' import healthcheck %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
---

services:
  grafana:
    image: grafana/grafana:latest
    container_name: grafana
    user: "{{ puid }}"
    restart: unless-stopped
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    environment:
      - GF_SECURITY_ADMIN_PASSWORD={{ grafana_admin_password }}
      - GF_ANALYTICS_REPORTING_ENABLED=false
      - GF_ANALYTICS_CHECK_FOR_UPDATES=false
    volumes:
      - ./data:/var/lib/grafana
      # Provisioned-as-code datasources + dashboards (read-only; UI edits persist in ./data).
      - ./provisioning/datasources.yml:/etc/grafana/provisioning/datasources/datasources.yml:ro
      - ./provisioning/dashboards.yml:/etc/grafana/provisioning/dashboards/dashboards.yml:ro
      - ./dashboards:/var/lib/grafana/dashboards:ro
    {{ service_networks() }}
    {{ healthcheck('wget --no-verbose --tries=1 --spider http://localhost:3000/ || exit 1') }}
    labels:
      {# Generate labels(container, port, docker_network, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          (container_item.networks | default([docker_network]))[0],
          container_item.use_authelia
        )
      }}
      {{ kuma(container_item.name) }}

      # Watchtower
      - "com.centurylinklabs.watchtower.depends-on=prometheus"
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('1.0', '1024M', '0.10', '128M') }}
  loki:
    image: grafana/loki:latest
    container_name: loki
    restart: unless-stopped
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    environment:
      - TZ={{ tz }}
    expose:
      - 3100
    volumes:
      - ./loki-config.yaml:/etc/loki/loki-config.yaml:ro
      - loki:/tmp
    command: -config.file=/etc/loki/loki-config.yaml
    {{ service_networks() }}
    labels:
      # The image has NO shell or HTTP client (single Go binary), so a Docker
      # healthcheck is impossible — instead Kuma probes /ready over the shared
      # monitoring net, which beats the old container-running docker monitor.
      {{ kuma('loki', monitor_type='http', url='http://loki:3100/ready') }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('1.0', '512M', '0.10', '64M') }}
  promtail:
    image: grafana/promtail:latest
    container_name: promtail
    restart: unless-stopped
    {{ healthcheck('["CMD", "bash", "-c", "echo > /dev/tcp/127.0.0.1/9080"]', start_period='15s') }}
    cap_drop:
      - ALL
    cap_add:
      # Reads root-owned /var/log + /var/lib/docker/containers logs; DAC_READ_SEARCH lets
      # root bypass DAC to read non-root-owned log files. Verify logs still ship on deploy
      # (Grafana Explore → Loki). It writes only its own positions file (owner-writable).
      - DAC_READ_SEARCH
    security_opt:
      - no-new-privileges:true
    environment:
      - TZ={{ tz }}
      - DOCKER_HOST=tcp://docker-proxy:2375
    volumes:
      - ./promtail-config.yaml:/etc/promtail/promtail-config.yaml:ro
      # Access to mounted log files
      - /var/log/:/logs
      # Access to the host log files
      - /var/lib/docker/containers:/var/lib/docker/containers:ro
    command: -config.file=/etc/promtail/promtail-config.yaml
    {{ service_networks() }}
    labels:
      {{ kuma('promtail') }}
      # Watchtower
      - "com.centurylinklabs.watchtower.depends-on=docker-proxy"
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('0.50', '256M', '0.05', '32M') }}

{{ external_networks() }}

volumes:
    loki:
