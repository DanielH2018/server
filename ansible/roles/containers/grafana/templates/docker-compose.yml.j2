{% from 'traefik.yml.j2' import labels with context %}
{% from 'autokuma.yml.j2' import labels as kuma with context %}
---

services:
  grafana:
    image: grafana/grafana:latest
    container_name: grafana
    user: "{{ puid }}"
    restart: unless-stopped
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    environment:
      - GF_SECURITY_ADMIN_PASSWORD={{ grafana_admin_password }}
      - GF_ANALYTICS_REPORTING_ENABLED=false
      - GF_ANALYTICS_CHECK_FOR_UPDATES=false
    volumes:
      - ./data:/var/lib/grafana
    networks:
{% for net in container_item.networks | default([docker_network]) %}
      - {{ net }}
{% endfor %}
    healthcheck:
      test: wget --no-verbose --tries=1 --spider http://localhost:3000/ || exit 1
      interval: 30s
      timeout: 10s
      retries: 3
    labels:
      {# Generate labels(container, port, docker_network, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          (container_item.networks | default([docker_network]))[0],
          container_item.use_authelia
        )
      }}
      {{ kuma(container_item.name) }}

      # Watchtower
      - "com.centurylinklabs.watchtower.depends-on: prometheus"
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    deploy:
      resources:
        limits:
          cpus: '1.0'
          memory: 1024M
        reservations:
          cpus: '0.10'
          memory: 128M
  loki:
    image: grafana/loki:latest
    container_name: loki
    restart: unless-stopped
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    environment:
      - TZ={{ tz }}
    expose:
      - 3100
    volumes:
      - ./loki-config.yaml:/etc/loki/loki-config.yaml:ro
      - loki:/tmp
    command: -config.file=/etc/loki/loki-config.yaml
    networks:
{% for net in container_item.networks | default([docker_network]) %}
      - {{ net }}
{% endfor %}
    labels:
      {{ kuma('loki') }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    deploy:
      resources:
        limits:
          cpus: '1.0'
          memory: 512M
        reservations:
          cpus: '0.10'
          memory: 64M
  promtail:
    image: grafana/promtail:latest
    container_name: promtail
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "bash", "-c", "echo > /dev/tcp/127.0.0.1/9080"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s
    security_opt:
      - no-new-privileges:true
    environment:
      - TZ={{ tz }}
      - DOCKER_HOST=tcp://docker-proxy:2375
    volumes:
      - ./promtail-config.yaml:/etc/promtail/promtail-config.yaml:ro
      # Access to mounted log files
      - /var/log/:/logs
      # Access to the host log files
      - /var/lib/docker/containers:/var/lib/docker/containers:ro
    command: -config.file=/etc/promtail/promtail-config.yaml
    networks:
{% for net in container_item.networks | default([docker_network]) %}
      - {{ net }}
{% endfor %}
    labels:
      {{ kuma('promtail') }}
      # Watchtower
      - "com.centurylinklabs.watchtower.depends-on:docker-proxy"
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    deploy:
      resources:
        limits:
          cpus: '0.50'
          memory: 256M
        reservations:
          cpus: '0.05'
          memory: 32M

networks:
{% for net in container_item.networks | default([docker_network]) %}
  {{ net }}:
    external: true
{% endfor %}

volumes:
    loki:
