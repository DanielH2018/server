server:
  http_listen_port: 9080
  grpc_listen_port: 0

positions:
  filename: /tmp/positions.yaml

clients:
  - url: http://loki:3100/loki/api/v1/push

scrape_configs:
- job_name: authlog
  static_configs:
  - targets:
      - authlog
    labels:
      job: authlog
      __path__: /logs/auth.log

- job_name: syslog
  static_configs:
  - targets:
      - syslog
    labels:
      job: syslog
      __path__: /logs/syslog

- job_name: traefik
  static_configs:
  - targets:
      - traefik
    labels:
      job: traefik
      __path__: /logs/traefik/*log

- job_name: docker
  docker_sd_configs:
    - host: "tcp://docker-proxy:2375"
      refresh_interval: 5s
  relabel_configs:
    # This grabs the container name from the Docker tag
    - source_labels: ['__meta_docker_container_name']
      regex: '/(.*)'
      target_label: 'container'
    # This grabs the "log stream" (stdout or stderr)
    - source_labels: ['__meta_docker_container_log_stream']
      target_label: 'stream'
