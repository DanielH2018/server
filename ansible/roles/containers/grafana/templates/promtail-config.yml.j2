server:
  http_listen_port: 9080
  grpc_listen_port: 0

positions:
  filename: /tmp/positions.yaml

clients:
  - url: http://loki:3100/loki/api/v1/push

scrape_configs:
- job_name: authlog
  static_configs:
  - targets:
      - authlog
    labels:
      job: authlog
      __path__: /logs/auth.log

- job_name: syslog
  static_configs:
  - targets:
      - syslog
    labels:
      job: syslog
      __path__: /logs/syslog

- job_name: traefik
  static_configs:
  - targets:
      - traefik
    labels:
      job: traefik
      __path__: /logs/traefik/*log

- job_name: docker
  docker_sd_configs:
    - host: unix:///var/run/docker.sock
      refresh_interval: 5s

  relabel_configs:
    # 1. Make the container name readable (strips the leading slash)
    - source_labels: ['__meta_docker_container_name']
      regex: '/(.*)'
      target_label: 'container'
    
    # 2. Add the stream (stdout vs stderr) as a label
    - source_labels: ['__meta_docker_container_log_stream']
      target_label: 'stream'

    # 3. Construct the path to the log file on the host using the Container ID
    - source_labels: ['__meta_docker_container_id']
      target_label: '__path__'
      replacement: /var/lib/docker/containers/$1/*.log