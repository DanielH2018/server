{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
---

services:
  monitor-bridge:
    image: python:3.12-alpine
    container_name: monitor-bridge
    user: "{{ puid }}:{{ pgid }}"
    restart: unless-stopped
    # Pure stdlib Python over HTTP — no caps, no writable rootfs needed.
    read_only: true
    tmpfs:
      - /tmp
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    command: ["python", "/app/check.py"]
    environment:
      - TZ={{ tz }}
      - PYTHONUNBUFFERED=1
      - PYTHONDONTWRITEBYTECODE=1
      - INTERVAL=300
      - PROMETHEUS_URL=http://prometheus:9090
      - KOPIA_URL=http://kopia:51515
      - KUMA_URL=http://uptime-kuma:3001
      - BACKUP_SOURCE_PATH=/data/home/{{ sys_user }}/server/containers
      - BACKUP_MAX_AGE_H=30
      - DISK_MOUNTPOINTS=/
      - DISK_MAX_PCT=90
      - CERT_MIN_DAYS=14
      - MEM_MAX_PCT=90
      - OOM_WINDOW=1h
      - CPU_WINDOW=15m
      - CPU_THROTTLE_PCT=25
      - CPU_MIN_THROTTLED_CORES=0.05
      - RESTART_WINDOW=15m
      - RESTART_MAX=3
      - TRAEFIK_5XX_PCT=5
      - TRAEFIK_MIN_RPS=0.05
      # Push tokens: we set them; Kuma honors client-supplied tokens. In secrets.yml.
      - KUMA_PUSH_KOPIA={{ monitor_bridge_kopia_push_token }}
      - KUMA_PUSH_DISK={{ monitor_bridge_disk_push_token }}
      - KUMA_PUSH_CERT={{ monitor_bridge_cert_push_token }}
      - KUMA_PUSH_MEM={{ monitor_bridge_mem_push_token }}
      - KUMA_PUSH_RESTARTS={{ monitor_bridge_restarts_push_token }}
      - KUMA_PUSH_OOM={{ monitor_bridge_oom_push_token }}
      - KUMA_PUSH_CPU={{ monitor_bridge_cpu_push_token }}
      - KUMA_PUSH_TARGETS={{ monitor_bridge_targets_push_token }}
      - KUMA_PUSH_TRAEFIK={{ monitor_bridge_traefik_push_token }}
      # n8n Prod-workflow failure monitoring (active workflows via the n8n public API).
      - N8N_URL=http://n8n:5678
      - N8N_API_KEY={{ n8n_api_key }}
      - N8N_FAIL_WINDOW=15m
      - N8N_FAIL_MAX=0
      - KUMA_PUSH_N8N={{ monitor_bridge_n8n_push_token }}
      # GitOps deployer liveness + deploy-status. State files are written on the host by
      # gitops_deploy.py and bind-mounted read-only at /gitops-state.
      - GITOPS_STATE_DIR=/gitops-state
      - GITOPS_MAX_AGE_MIN=90
      - KUMA_PUSH_GITOPS_ALIVE={{ monitor_bridge_gitops_alive_push_token }}
      - KUMA_PUSH_GITOPS_STATUS={{ monitor_bridge_gitops_status_push_token }}
    volumes:
      - ./check.py:/app/check.py:ro
      - /var/lib/gitops-deploy:/gitops-state:ro
    {{ service_networks() }}
    labels:
      {# Container-liveness monitor + one push monitor per check (AutoKuma-provisioned). -#}
      {{ kuma('monitor-bridge') }}
      {{ kuma('monitor-bridge-backup', monitor_type='push', name='Backup Freshness', interval=600, push_token=monitor_bridge_kopia_push_token) }}
      {{ kuma('monitor-bridge-disk', monitor_type='push', name='Root Disk', interval=600, push_token=monitor_bridge_disk_push_token) }}
      {{ kuma('monitor-bridge-cert', monitor_type='push', name='TLS Cert Expiry', interval=600, push_token=monitor_bridge_cert_push_token) }}
      {{ kuma('monitor-bridge-mem', monitor_type='push', name='Memory', interval=600, push_token=monitor_bridge_mem_push_token) }}
      {{ kuma('monitor-bridge-restarts', monitor_type='push', name='Container Restarts', interval=600, push_token=monitor_bridge_restarts_push_token) }}
      {{ kuma('monitor-bridge-oom', monitor_type='push', name='Container OOM', interval=600, push_token=monitor_bridge_oom_push_token) }}
      {{ kuma('monitor-bridge-cpu', monitor_type='push', name='CPU Throttling', interval=600, push_token=monitor_bridge_cpu_push_token) }}
      {{ kuma('monitor-bridge-targets', monitor_type='push', name='Scrape Targets', interval=600, push_token=monitor_bridge_targets_push_token) }}
      {{ kuma('monitor-bridge-traefik', monitor_type='push', name='Traefik 5xx', interval=600, push_token=monitor_bridge_traefik_push_token) }}
      {{ kuma('monitor-bridge-n8n', monitor_type='push', name='n8n Prod Workflows', interval=600, push_token=monitor_bridge_n8n_push_token) }}
      {# GitOps deployer: liveness (deployer ticking) + deploy-status (rollback hold), pushed by
         check_gitops_alive/status from the host state files. interval 600s = 2× the 5-min loop. -#}
      {{ kuma('gitops-deploy-alive', monitor_type='push', name='GitOps Deploy — Alive', interval=600, push_token=monitor_bridge_gitops_alive_push_token) }}
      {{ kuma('gitops-deploy-status', monitor_type='push', name='GitOps Deploy — Status', interval=600, push_token=monitor_bridge_gitops_status_push_token) }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('0.10', '64M', '0.02', '16M') }}

{{ external_networks() }}
