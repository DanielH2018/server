{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'healthcheck.yml.j2' import healthcheck %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
---

services:
  monitor-bridge:
    image: python:3.14-alpine
    container_name: monitor-bridge
    user: "{{ puid }}:{{ pgid }}"
    restart: unless-stopped
    # Pure stdlib Python over HTTP — no caps, no writable rootfs needed.
    read_only: true
    tmpfs:
      - /tmp
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    command: ["python", "/app/check.py"]
    # check.py touches /tmp/heartbeat (tmpfs) after every completed cycle; stale mtime
    # means the loop HUNG (death already exits the container) -> unhealthy -> autoheal
    # restart. 1000s ≈ 3×INTERVAL + slack. Kuma push silence remains the alerting path.
    {{ healthcheck("[\"CMD\", \"python3\", \"-c\", \"import os,sys,time; sys.exit(0 if time.time()-os.stat('/tmp/heartbeat').st_mtime<1000 else 1)\"]") }}
    environment:
      - TZ={{ tz }}
      - PYTHONUNBUFFERED=1
      - PYTHONDONTWRITEBYTECODE=1
      - INTERVAL=300
      # Startup/redeploy grace for the reach-out checks (STARTUP_GRACE in check.py: Backup
      # Freshness / n8n Prod Workflows / Arr Queue Warnings / Pi Pressure). They poll a live app
      # dependency with no reachability gate and no hysteresis, so the bridge's first cycle after
      # the weekly host reboot — when kopia/n8n/sonarr/radarr/the Pi glances are still starting —
      # flipped each max_retries=0 monitor DOWN for one transient cycle and paged. run_once now
      # holds them `up` for the first GRACE_CYCLES-1 consecutive down cycles; only the
      # GRACE_CYCLES'th straight down pages a genuinely-dead dependency (like HA_CONSECUTIVE=2).
      - GRACE_CYCLES=2
      - PROMETHEUS_URL=http://prometheus:9090
      - KOPIA_URL=http://kopia:51515
      - KUMA_URL=http://uptime-kuma:3001
      - BACKUP_SOURCE_PATH=/data/home/{{ sys_user }}/server/containers
      - BACKUP_MAX_AGE_H=30
      # Snapshot-shrink guard folded into Backup Freshness: a fresh, 0-error snapshot still hides a
      # service that silently left backup scope (kopiaignore over-match / vanished bind mount). Floor
      # the latest snapshot's total files+bytes at N% below the trailing-median (from Kopia's own
      # snapshot history); the median absorbs the routine one-off drops from exclusion tuning.
      # TEMP 2026-07-13 → revert ~2026-07-20: bumped 20→55 to absorb an INTENTIONAL ~40% re-baseline
      # (karakeep precrawled purge −360M + code-server VSIX exclude −74M + retention 4w/3m→0 dropping
      # the fat weekly/monthly snapshots). The trailing median holds the pre-shrink ~1.1GB for ~4 days,
      # so a 20% floor would false-page Backup Freshness until post-shrink dailies dominate it. Revert
      # to 20 once `kopia snapshot list` shows the retained set is all post-shrink (~0.7GB). See memory.
      - BACKUP_SIZE_DROP_PCT=55
      - BACKUP_SIZE_MIN_HISTORY=3
      # /boot: old kernels filling it quietly breaks upgrades; /boot/efi (vfat ESP):
      # same failure class for firmware/bootloader updates (node-exporter exposes both)
      - DISK_MOUNTPOINTS=/,/boot,/boot/efi
      - DISK_MAX_PCT=90
      - CERT_MIN_DAYS=14
      - MEM_MAX_PCT=90
      - OOM_WINDOW=1h
      - CPU_WINDOW=15m
      - CPU_THROTTLE_PCT=25
      - CPU_MIN_THROTTLED_CORES=0.05
      # Hysteresis: only the 3rd consecutive breaching cycle (~15 min) alerts; one- or
      # two-cycle bursts log the offender but push up. A clean cycle resets the streak.
      - CPU_CONSECUTIVE=3
      - RESTART_WINDOW=15m
      - RESTART_MAX=3
      - TRAEFIK_5XX_PCT=5
      - TRAEFIK_MIN_RPS=0.05
      # Push tokens: we set them; Kuma honors client-supplied tokens. In secrets.yml.
      - KUMA_PUSH_KOPIA={{ monitor_bridge_kopia_push_token }}
      - KUMA_PUSH_DISK={{ monitor_bridge_disk_push_token }}
      - KUMA_PUSH_CERT={{ monitor_bridge_cert_push_token }}
      - KUMA_PUSH_MEM={{ monitor_bridge_mem_push_token }}
      - KUMA_PUSH_RESTARTS={{ monitor_bridge_restarts_push_token }}
      - KUMA_PUSH_OOM={{ monitor_bridge_oom_push_token }}
      - KUMA_PUSH_CPU={{ monitor_bridge_cpu_push_token }}
      - KUMA_PUSH_TARGETS={{ monitor_bridge_targets_push_token }}
      - KUMA_PUSH_TRAEFIK={{ monitor_bridge_traefik_push_token }}
      # Prometheus reachability gate: probed once per cycle BEFORE the prom-dependent metric
      # checks. When Prometheus is unreachable they're suppressed (pushed `up` w/ a skip msg,
      # heartbeat kept alive) and only THIS monitor pages — one outage is one alert, not a storm.
      - KUMA_PUSH_PROMETHEUS={{ monitor_bridge_prometheus_push_token }}
      # n8n Prod-workflow failure monitoring (active workflows via the n8n public API).
      - N8N_URL=http://n8n:5678
      - N8N_API_KEY={{ n8n_api_key }}
      - N8N_FAIL_WINDOW=15m
      - N8N_FAIL_MAX=0
      - KUMA_PUSH_N8N={{ monitor_bridge_n8n_push_token }}
      # Sonarr/Radarr queue warnings (2026-07-01 incident: an indexer served a poisoned
      # fake-episode .exe; sonarr blocked the import itself and flagged the queue item
      # trackedDownloadStatus "warning", but nothing paged, so it sat seeding for a day
      # before a manual review caught it). Empty key = that app skipped; both empty =
      # disabled, like N8N_API_KEY.
      - SONARR_URL=http://sonarr:8989
      - SONARR_API_KEY={{ sonarr_api_key }}
      - RADARR_URL=http://radarr:7878
      - RADARR_API_KEY={{ radarr_api_key }}
      - KUMA_PUSH_ARR_QUEUE={{ monitor_bridge_arr_queue_push_token }}
      # Prowlarr sustained-indexer watchdog: Prowlarr's in-app health notification is binary
      # (every flap pages, or — with warnings off — only the all-indexers-down red error). This
      # polls /api/v1/indexerstatus and `down`s only when an indexer has been failing >= 1 week
      # (age from Prowlarr's own initialFailure, so it survives a bridge redeploy), suppressing the
      # sub-threshold flaps public trackers throw that self-clear inside Prowlarr's ~5-15min backoff.
      # Set to a full week (10080 min) deliberately: only a genuinely long outage should page here —
      # short/flaky drops are noise. Prowlarr's own all-indexers-down onHealthIssue is the fast backstop.
      # Empty key = disabled (stays up), like N8N_API_KEY. Already on `media`, reaches prowlarr:9696.
      - PROWLARR_URL=http://prowlarr:9696
      - PROWLARR_API_KEY={{ prowlarr_api_key }}
      - PROWLARR_INDEXER_MIN_DOWN_MIN=10080
      # Comma-separated indexer names never paged (case-insensitive) — chronically-flaky public
      # trackers whose backend routinely 503s/times-out past the sustained-down gate while the other indexers
      # cover the same searches. The Pirate Bay's apibay.org (503s + full timeouts) flapped this
      # monitor up/down for hours on 2026-07-05. Prowlarr's own all-down onHealthIssue is the backstop.
      - PROWLARR_INDEXER_IGNORE=The Pirate Bay
      - KUMA_PUSH_PROWLARR_INDEXERS={{ monitor_bridge_prowlarr_indexers_push_token }}
      # GitOps deployer liveness + deploy-status. State files are written on the host by
      # gitops_deploy.py and bind-mounted read-only at /gitops-state.
      - GITOPS_STATE_DIR=/gitops-state
      - GITOPS_MAX_AGE_MIN=90
      - KUMA_PUSH_GITOPS_ALIVE={{ monitor_bridge_gitops_alive_push_token }}
      - KUMA_PUSH_GITOPS_STATUS={{ monitor_bridge_gitops_status_push_token }}
      # Monthly kopia restore drill: the host cron (kopia role) writes state.json;
      # we alert on failure, >35d staleness, or a missing/corrupt file.
      - RESTORE_DRILL_STATE=/restore-drill/state.json
      - RESTORE_DRILL_MAX_AGE_D=35
      - KUMA_PUSH_RESTORE_DRILL={{ kopia_restore_drill_push_token }}
      # Daily wg-easy Pi-peer backup pull: the wg-easy role's daniel-server host cron writes
      # state.json after rsyncing the Pi's un-rebuildable WireGuard peer keys into Kopia scope. The
      # pull uses no --delete, so a broken pull keeps Backup Freshness green while the peers go stale
      # — this is the watchdog. Alert on a failed pull, >2.5d staleness, or a missing/corrupt file.
      - PI_PEERS_STATE=/pi-peers/state.json
      - PI_PEERS_MAX_AGE_D=2.5
      - KUMA_PUSH_PI_PEERS={{ monitor_bridge_pi_peers_push_token }}
      # Every-5-min CrowdSec home-IP allowlist updater (traefik role) writes state.json on EVERY run
      # incl. the IP-unchanged fast path; it was the last self-loggering cron with no watchdog — a
      # silent failure just meant occasional 403s on the next home-IP rotation. Alert on a failed run
      # or 30-min staleness (6 missed 5-min runs).
      - HOME_ALLOWLIST_STATE=/home-allowlist/state.json
      - HOME_ALLOWLIST_MAX_AGE_MIN=30
      - KUMA_PUSH_HOME_ALLOWLIST={{ monitor_bridge_home_allowlist_push_token }}
      # DOCKER-USER origin-lock watchdog: the traefik role's docker-user-verify.sh cron (every 15 min,
      # as root) re-reads the LIVE iptables DOCKER-USER chain and asserts the terminal DROP for :80/:443
      # + a RETURN allow are present, writing state.json. The seed/re-assert units apply the rules but
      # write no state — this is the only signal the origin lock is ACTUALLY applied (a post-boot flush
      # would leave 80/443 reachable direct, Cloudflare/CrowdSec bypass, invisibly). Alert on a failed
      # live assert or 45-min staleness (3 missed 15-min runs).
      - DOCKER_USER_STATE=/docker-user/state.json
      - DOCKER_USER_MAX_AGE_MIN=45
      - KUMA_PUSH_DOCKER_USER={{ monitor_bridge_docker_user_push_token }}
      # Weekly kopia snapshot verify: the host cron (kopia role) writes state.json; we
      # alert on a FAILED verify (bit-rot / unreadable blob the old `| logger` cron
      # swallowed), >10d staleness, or a missing/corrupt file. The verify tier of the
      # three-tier backup assurance — previously the only un-monitored one.
      - VERIFY_STATE=/verify/state.json
      - VERIFY_MAX_AGE_D=10
      - KUMA_PUSH_VERIFY={{ monitor_bridge_verify_push_token }}
      # Quarterly kopia DEEP content verify: the kopia role's content-verify.sh cron (1st of Mar/Jun/
      # Sep/Dec) runs `kopia snapshot verify --verify-files-percent=25` and writes state.json — the
      # deep tier below the weekly 1% verify, catching a mis-purge / blob bug the 1% sample misses.
      # Alert on a FAILED deep verify or >100d staleness (~92d max inter-quarter gap + margin; a missed
      # quarter pages). Seeded on first deploy so it's green until the first quarterly run.
      - CONTENT_VERIFY_STATE=/content-verify/state.json
      - CONTENT_VERIFY_MAX_AGE_D=100
      - KUMA_PUSH_CONTENT_VERIFY={{ monitor_bridge_content_verify_push_token }}
      # Hourly disk-autoprune host cron (autofix-bridge role): conservative docker/builder/
      # container prune when `/` used% crosses a threshold. Alert on a FAILED prune command
      # or >3h staleness (cron broken / never ran) — a disk still full of real data after a
      # clean prune is Root Disk's alert, not this one.
      - DISK_PRUNE_STATE=/autofix-disk/state.json
      - DISK_PRUNE_MAX_AGE_H=3
      - KUMA_PUSH_DISK_PRUNE={{ monitor_bridge_disk_prune_push_token }}
      # Daily kopia FULL-maintenance freshness: the host cron (kopia role) queries `kopia
      # maintenance info --json` and writes state.json. Full maintenance GCs expired blobs from
      # B2, so a stall is the upstream CAUSE the b2_usage check only catches weeks later as the
      # symptom. Alert on a stalled/disabled/failed cycle, >2.5d staleness, or a missing file.
      - MAINTENANCE_STATE=/maintenance/state.json
      - MAINTENANCE_MAX_AGE_D=2.5
      - KUMA_PUSH_MAINTENANCE={{ monitor_bridge_maintenance_push_token }}
      # B2 free tier is 10GB; alert at 85% so there's runway to prune/upgrade
      # before the bucket fills and nightly snapshots start failing.
      - B2_USAGE_STATE=/b2-usage/state.json
      - B2_USAGE_MAX_AGE_D=2.5
      - B2_CAP_GB=10
      - B2_USAGE_MAX_PCT=85
      - KUMA_PUSH_B2={{ monitor_bridge_b2_push_token }}
      # B2 growth TREND: predict_linear over the kopia_b2_billable_bytes gauge (exported by the
      # same b2-usage cron via node-exporter textfile) — `down` when on track to hit the cap
      # within B2_TREND_HORIZON_D days, the runway warning the absolute-85% B2 monitor can't give.
      # Prom-dependent (suppressed under the Prometheus gate); a missing gauge reads as down.
      - B2_TREND_WINDOW=7d
      - B2_TREND_HORIZON_D=7
      - KUMA_PUSH_B2_TREND={{ monitor_bridge_b2_trend_push_token }}
      # Scrutiny SMART freshness: the collector (cron-as-PID1, daily 00:00, no usable
      # healthcheck) only shows death as aging collector_date in the web API.
      - SCRUTINY_URL=http://scrutiny:8080
      - SCRUTINY_MAX_AGE_H=26
      - KUMA_PUSH_SCRUTINY={{ monitor_bridge_scrutiny_push_token }}
      # Pi pressure: swap-thrash early warning for the 512MB Zero 2 W, polled from the
      # glances API already running there (zero Pi-side footprint; the static Kuma HTTP
      # monitor covers glances itself). 2026-06-11 fwupd incident: load5/core >1.7 with
      # mem available bottoming at 13MB — invisible to every other monitor.
      - PI_GLANCES_URL=http://{{ hostvars['daniel-pi'].server_ip }}:61208
      - PI_LOAD_MAX=1.5
      - PI_MEM_MIN_MB=50
      # SD card usage via glances /api/4/fs (deduped by device) — the server-only
      # Root Disk check can't see the Pi, and a filling SD card is the classic slow death.
      - PI_DISK_MAX_PCT=90
      - KUMA_PUSH_PI={{ monitor_bridge_pi_push_token }}
      # HA automation-engine heartbeat: poll input_datetime.ha_heartbeat (stamped every minute by an
      # HA time_pattern automation) over the `apps` net with a long-lived token; `down` when it's
      # stale -> a wedged-but-running HA (HTTP :8123 up, scheduler stuck) the container healthcheck
      # can't see. Empty HA_URL/HA_TOKEN = disabled (stays up). 300s = 5 missed 1-min beats.
      # HA_CONSECUTIVE=2: hysteresis (like CPU_CONSECUTIVE) so a planned redeploy — API
      # unreachable ~120s, then the scheduler a beat behind — doesn't false-page; only 2 straight
      # down cycles (~one INTERVAL of continuous badness) go `down`. A real wedge still pages.
      - HA_URL=http://home-assistant:8123
      - HA_TOKEN={{ monitor_bridge_ha_token }}
      - HA_HEARTBEAT_MAX_AGE=300
      - HA_CONSECUTIVE=2
      - KUMA_PUSH_HA={{ monitor_bridge_ha_push_token }}
      # Renovate manual-action notifier liveness: renovate_notify.py writes last_run on the
      # host (daily timer); bind-mounted read-only at /renovate-state. 36h = one missed run + slack.
      - RENOVATE_STATE_DIR=/renovate-state
      - RENOVATE_MAX_AGE_MIN=2160
      - KUMA_PUSH_RENOVATE_ALIVE={{ monitor_bridge_renovate_alive_push_token }}
      # Loki log-ingestion freshness: Loki's /ready Kuma probe stays green even when promtail
      # stops shipping (docker-proxy break, positions corruption). Two arms (see check.py):
      # arm 1 counts the file-tail union (authlog+syslog+traefik, EXCLUDING the high-volume
      # docker_sd `job:docker` stream) over a tolerant window (LOKI_FILETAIL_WINDOW) and `down`s at
      # zero — a file-tail break silences all three at once, while syslog's routine volume keeps a
      # quiet night alive; arm 2 counts {container=~".+"} (the docker stream) over LOKI_WINDOW.
      # Reached at loki:3100 over `monitoring`.
      - LOKI_URL=http://loki:3100
      - LOKI_STREAM={job=~"authlog|syslog|traefik"}
      - LOKI_WINDOW=30m
      - LOKI_FILETAIL_WINDOW=3h
      - KUMA_PUSH_LOKI={{ monitor_bridge_loki_push_token }}
      # Loki reachability GATE (peer of the Prometheus gate): probed once per cycle before the
      # Loki-querying checks (Loki Ingestion, Recyclarr, Janitorr). When Loki is unreachable they're
      # suppressed (pushed `up` w/ a skip msg) and only THIS monitor pages — one outage, one alert.
      - KUMA_PUSH_LOKI_REACHABLE={{ monitor_bridge_loki_reachable_push_token }}
      # Promtail dropped-entries watchdog: Prometheus already scrapes promtail:9080, exposing the
      # promtail_dropped_entries_total{reason=...} counter. Loki Log Ingestion only catches TOTAL
      # silence; this surfaces PARTIAL loss — entries promtail gave up shipping when Loki rejected them
      # (reason="ingester_error"). increase() over the window handles counter resets; alert only above
      # PROMTAIL_DROPPED_MAX so a transient Loki restart doesn't page. Prom-dependent.
      - PROMTAIL_DROPPED_WINDOW=1h
      - PROMTAIL_DROPPED_MAX=1000
      - KUMA_PUSH_PROMTAIL_DROPPED={{ monitor_bridge_promtail_dropped_push_token }}
      # Discord delivery: GET-verify Kuma's own notification webhook is still valid — a
      # rotated/revoked/deleted webhook makes Kuma's alert POSTs silently fail while every
      # monitor stays green-in-UI (the alert chain's delivery hop no other monitor, not even
      # the off-box UptimeRobot host dead-man, exercises). Same webhook the kuma() notification
      # posts to. A GET (not POST) never spams the channel; DISCORD_CONSECUTIVE adds streak
      # hysteresis so a transient blip on this internet-facing check doesn't false-page.
      - DISCORD_WEBHOOK_URL={{ monitor_discord_webhook_url }}
      # Also GET-verify the CrowdSec ban-alert webhook — CrowdSec POSTs to it directly (not via
      # Kuma), so a rotated/revoked URL silently drops security-ban alerts with no Kuma backstop.
      - DISCORD_CROWDSEC_WEBHOOK_URL={{ crowdsec_discord_webhook_url }}
      # And the GitOps/Renovate webhook — it delivers the gitops-deploy rollback alert AND every
      # renovate_notify digest, neither via Kuma. renovate_notify greens its liveness marker even
      # when the POST fails, so a dead webhook here drops digests while its monitor stays green.
      - DISCORD_GITOPS_WEBHOOK_URL={{ gitops_deploy_discord_webhook }}
      # And the *arr health/event webhook — Sonarr/Radarr/Prowlarr POST their onHealthIssue alerts
      # (indexer down, download-client errors) directly to it via in-app Discord Connect (config
      # lives in the app DBs, not here); a rotated/revoked URL drops those with no Kuma backstop.
      - DISCORD_ARR_WEBHOOK_URL={{ arr_discord_webhook_url }}
      # And the healthchecks.io app's own Discord webhook — it POSTs its check-down/up alerts to it
      # via a "webhook" channel (config only in hc.sqlite, not templated), NOT via Kuma. A rotated/
      # revoked URL silently drops those; it's a redundant secondary to its SMTP path, still worth GET-verifying.
      - DISCORD_HEALTHCHECKS_WEBHOOK_URL={{ healthchecks_discord_webhook_url }}
      - DISCORD_CONSECUTIVE=2
      - KUMA_PUSH_DISCORD={{ monitor_bridge_discord_push_token }}
      # Alert-email backstop deliverability, folded into the Discord Delivery check: the uptime-kuma
      # `email` notification (Gmail SMTP) is the independent 2nd channel attached only to Discord
      # Delivery, so a silently-revoked app-password would leave that backstop dead undetected. A
      # throttled SMTP login probe (same creds Kuma uses) flips this monitor down on a broken
      # credential, which still pages via the working Discord channel. Reuses the acme `email` var.
      - SMTP_USER={{ email }}
      - SMTP_PASSWORD={{ smtp_notify_app_password }}
      # Recyclarr sync health via Loki: recyclarr runs `recyclarr sync` under supercronic (@daily);
      # the container healthcheck only proves the scheduler is alive, so an ERRORING sync (the silent
      # 2026-06-10 v8-major breakage) shows up nowhere but the logs. /cron.sh ends with the sync so
      # its exit code propagates -> supercronic logs `job succeeded`/`job failed`; we count both over
      # 26h (one @daily run + slack) and `down` on any failure or no successful run. Reached via loki:3100.
      - RECYCLARR_LOKI_SELECTOR={container="recyclarr"}
      - RECYCLARR_WINDOW=26h
      - KUMA_PUSH_RECYCLARR={{ monitor_bridge_recyclarr_push_token }}
      # Janitorr scheduled-cleanup error watchdog: janitorr's healthcheck only proves the JVM is
      # alive, so an internal cleanup error (failed delete, bad config, a bug) logs ERROR and is
      # otherwise invisible — and janitorr DELETES REAL MEDIA. Gated on Prometheus container uptime
      # to skip the documented post-boot FeignException race (an @Scheduled cleanup firing before
      # jellyfin/sonarr/radarr are ready); counts errors only over the post-startup slice of the
      # window. Prom-dependent (uptime) AND Loki-dependent (count) — suppressed under either gate.
      - JANITORR_LOKI_SELECTOR={container="janitorr"}
      - JANITORR_WINDOW=12h
      - JANITORR_STARTUP_GRACE_S=600
      - KUMA_PUSH_JANITORR={{ monitor_bridge_janitorr_push_token }}
    volumes:
      - ./check.py:/app/check.py:ro
      - /var/lib/gitops-deploy:/gitops-state:ro
      - /var/lib/renovate-notify:/renovate-state:ro
      - /var/lib/kopia-restore-drill:/restore-drill:ro
      - /var/lib/wg-easy-pi-peers:/pi-peers:ro
      - /var/lib/crowdsec-home-allowlist:/home-allowlist:ro
      - /var/lib/kopia-verify:/verify:ro
      - /var/lib/autofix-disk-prune:/autofix-disk:ro
      - /var/lib/kopia-maintenance:/maintenance:ro
      - /var/lib/kopia-b2-usage:/b2-usage:ro
      - /var/lib/docker-user-rules:/docker-user:ro
      - /var/lib/kopia-content-verify:/content-verify:ro
    {{ service_networks() }}
    labels:
      {# Container-liveness monitor + one push monitor per check (AutoKuma-provisioned).
         max_retries=0 on every push monitor: with retries, Kuma parks a pushed `down`
         (and its named-offender msg) in PENDING, then its 60s watchdog — which only an
         `up` push satisfies — crosses maxretries first, so the visible DOWN event always
         reads "No heartbeat in the time window". With 0 retries the bridge's own push
         flips the state and the descriptive msg survives into the event + notification.
         Trade-off: a dead bridge pages after one missed 600s window (no grace beats). -#}
      {{ kuma('monitor-bridge') }}
      {{ kuma('monitor-bridge-backup', monitor_type='push', name='Backup Freshness', interval=600, max_retries=0, push_token=monitor_bridge_kopia_push_token) }}
      {{ kuma('monitor-bridge-disk', monitor_type='push', name='Root Disk', interval=600, max_retries=0, push_token=monitor_bridge_disk_push_token) }}
      {{ kuma('monitor-bridge-cert', monitor_type='push', name='TLS Cert Expiry', interval=600, max_retries=0, push_token=monitor_bridge_cert_push_token) }}
      {{ kuma('monitor-bridge-mem', monitor_type='push', name='Memory', interval=600, max_retries=0, push_token=monitor_bridge_mem_push_token) }}
      {{ kuma('monitor-bridge-restarts', monitor_type='push', name='Container Restarts', interval=600, max_retries=0, push_token=monitor_bridge_restarts_push_token) }}
      {{ kuma('monitor-bridge-oom', monitor_type='push', name='Container OOM', interval=600, max_retries=0, push_token=monitor_bridge_oom_push_token) }}
      {{ kuma('monitor-bridge-cpu', monitor_type='push', name='CPU Throttling', interval=600, max_retries=0, push_token=monitor_bridge_cpu_push_token) }}
      {# Prometheus reachability — the root-cause monitor that gates the prom-dependent checks:
         when it's down they're suppressed and only this one pages (no 9-monitor storm). -#}
      {{ kuma('monitor-bridge-prometheus', monitor_type='push', name='Prometheus Reachable', interval=600, max_retries=0, push_token=monitor_bridge_prometheus_push_token) }}
      {{ kuma('monitor-bridge-targets', monitor_type='push', name='Scrape Targets', interval=600, max_retries=0, push_token=monitor_bridge_targets_push_token) }}
      {{ kuma('monitor-bridge-traefik', monitor_type='push', name='Traefik 5xx', interval=600, max_retries=0, push_token=monitor_bridge_traefik_push_token) }}
      {{ kuma('monitor-bridge-n8n', monitor_type='push', name='n8n Prod Workflows', interval=600, max_retries=0, push_token=monitor_bridge_n8n_push_token) }}
      {# Arr Queue Warnings: check_arr_queue polls sonarr+radarr's own /queue for a
         trackedDownloadStatus "warning" or blocked import (2026-07-01 poisoned-.exe
         incident) and names the offending release + app. -#}
      {{ kuma('monitor-bridge-arr-queue', monitor_type='push', name='Arr Queue Warnings', interval=600, max_retries=0, push_token=monitor_bridge_arr_queue_push_token) }}
