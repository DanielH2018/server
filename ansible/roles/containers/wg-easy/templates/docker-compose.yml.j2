{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
{% from 'expose.yml.j2' import web_ui_labels with context %}
---

services:
  wg-easy:
    # Pinned to the v14 tag + digest (the bcrypt PASSWORD_HASH auth model). The `:14` keeps Renovate
    # tracking the major so it can OFFER a v15 bump as a deliberate PR; the digest keeps it immutable
    # within v14.x. MUST NOT float to :latest → v15, which drops PASSWORD_HASH for an interactive
    # setup wizard and would silently reopen the server's monitoring-net-exposed admin API.
    image: ghcr.io/wg-easy/wg-easy:14@sha256:5f26407fd2ede54df76d63304ef184576a6c1bb73f934a58a11abdd852fab549
    container_name: wg-easy
    # NET_ADMIN to create the wg interface + apply rules; NET_RAW because wg-quick runs
    # iptables (the iptables CLI opens a raw socket to init the 'nat' table — fails with
    # "can't initialize iptables table `nat`: Permission denied" without it). SYS_MODULE
    # not needed (wireguard module loaded on host). Verify on deploy (docker logs wg-easy).
    cap_drop:
      - ALL
    cap_add:
      - NET_ADMIN
      - NET_RAW
    security_opt:
      - no-new-privileges:true
    sysctls:
      - net.ipv4.ip_forward=1
      - net.ipv4.conf.all.src_valid_mark=1
    ports:
      - "{{ container_item.udp_port }}:{{ container_item.udp_port }}/udp"
{% if (container_item.expose_mode | default(expose_mode | default('traefik'))) == 'lan' %}
      # LAN-only hosts (daniel-pi): bind the admin UI to the host's LAN IP, not 0.0.0.0,
      # so it isn't reachable on the WireGuard tunnel or other interfaces.
      - "{{ server_ip }}:{{ container_item.port }}:51821/tcp"
{% endif %}
    environment:
      - LANG=en
      - WG_HOST=wireguard.{{ domain }}
      - WG_PORT={{ container_item.udp_port }}
      - WG_PERSISTENT_KEEPALIVE=25
{% if container_item.password_hash is defined %}
      # Admin UI/API auth (wg-easy v14 → bcrypt PASSWORD_HASH). The `$` in a bcrypt hash MUST be
      # doubled or Compose interpolates it at parse time and mangles the hash (the validate-compose
      # hook only guards command/entrypoint/healthcheck, not environment). Set on the server (its
      # admin API is reachable to every monitoring-net neighbor); the Pi omits it (accepted LAN-only
      # risk — see this role's CLAUDE.md). Authelia only gates the Traefik ingress, not this in-net API.
      - PASSWORD_HASH={{ container_item.password_hash | replace('$', '$$') }}
{% endif %}
{% if container_item.default_dns is defined %}
      # DNS baked into generated client configs so *.local.{{ domain }} resolves via Pi-hole
      # over the tunnel (private homelab path, bypasses Cloudflare/CrowdSec). Only set where
      # defined per host; desktop split-tunnel clients override AllowedIPs/DNS locally.
      - WG_DEFAULT_DNS={{ container_item.default_dns }}
{% endif %}
    volumes:
      - ./config:/etc/wireguard
    restart: unless-stopped
    {{ service_networks() }}
    labels:
      # Disable watchtower update — pinned/Renovate tier (v14 tag+digest, MUST NOT float).
      # The digest already blocks a float, but this keeps wg-easy out of the auto-update pool
      # (and out of WATCHTOWER_AUTOUPDATE) so a future digest-drop can't silently re-enrol it.
      - "com.centurylinklabs.watchtower.enable=false"
{{ web_ui_labels('51821') }}
      {{ kuma(container_item.name) }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('0.50', '256M', '0.05', '32M') }}

{{ external_networks() }}
