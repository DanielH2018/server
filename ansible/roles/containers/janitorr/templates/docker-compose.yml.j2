{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
{% from 'healthcheck.yml.j2' import healthcheck %}
---

services:
  janitorr:
    # Digest-pinned + watchtower-disabled (label below): janitorr DELETES media for real
    # (dry-run off), so it must not change unsupervised — and `jvm-stable` is a floating
    # non-semver alias Renovate can't version-track, so a bare tag here would never update
    # at all (the untracked-escape-hatch trap; this digest = the jvm-stable build pulled
    # 2026-06-28). Manual update: `docker pull ghcr.io/schaka/janitorr:jvm-stable`, take
    # the new digest, redeploy.
    image: ghcr.io/schaka/janitorr@sha256:6becfbed9098d27e6bf81a114976394a091d095ee5aba3ae8d86a4fd94af8e7a
    user: {{ puid }}:{{ pgid }}
    container_name: janitorr
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    environment:
      - TZ={{ tz }}
    volumes:
      - ./config/application.yml:/config/application.yml
      - /home/{{ sys_user }}/server/containers/data:/data
    restart: unless-stopped
    {{ healthcheck('["CMD", "bash", "-c", "cat /proc/1/comm | grep -q java"]', start_period='60s') }}
    {{ service_networks() }}
    labels:
      # Watchtower — digest-pinned + manually updated; opt out of auto-update (deletes real media)
      - "com.centurylinklabs.watchtower.enable=false"
      {{ kuma(container_item.name) }}
    # Resource caps for blast-radius containment (M1). JVM app, so size memory
    # generously and tune from cAdvisor/Grafana.
    {{ resources('1.0', '1024M', '0.10', '128M') }}

{{ external_networks() }}
