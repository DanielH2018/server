{% from 'traefik.yml.j2' import labels with context %}
{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
{% from 'healthcheck.yml.j2' import healthcheck %}
---

services:
  janitorr:
    image: ghcr.io/schaka/janitorr:jvm-stable
    user: {{ puid }}:{{ pgid }}
    container_name: janitorr
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    environment:
      - TZ={{ tz }}
    volumes:
      - ./config/application.yml:/config/application.yml
      - /home/{{ sys_user }}/server/containers/data:/data
    restart: unless-stopped
    {{ healthcheck('["CMD", "bash", "-c", "cat /proc/1/comm | grep -q java"]', start_period='60s') }}
    {{ service_networks() }}
    labels:
      # Manual/Renovate-managed: janitorr DELETES media for real (dry-run off), so the
      # :jvm-stable rolling tag must not be auto-bumped by watchtower (monitor-all mode)
      # — an unsupervised change to retention/expiration semantics is high-consequence.
      - "com.centurylinklabs.watchtower.enable=false"
      {{ kuma(container_item.name) }}
    # Resource caps for blast-radius containment (M1). JVM app, so size memory
    # generously and tune from cAdvisor/Grafana.
    {{ resources('1.0', '1024M', '0.10', '128M') }}

{{ external_networks() }}
