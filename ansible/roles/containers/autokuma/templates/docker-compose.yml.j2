{% from 'autokuma.yml.j2' import labels as kuma with context %}
---

services:
  autokuma:
    image: ghcr.io/bigboot/autokuma:latest
    container_name: autokuma
    restart: unless-stopped
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    healthcheck:
      test: ["CMD", "bash", "-c", "cat /proc/1/comm | grep -q autokuma"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s
    environment:
      - AUTOKUMA__KUMA__URL=http://uptime-kuma:3001
      - AUTOKUMA__KUMA__USERNAME={{ uptime_kuma_username }}
      - AUTOKUMA__KUMA__PASSWORD={{ uptime_kuma_password }}
      - AUTOKUMA__DOCKER__HOSTS=tcp://docker-proxy:2375
      - AUTOKUMA__DB_PATH=/data/autokuma.db
    volumes:
      - ./data:/data
    networks:
{% for net in container_item.networks | default([docker_network]) %}
      - {{ net }}
{% endfor %}
    labels:
      - "com.centurylinklabs.watchtower.depends-on=docker-proxy,uptime-kuma"
      {{ kuma(container_item.name) }}

networks:
{% for net in container_item.networks | default([docker_network]) %}
  {{ net }}:
    external: true
{% endfor %}
