{% from 'traefik.yml.j2' import labels with context %}
---

services:
  beszel:
    image: henrygd/beszel:latest
    container_name: beszel
    #extra_hosts:
    #  - host.docker.internal:host-gateway
    restart: unless-stopped
    networks:
      - {{ docker_network }}
    volumes:
      - ./beszel_data:/beszel_data
      - ./beszel_socket:/beszel_socket
    environment:
      - USER_CREATION=true
      - DISABLE_PASSWORD_AUTH=true
    labels:
      {# Generate labels(container, port, docker_network, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          docker_network,
          container_item.use_authelia
        )
      }}

  beszel-agent:
    image: henrygd/beszel-agent:latest
    container_name: beszel-agent
    restart: unless-stopped
    network_mode: host
    volumes:
      - ./beszel_agent_data:/var/lib/beszel-agent
      - ./beszel_socket:/beszel_socket
    environment:
      DOCKER_HOST: "tcp://docker-proxy:2375"
      LISTEN: /beszel_socket/beszel.sock
      KEY: "{{ beszel_agent_key }}"
    labels:
      # Watchtower
      - "com.centurylinklabs.watchtower.depends-on:docker-proxy"

networks:
  {{ docker_network }}:
    external: true

volumes:
  beszel_agent_data:
