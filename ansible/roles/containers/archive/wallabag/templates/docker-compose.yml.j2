{% from 'traefik.yml.j2' import labels with context %}
{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'healthcheck.yml.j2' import healthcheck %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
---
services:
  wallabag:
    container_name: wallabag
    image: wallabag/wallabag:latest
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    {{ service_networks() }}
    environment:
      - MYSQL_ROOT_PASSWORD={{ wallabag_mysql_root_password }}
      - SYMFONY__ENV__DATABASE_DRIVER=pdo_mysql
      - SYMFONY__ENV__DATABASE_HOST=db
      - SYMFONY__ENV__DATABASE_PORT=3306
      - SYMFONY__ENV__DATABASE_NAME={{ wallabag_db_name }}
      - SYMFONY__ENV__DATABASE_USER={{ wallabag_db_user }}
      - SYMFONY__ENV__DATABASE_PASSWORD={{ wallabag_db_password }}
      - SYMFONY__ENV__DATABASE_CHARSET=utf8mb4
      - SYMFONY__ENV__DATABASE_TABLE_PREFIX="wallabag_"
      - SYMFONY__ENV__MAILER_DSN=smtp://127.0.0.1
      - SYMFONY__ENV__FROM_EMAIL=wallabag@example.com
      - SYMFONY__ENV__DOMAIN_NAME=https://{{ container_item.hostname | default(container_item.name) }}.{{ domain }}
      - SYMFONY__ENV__SERVER_NAME="Your wallabag instance"
    volumes:
      - wallabag-images:/var/www/wallabag/web/assets/images
      - wallabag_data:/var/www/wallabag/data
    depends_on:
      - db
      - redis
    {{ healthcheck('curl --fail -s http://localhost:80/ || exit 1') }}
    labels:
      {# Generate labels(container, port, docker_network, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          (container_item.networks | default([docker_network]))[0],
          container_item.use_authelia
        )
      }}
      {{ kuma(container_item.name) }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('1.0', '768M', '0.10', '128M') }}

  db:
    image: mariadb:latest
    container_name: wallabag-db
    restart: unless-stopped
    networks:
      - {{ docker_network }}
    environment:
      - MYSQL_ROOT_PASSWORD={{ wallabag_mysql_root_password }}
    volumes:
      - wallabag-db:/var/lib/mysql
    {{ healthcheck('["CMD", "/usr/local/bin/healthcheck.sh", "--innodb_initialized"]', interval='20s', timeout='3s') }}
    labels:
      {{ kuma('wallabag-db', name='Wallabag DB') }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('1.0', '512M', '0.10', '128M') }}

  redis:
    image: redis:alpine
    container_name: wallabag-redis
    restart: unless-stopped
    volumes:
      - wallabag-redis:/data
    networks:
      - {{ docker_network }}
    {{ healthcheck('["CMD", "redis-cli", "ping"]', interval='20s', timeout='3s') }}
    labels:
      {{ kuma('wallabag-redis', name='Wallabag Redis') }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('0.50', '128M', '0.05', '16M') }}

{{ external_networks() }}

volumes:
  wallabag-images:
  wallabag_data:
  wallabag-db:
  wallabag-redis:
