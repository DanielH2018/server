{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'resources.yml.j2' import resources %}
---
services:
  valheim:
    image: ghcr.io/lloesche/valheim-server:latest
    container_name: valheim
    cap_add:
      - sys_nice
    volumes:
      - ./valheim/config:/config
      - ./valheim/data:/opt/valheim
    ports:
      - 2456-2458:2456-2458/udp
      - 9001:9001/tcp
    environment:
      SERVER_NAME: "DBoy's Server"
      WORLD_NAME: Dedicated
      SERVER_PASS: {{ valheim_server_pass }}
      SERVER_PUBLIC: "true"
    restart: unless-stopped
    stop_grace_period: 2m
    labels:
      {{ kuma(container_item.name) }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    # Valheim's dedicated server simulates the world in RAM — keep generous headroom.
    {{ resources('4.0', '6144M', '0.5', '2048M') }}
