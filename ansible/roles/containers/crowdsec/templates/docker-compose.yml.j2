{% from 'traefik.yml.j2' import labels with context %}
---
version: '3.8'
services:
  crowdsec:
    image: crowdsecurity/crowdsec:latest
    restart: unless-stopped
    container_name: crowdsec
    security_opt:
      - no-new-privileges:true
    environment:
      GID: "${GID-{{ pgid }}}"
      COLLECTIONS: "crowdsecurity/linux crowdsecurity/traefik crowdsecurity/http-cve crowdsecurity/whitelist-good-actors LePresidente/authelia"
    volumes:
      - ./config:/etc/crowdsec:rw
      - crowdsec-db:/var/lib/crowdsec/data/
      - /var/log/traefik:/var/log/traefik/:ro
      - /var/log/auth.log:/var/log/auth.log:ro
      - /var/log/authelia:/var/log/authelia/:ro
    networks:
      - {{ docker_network }}
    command: docker exec crowdsec cscli hub update && docker exec crowdsec cscli hub upgrade

  dashboard:
    #we're using a custom Dockerfile so that metabase pops with pre-configured dashboards
    build: .
    container_name: crowdsec-dashboard
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    environment:
      MB_DB_FILE: /data/metabase.db
      MGID: "${GID-{{ pgid}}}"
    depends_on:
      - crowdsec
    volumes:
      - crowdsec-db:/metabase-data/
    networks:
      - {{ docker_network }}
    healthcheck:
      test: curl --fail -s http://localhost:3000/ || exit 1
      interval: 30s
      timeout: 10s
      retries: 3
    labels:
      # Enable traefik for container
      - "traefik.enable=true"
      # Use traefik network
      - "traefik.docker.network={{ docker_network }}"

      {# Generate labels(container, port, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          container_item.use_authelia
        )
      }}

      # Disable watchtower update
      - "com.centurylinklabs.watchtower.enable=false"

networks:
  {{ docker_network }}:
    external: true
volumes:
  crowdsec-db:
