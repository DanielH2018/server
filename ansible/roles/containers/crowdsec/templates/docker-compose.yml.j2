{% from 'traefik.yml.j2' import labels with context %}
{% from 'autokuma.yml.j2' import labels as kuma with context %}
---
services:
  dashboard:
    #we're using a custom Dockerfile so that metabase pops with pre-configured dashboards
    build: .
    container_name: crowdsec-dashboard
    restart: unless-stopped
    # Metabase's run_metabase.sh runs as root, then `chown metabase:metabase`s its
    # H2 DB dir (line ~149) and `su`s down to the metabase user (uid 2000/gid 1000).
    # So it needs CHOWN (the chown is `2>/dev/null` — without CHOWN it silently fails,
    # the DB stays root-owned, and the su-dropped user can't rewrite it →
    # "AccessDeniedException ... metabase.db.mv.db") plus SETUID/SETGID (for the su).
    cap_drop:
      - ALL
    cap_add:
      - CHOWN
      - SETUID
      - SETGID
    security_opt:
      - no-new-privileges:true
    environment:
      MB_DB_FILE: /data/metabase.db
      MGID: "${GID-{{ pgid}}}"
    volumes:
      - crowdsec-db:/metabase-data/
    networks:
{% for net in container_item.networks | default([docker_network]) %}
      - {{ net }}
{% endfor %}
    healthcheck:
      test: curl --fail -s http://localhost:3000/ || exit 1
      interval: 30s
      timeout: 10s
      retries: 3
    labels:
      {# Generate labels(container, port, docker_network, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          (container_item.networks | default([docker_network]))[0],
          container_item.use_authelia
        )
      }}
      {{ kuma('crowdsec-dashboard') }}

      # Disable watchtower update
      - "com.centurylinklabs.watchtower.enable=false"

networks:
{% for net in container_item.networks | default([docker_network]) %}
  {{ net }}:
    external: true
{% endfor %}

volumes:
  crowdsec-db:
    external: true
    name: crowdsec-db
