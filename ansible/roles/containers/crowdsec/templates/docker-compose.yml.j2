{% from 'traefik.yml.j2' import labels with context %}
{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'healthcheck.yml.j2' import healthcheck %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
---
services:
  dashboard:
    #we're using a custom Dockerfile so that metabase pops with pre-configured dashboards
    build:
      context: .
      pull: true  # weekly redeploy cron rebuilds — without pull it reuses the cached base forever
    container_name: crowdsec-dashboard
    restart: unless-stopped
    # Metabase's run_metabase.sh runs as root, then `chown metabase:metabase`s its
    # H2 DB dir (line ~149) and `su`s down to the metabase user (uid 2000/gid 1000).
    # So it needs CHOWN (the chown is `2>/dev/null` — without CHOWN it silently fails,
    # the DB stays root-owned, and the su-dropped user can't rewrite it →
    # "AccessDeniedException ... metabase.db.mv.db") plus SETUID/SETGID (for the su).
    cap_drop:
      - ALL
    cap_add:
      - CHOWN
      - SETUID
      - SETGID
    security_opt:
      - no-new-privileges:true
    environment:
      MB_DB_FILE: /data/metabase.db
      MGID: "${GID-{{ pgid}}}"
      # Pin the JVM heap. Metabase otherwise sizes -Xmx to 25% of the cgroup limit,
      # which under the M1 memory cap is too small and OOMs ("OutOfMemoryError: Java
      # heap space") in a startup crash-loop. Keep the `deploy` memory limit below
      # >= this heap + ~1G non-heap overhead.
      JAVA_TOOL_OPTIONS: "-Xmx1g"
    volumes:
      - crowdsec-db:/metabase-data/
    {{ service_networks() }}
    {# Metabase is a slow-booting JVM app (H2 DB init) -> long start_period. -#}
    {{ healthcheck('curl --fail -s http://localhost:3000/ || exit 1', start_period='90s') }}
    labels:
      {# Generate labels(container, port, docker_network, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          (container_item.networks | default([docker_network]))[0],
          container_item.use_authelia
        )
      }}
      {{ kuma('crowdsec-dashboard') }}

      # Disable watchtower update
      - "com.centurylinklabs.watchtower.enable=false"
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    # Sized for the JVM: -Xmx1g heap (JAVA_TOOL_OPTIONS above) + non-heap overhead.
    # Don't lower memory without lowering -Xmx, or Metabase OOM-crash-loops on boot.
    {{ resources('1.0', '2048M', '0.10', '256M') }}

{{ external_networks() }}

volumes:
  crowdsec-db:
    external: true
    name: crowdsec-db
