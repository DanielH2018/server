{% from 'traefik.yml.j2' import labels with context %}
{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'healthcheck.yml.j2' import healthcheck %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
---

services:
  zigbee2mqtt:
    image: ghcr.io/koenkk/zigbee2mqtt:2.12.0
    container_name: zigbee2mqtt
    # Run as 1000:1000 so it owns its 0640 ./data/configuration.yaml: the image runs as
    # root, but cap_drop ALL strips DAC_OVERRIDE, so root can't bypass file perms (EACCES).
    user: "{{ puid }}:{{ pgid }}"
    environment:
      - TZ={{ tz }}
    volumes:
      - ./data:/app/data
    restart: unless-stopped
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    {{ service_networks() }}
    # Z2M takes a moment to connect to the coordinator before the frontend serves.
    # Use 127.0.0.1 not localhost: Z2M listens IPv4-only (0.0.0.0:8080), but busybox wget
    # resolves localhost to ::1 first and won't fall back to IPv4 → false "unhealthy".
    {{ healthcheck('wget -q -O /dev/null http://127.0.0.1:8080/ || exit 1', start_period='60s') }}
    labels:
      # Disable watchtower update — pinned + Renovate-managed
      - "com.centurylinklabs.watchtower.enable=false"
      {# Generate labels(container, port, docker_network, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          (container_item.networks | default([docker_network]))[0],
          container_item.use_authelia
        )
      }}
      {{ kuma(container_item.name) }}
      {# Static TCP monitor for the SLZB-06M coordinator itself ({{ slzb_ip }}:6638) — an infra-level
         page that fires even if HA/MQTT are down, catching an EHOSTUNREACH like the 2026-06-18 unplug
         (the z2m `docker` monitor above stays UP while Z2M crash-loops against an unreachable radio).
         Declared as a second AutoKuma monitor on this container's labels — AutoKuma keys monitors by
         id, not by container, so the target need not be a container. -#}
      {{ kuma('slzb-coordinator', port=6638, name='SLZB-06M Coordinator', hostname=slzb_ip, monitor_type='port') }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('0.50', '256M', '0.05', '64M') }}

{{ external_networks() }}
