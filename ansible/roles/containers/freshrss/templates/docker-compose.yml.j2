{% from 'traefik.yml.j2' import labels with context %}
{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'healthcheck.yml.j2' import healthcheck %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
---

services:
  freshrss:
    image: lscr.io/linuxserver/freshrss:latest
    container_name: freshrss
    environment:
      - PUID={{ puid }}
      - PGID={{ pgid }}
      - TZ={{ tz }}
    volumes:
      - ./config:/config
    restart: unless-stopped
    # LSIO image: cap_drop ALL plus the s6 privilege-drop set and NET_BIND_SERVICE for :80.
    # Verify on deploy (docker logs freshrss) — add back caps if it fails to start.
    cap_drop:
      - ALL
    cap_add:
      - CHOWN
      - SETUID
      - SETGID
      - FOWNER
      - DAC_OVERRIDE
      - NET_BIND_SERVICE
    security_opt:
      - no-new-privileges:true
    {{ service_networks() }}
      - internal
    {{ healthcheck('curl --fail -s http://localhost:80/ || exit 1') }}
    labels:
      {# Generate labels(container, port, docker_network, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          (container_item.networks | default([docker_network]))[0],
          container_item.use_authelia
        )
      }}
      {{ kuma(container_item.name) }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('1.0', '512M', '0.10', '64M') }}

  feed-cache:
    image: nginx:alpine
    container_name: freshrss-feed-cache
    restart: unless-stopped
    # nginx binds :80 and forks workers — needs NET_BIND_SERVICE + SETUID/SETGID/CHOWN.
    cap_drop:
      - ALL
    cap_add:
      - CHOWN
      - SETUID
      - SETGID
      - NET_BIND_SERVICE
    security_opt:
      - no-new-privileges:true
    volumes:
      - ./nginx-feed-cache.conf:/etc/nginx/conf.d/default.conf:ro
      - feed_cache:/var/cache/nginx
    networks:
      - internal
    {{ healthcheck('["CMD-SHELL", "wget -q -O /dev/null http://127.0.0.1/health"]') }}
    labels:
      {{ kuma('freshrss-feed-cache', name='FreshRSS Cache') }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('0.50', '128M', '0.05', '16M') }}

{{ external_networks() }}
  # Despite the name, NOT a true-internal net: the feed-cache nginx proxies
  # rachelbythebay.com outbound, so `internal: true` would break it.
  internal:
    internal: false

volumes:
  feed_cache:
