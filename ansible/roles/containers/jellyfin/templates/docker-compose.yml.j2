{% from 'traefik.yml.j2' import labels with context %}
{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'healthcheck.yml.j2' import healthcheck %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
---

services:
  jellyfin:
    image: lscr.io/linuxserver/jellyfin:10.11.10ubu2404-ls35
    container_name: jellyfin
    environment:
      - PUID={{ puid }}
      - PGID={{ pgid }}
      - TZ={{ tz }}
      - JELLYFIN_PublishedServerUrl={{ server_ip }} #optional
      - DOCKER_MODS=linuxserver/mods:jellyfin-opencl-intel
    volumes:
      - ./config:/config
      # Both media mounts read-only (2026-07-03): jellyfin only READS the library —
      # SaveLocalMetadata is off in every library, artwork/trickplay/chapters live in
      # /config, and all writers (the *arrs, bazarr, janitorr, qbittorrent) have their
      # own mounts. Caps the blast radius of the one internet-facing, Authelia-less
      # media parser. Cost: deleting media from the Jellyfin UI now fails — delete via
      # the *arrs (which janitorr also drives).
      - /home/{{ sys_user }}/server/containers/data/media:/data:ro
      # Same tree AGAIN at /data/media (janitorr-congruent view, 2026-07-02 review M4):
      # janitorr mounts containers/data at /data, so the leaving-soon dir it hands
      # Jellyfin (media-server-leaving-soon-dir: /data/media/leaving-soon) and the
      # symlink TARGETS it writes inside it (/data/media/tv/..., as reported by the
      # *arrs) only resolve here if /data/media/* exists in THIS namespace too. The
      # existing libraries stay at /data/tv + /data/movies via the mount above —
      # migrating them instead would mean editing library paths in Jellyfin's own DB.
      - /home/{{ sys_user }}/server/containers/data/media:/data/media:ro
    restart: unless-stopped
    ports:
      # Bind LAN discovery to the host's LAN IP (not 0.0.0.0), matching the
      # pihole/portainer convention — these are local-network discovery
      # protocols and shouldn't listen on every interface.
      - "{{ server_ip }}:7359:7359/udp"
      - "{{ server_ip }}:1900:1900/udp"
      # Direct LAN access by IP, bound to the host LAN IP (not 0.0.0.0) so it
      # never listens on the WAN/other interfaces — Traefik still fronts the
      # public jellyfin.<domain> route.
      - "{{ server_ip }}:8096:8096"
    devices:
      - /dev/dri:/dev/dri
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      - SETGID
      - SETUID
      - CHOWN
      # FOWNER + DAC_OVERRIDE: the DOCKER_MODS opencl-intel installer runs a root
      # dpkg unpack that chmods/chowns files it doesn't own — under cap_drop:ALL
      # those EPERM (intel-opencl-icd-legacy1 stays unconfigured, errors every boot).
      # Same recipe as the four *arrs (ca7d6832).
      - FOWNER
      - DAC_OVERRIDE
    {{ service_networks() }}
    # start_period 60s: a library scan + plugin/HW-transcode init on a slow (esp. post-update)
    # boot can exceed the macro's 30s default and trip a needless autoheal restart mid-boot.
    {{ healthcheck('curl --fail -s http://localhost:8096/health || exit 1', start_period='60s') }}
    labels:
      # Disable watchtower update — pinned + Renovate-managed
      - "com.centurylinklabs.watchtower.enable=false"
      {# Generate labels(container, port, docker_network, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          (container_item.networks | default([docker_network]))[0],
          container_item.use_authelia
        )
      }}
      {{ kuma(container_item.name) }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('4.0', '4096M', '0.25', '256M') }}

{{ external_networks() }}
