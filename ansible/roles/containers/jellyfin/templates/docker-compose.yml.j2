{% from 'traefik.yml.j2' import labels with context %}
---
version: "3.8"
services:
  jellyfin:
    image: lscr.io/linuxserver/jellyfin:latest
    container_name: jellyfin
    environment:
      - puid={{ puid }}
      - pgid={{ pgid }}
      - tz={{ tz }}
      - JELLYFIN_PublishedServerUrl={{ SERVER_IP }} #optional
      - DOCKER_MODS=linuxserver/mods:jellyfin-opencl-intel
    volumes:
      - ./config:/config
      - /home/{{ sys_user }}/server/containers/data/media:/data
    restart: unless-stopped
    devices:
      - /dev/dri:/dev/dri
    networks:
      - {{ docker_network }}
    healthcheck:
      test: curl --fail -s http://localhost:8096/ || exit 1
      interval: 30s
      timeout: 10s
      retries: 3
    labels:
      # Enable traefik for container
      - "traefik.enable=true"
      # Use traefik network
      - "traefik.docker.network={{ docker_network }}"

      {# Generate labels(container, port, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          container_item.use_authelia
        )
      }}

networks:
  {{ docker_network }}:
    external: true
