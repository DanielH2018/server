# Configarr config — managed by Ansible (roles/containers/configarr). DO NOT hand-edit
# the rendered copy under containers/ — edit this template.
#
# SCOPE IS DELIBERATELY MINIMAL. The Sonarr "Anime" profile is the operator's own bespoke
# scheme (52 scored "Anime Profile N_N_N" custom formats). We do NOT reproduce or manage
# that scheme here — a read-only snapshot lives in files/baseline/ for reference, and the
# live definitions stay in Sonarr's DB (Kopia-backed). Because `delete_unmanaged_custom_formats`
# is left OFF (the default), Configarr only ADDS/updates the CFs defined below and never
# touches the bespoke scheme or its scores.
#
# Why this exists: NTRX advertised "BD Remux 1080p AVC" but shipped a long-GOP HEVC 10-bit
# re-encode (Mushoku Tensei S2, 2026-07-16) -> Jellyfin buffering + slow seeks. Sonarr trusts
# the release TITLE at grab time, so only release-group reputation can stop a lying label.
trashGuideUrl: https://github.com/TRaSH-Guides/Guides
# configarr resolves the `include: - template:` entries below from the recyclarr config-templates
# repo (the guide-backed WEB-1080p / HD Bluray + WEB profiles recyclarr v8 dropped from `include:`
# but configarr still pulls). This replaces the retired recyclarr role's trash_id profiles.
recyclarrConfigUrl: https://github.com/recyclarr/config-templates

customFormatDefinitions:
  # Reject mislabeled "fake remux" groups. With the Anime profile's minFormatScore=0,
  # a -10000 assigned score drops the release below the floor -> rejected outright.
  - trash_id: local-fake-remux-groups
    name: "Fake/Mislabeled Remux Groups"
    includeCustomFormatWhenRenaming: false
    specifications:
      - name: NTRX
        implementation: ReleaseGroupSpecification
        negate: false
        required: false
        fields:
          value: "^(NTRX)$"

  # Prefer genuine anime remux/encode groups actually seen in this library's grab history.
  - trash_id: local-anime-trusted-groups
    name: "Trusted Anime Groups"
    includeCustomFormatWhenRenaming: false
    specifications:
      - name: TTGA
        implementation: ReleaseGroupSpecification
        negate: false
        required: false
        fields:
          value: "^(TTGA)$"
      - name: LostYears
        implementation: ReleaseGroupSpecification
        negate: false
        required: false
        fields:
          value: "^(LostYears)$"

  # Prefer anime releases that ship English softsubs. Group reputation is the ONLY pre-grab
  # English-subtitle signal Sonarr has — it scores the release TITLE, never the file — so these
  # groups are the ones known to mux the streaming-service English subs (embedded ASS) into the
  # release. POSITIVE-ONLY on purpose: the Anime profile's minFormatScore=0 means a NEGATIVE
  # score would drop a subs-less release below the floor and REJECT it, which would break the
  # "grab a raw release when it's the only option, then let Bazarr/Whisper fill the gap" fallback.
  # Tune the alternation from THIS library's grab history (same discipline as the trusted list).
  - trash_id: local-anime-english-sub-groups
    name: "Anime English-Sub Groups"
    includeCustomFormatWhenRenaming: false
    specifications:
      - name: English-subbing anime groups
        implementation: ReleaseGroupSpecification
        negate: false
        required: false
        fields:
          value: "^(SubsPlease|Erai-raws|ASW|EMBER|ToonsHub)$"

  # Title-level English-subtitle signal for subbed releases from groups not in the list above:
  # multi-sub / dual-audio tags in the release name strongly correlate with an English track.
  - trash_id: local-anime-multisub-tags
    name: "Anime Multi-Sub / Dual-Audio (title)"
    includeCustomFormatWhenRenaming: false
    specifications:
      - name: Multi-Sub or Dual-Audio in title
        implementation: ReleaseTitleSpecification
        negate: false
        required: false
        fields:
          value: "\\b(Multi[-. ]?Subs?|Multiple[-. ]Subtitle|Dual[-. ]?Audio)\\b"

sonarr:
  series:
    base_url: http://sonarr:8989
    api_key: {{ sonarr_api_key }}

    # Guide-backed WEB-1080p profile (ported from the retired recyclarr role). Syncs onto the
    # existing "WEB-1080p" Sonarr profile by name — no duplicate. delete_unmanaged_custom_formats
    # stays OFF (default) so the 52 bespoke "Anime Profile N_N_N" CFs are never touched.
    quality_definition:
      type: series
    include:
      - template: sonarr-v4-quality-profile-web-1080p
      - template: sonarr-v4-custom-formats-web-1080p

    custom_formats:
      - trash_ids:
          - local-fake-remux-groups
        assign_scores_to:
          - name: Anime
            score: -10000
      - trash_ids:
          - local-anime-trusted-groups
        assign_scores_to:
          - name: Anime
            score: 200
      # Strong nudge toward English-softsub groups (still below the -10000 fake-remux reject).
      - trash_ids:
          - local-anime-english-sub-groups
        assign_scores_to:
          - name: Anime
            score: 300
      # Milder nudge for title-tagged multi-sub / dual-audio releases.
      - trash_ids:
          - local-anime-multisub-tags
        assign_scores_to:
          - name: Anime
            score: 100

radarr:
  movies:
    base_url: http://radarr:7878
    api_key: {{ radarr_api_key }}

    # Guide-backed HD Bluray + WEB profile (ported from the retired recyclarr role). Syncs onto the
    # existing "HD Bluray + WEB" Radarr profile by name. No local CFs here — Radarr has no bespoke
    # scheme to protect, but delete_unmanaged stays OFF (default) for symmetry/safety.
    quality_definition:
      type: movie
    include:
      - template: radarr-quality-profile-hd-bluray-web
      - template: radarr-custom-formats-hd-bluray-web
