{% from 'traefik.yml.j2' import labels with context %}
{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
{# Only stand up the code-server read proxy on the host that runs code-server (daniel-server; NOT
   the memory-constrained Pi, which has docker-proxy for autoheal but no code-server). Gated on the
   HOST, not containers_list: a tagged `deploy.yml --tags docker-proxy` set_facts containers_list to
   the filtered dependency closure (docker-proxy + deps, no code-server), so a containers_list probe
   renders False and drops the service. inventory_hostname is stable across that filtering. -#}
{% set has_code_server = (inventory_hostname | default('')) == 'daniel-server' %}
---

services:
  docker-proxy:
    image: lscr.io/linuxserver/socket-proxy:latest
    container_name: docker-proxy
    environment:
      - CONTAINERS=1  # Allow access to viewing containers
      - SERVICES=1    # Allow access to viewing services (necessary when using Docker Swarm)
      - TASKS=1       # Allow access to viewing tasks (necessary when using Docker Swarm)
      - POST=0        # Read-only: no write/lifecycle ops on this broadly-reachable proxy
      - EXEC=0        # Read-only: no container exec (Portainer + lifecycle automation use dedicated proxies)
      - INFO=1        # Portainer checks this to validate connection
      - VERSION=1     # Portainer checks this to validate connection
      - PING=1        # Portainer checks this to validate connection
      - IMAGES=1
      - VOLUMES=1
      - NETWORKS=1
      - EVENTS=1
    {{ service_networks() }}
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro # Mounted as read-only
    read_only: true
    tmpfs:
      - /run
    # LSIO socket-proxy is haproxy on a high port — already read_only + tmpfs.
    # Empty add; if haproxy can't drop to its user, add [SETUID, SETGID]. Verify on deploy.
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "wget -qO /dev/null http://localhost:2375/version || exit 1"]
      # Host-tunable cadence: 10s is fine on the server, but each probe forks runc twice —
      # real CPU/PID churn on the Pi (see container_healthcheck_interval in its host_vars).
      interval: {{ container_healthcheck_interval | default('10s') }}
      timeout: 5s
      retries: 3
      start_period: 10s
    labels:
      # Disable watchtower update
      - "com.centurylinklabs.watchtower.enable=false"
      {{ kuma(container_item.name) }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('0.50', '128M', '0.05', '16M') }}

  # Write-capable proxy for lifecycle automation only (Watchtower + Autoheal).
  # POST=1 enables create/start/stop/restart; EXEC stays off. It lives solely on the
  # private `lifecycle` network those two containers join, so write access to the
  # Docker API is NOT exposed to the proxy/monitoring/apps networks.
  docker-proxy-lifecycle:
    image: lscr.io/linuxserver/socket-proxy:latest
    container_name: docker-proxy-lifecycle
    environment:
      - CONTAINERS=1
      - IMAGES=1         # Watchtower pulls/prunes images
      - NETWORKS=1       # Watchtower needs network info to recreate containers
      - INFO=1
      - VERSION=1
      - PING=1
      - EVENTS=1
      - POST=1           # Allow write methods (POST/PUT/DELETE): create/remove containers + image cleanup
      - ALLOW_START=1    # Watchtower: start recreated containers
      - ALLOW_STOP=1     # Watchtower: stop old containers before replacing
      - ALLOW_RESTARTS=1 # Autoheal: restart unhealthy containers (also covers Watchtower kill)
      # EXEC=0 blocks the exec *run* path (/exec/{id}/start -> 403, verified). Note: create-exec
      # (/containers/{id}/exec) still slips through via CONTAINERS+POST, but with /exec/start
      # blocked it can't execute. Accepted: this proxy is already create-capable (POST=1, needed
      # by Watchtower) and isolated to the lifecycle net with only Watchtower + Autoheal.
      - EXEC=0
    networks:
      - lifecycle
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
    read_only: true
    tmpfs:
      - /run
    # LSIO socket-proxy is haproxy on a high port — already read_only + tmpfs.
    # Empty add; if haproxy can't drop to its user, add [SETUID, SETGID]. Verify on deploy.
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "wget -qO /dev/null http://localhost:2375/version || exit 1"]
      interval: {{ container_healthcheck_interval | default('10s') }}
      timeout: 5s
      retries: 3
      start_period: 10s
    labels:
      - "com.centurylinklabs.watchtower.enable=false"
      {{ kuma('docker-proxy-lifecycle') }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('0.50', '128M', '0.05', '16M') }}

{% if has_code_server %}
  # Read-only proxy dedicated to code-server's in-IDE `docker` CLI (Security M1). Same
  # least-privilege env as the main docker-proxy (POST=0/EXEC=0), but it lives SOLELY on the
  # private `codeserver` network shared only with code-server — so the shared docker-proxy can
  # stay off `apps` and the internet-facing app fleet can no longer read every container's Env
  # (secrets) via CONTAINERS=1. code-server is the only apps-side consumer, hence its own proxy.
  docker-proxy-codeserver:
    image: lscr.io/linuxserver/socket-proxy:latest
    container_name: docker-proxy-codeserver
    environment:
      - CONTAINERS=1
      - SERVICES=1
      - TASKS=1
      - POST=0        # Read-only: no write/lifecycle ops
      - EXEC=0        # Read-only: no container exec
      - INFO=1
      - VERSION=1
      - PING=1
      - IMAGES=1
      - VOLUMES=1
      - NETWORKS=1
      - EVENTS=1
    networks:
      - codeserver
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
    read_only: true
    tmpfs:
      - /run
    # LSIO socket-proxy is haproxy on a high port — already read_only + tmpfs.
    # Empty add; if haproxy can't drop to its user, add [SETUID, SETGID]. Verify on deploy.
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "wget -qO /dev/null http://localhost:2375/version || exit 1"]
      interval: {{ container_healthcheck_interval | default('10s') }}
      timeout: 5s
      retries: 3
      start_period: 10s
    labels:
      - "com.centurylinklabs.watchtower.enable=false"
      {{ kuma('docker-proxy-codeserver') }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('0.50', '128M', '0.05', '16M') }}
{% endif %}

{{ external_networks() }}
  lifecycle:
    external: true
{% if has_code_server %}
  codeserver:
    external: true
{% endif %}
