{% from 'traefik.yml.j2' import labels with context %}
---
version: "3.8"
services:
  bazarr:
    image: lscr.io/linuxserver/bazarr:latest
    container_name: bazarr
    environment:
      - PUID={{ PUID }}
      - PGID={{ PGID }}
      - TZ={{ TZ }}
    volumes:
      - /etc/localtime:/etc/localtime:ro
      - ./config:/config
      - /home/{{ SYS_USER }}/server/containers/data/media/tv:/tv
      - /home/{{ SYS_USER }}/server/containers/data/media/movies:/movies
      - /home/{{ SYS_USER }}/server/containers/data/downloads:/downloads
    restart: unless-stopped
    networks:
      - {{ DOCKER_NETWORK }}
    healthcheck:
      test: curl --fail -s http://localhost:6767/ || exit 1
      interval: 30s
      timeout: 10s
      retries: 3
    labels:
      # Enable traefik for container
      - "traefik.enable=true"
      # Use traefik network
      - "traefik.docker.network={{ DOCKER_NETWORK }}"

      {# Generate labels(container, port, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          container_item.use_authelia
        )
      }}
  whisper:
    image: onerahmet/openai-whisper-asr-webservice:latest
    container_name: whisper
    environment:
      - PUID={{ PUID }}
      - PGID={{ PGID }}
      - TZ={{ TZ }}
      - ASR_MODEL=small
      - ASR_ENGINE=faster_whisper
    volumes:
      - ./whisper_config:/config
    networks:
      - {{ DOCKER_NETWORK }}
    restart: unless-stopped

networks:
  {{ DOCKER_NETWORK }}:
    external: true
