{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
{% from 'healthcheck.yml.j2' import healthcheck %}
---
services:
  homelab-mcp:
    build:
      context: .
      pull: true  # rebuilds must fetch the newest python base
    container_name: homelab-mcp
    restart: unless-stopped
    user: "1000:1000"
    environment:
      - HOMELAB_MCP_TOKEN={{ homelab_mcp_token }}
      - HOMELAB_HA_TOKEN={{ claude_ha_token }}
      - HOMELAB_FILE_ROOT=/srv/ansible-src
      # Trusted host for the MCP transport's DNS-rebinding guard (else 421 Invalid Host).
      - MCP_PUBLIC_HOST=mcp.local.{{ domain }}
      - PORT={{ container_item.port }}
      - PYTHONDONTWRITEBYTECODE=1
      - TZ=America/Chicago
    volumes:
      # ansible/ source, READ-ONLY — the read_file/list_files jail root. secrets.yml
      # is denied in-app (safe_reads.path_is_denied) and the age key isn't under here,
      # so the worst a jail bug could surface is SOPS ciphertext.
      - /home/{{ sys_user }}/server/ansible:/srv/ansible-src:ro
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    read_only: true
    tmpfs:
      - /tmp
    {{ healthcheck('["CMD", "bash", "-c", "echo > /dev/tcp/127.0.0.1/8000"]', start_period='20s', name=container_item.name) }}
    {{ service_networks() }}
    labels:
      # LAN-only + bearer-token routing is defined in traefik's file provider
      # (roles/containers/traefik/templates/config.yml.j2, mode 0600), NOT here, so the
      # token stays OUT of container labels (any monitoring-net peer can read labels via
      # docker-proxy). This block only PUBLISHES the service; the token-gated mcp.local
      # router references it cross-provider as homelab-mcp@docker.
      - "traefik.enable=true"
      - "traefik.docker.network={{ (container_item.networks | default([docker_network]))[0] }}"
      - "traefik.http.services.homelab-mcp.loadbalancer.server.port={{ container_item.port }}"
      - "com.centurylinklabs.watchtower.enable=false"
      {{ kuma(container_item.name) }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('0.50', '256M', '0.05', '32M') }}

{{ external_networks() }}
