{% from 'traefik.yml.j2' import labels with context %}
{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
{% from 'healthcheck.yml.j2' import healthcheck %}
---
services:
  n8n:
    build:
      context: .
      dockerfile: Dockerfile
      pull: true
    container_name: n8n
    restart: unless-stopped
    environment:
      - N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
      - N8N_HOST=n8n.{{ domain }}
      - N8N_PORT=5678
      - N8N_PROTOCOL=https
      - N8N_RUNNERS_ENABLED=true
      - N8N_PROXY_HOPS=1
      - NODE_ENV=production
      - NODE_RUNNERS_ENABLED=true
      - N8N_RUNNERS_MODE=external
      # Binds the task-runner broker on ALL interfaces (n8n has no per-interface bind option).
      # The runner connects over `internal`, but the broker is ALSO reachable from `apps` siblings
      # — the control is N8N_RUNNERS_AUTH_TOKEN below, NOT network isolation. (Don't read it as
      # internal-only; a sibling holding the token could register a runner = code execution.)
      - N8N_RUNNERS_BROKER_LISTEN_ADDRESS=0.0.0.0
      - N8N_RUNNERS_AUTH_TOKEN={{ n8n_runner_auth_token }}
      - N8N_NATIVE_PYTHON_RUNNER=true
      - N8N_RUNNERS_TASK_REQUEST_TIMEOUT=300
      # Keep database.sqlite small (it hit 840M of execution history — the Kopia
      # backup only needs workflows/credentials): prune runs older than 7 days and
      # compact the DB on startup so the space is actually returned to the FS.
      - EXECUTIONS_DATA_PRUNE=true
      - EXECUTIONS_DATA_MAX_AGE=168
      - DB_SQLITE_VACUUM_ON_STARTUP=true
      - WEBHOOK_URL=https://n8n.{{ domain }}/
      - GENERIC_TIMEZONE={{ tz }}
      - TZ={{ tz }}
    volumes:
      # Bind mount (under containers/n8n/) instead of a named volume so the n8n
      # state — workflows, execution history, and encrypted credentials + the
      # encryption key in ./data/config — lands in Kopia's backup scope.
      - ./data:/home/node/.n8n
      - ./local-files:/files
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    {{ healthcheck('["CMD", "wget", "-q", "--spider", "http://localhost:5678/healthz"]', start_period='60s') }}
    {{ service_networks() }}
      - internal
    labels:
      {# Generate labels(container, port, docker_network, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          (container_item.networks | default([docker_network]))[0],
          container_item.use_authelia
        )
      }}
      {{ kuma(container_item.name) }}

      ## Webhook Bypass (Public)
      # /webhook-test/ is intentionally excluded — it is a dev endpoint with no legitimate external use
      - "traefik.http.routers.n8n-webhook.rule=Host(`n8n.{{ domain }}`) && PathPrefix(`/webhook/`)"
      - "traefik.http.routers.n8n-webhook.entrypoints=https"
      - "traefik.http.routers.n8n-webhook.tls=true"
      - "traefik.http.routers.n8n-webhook.service=n8n"
      # rate-limit moved off the https entrypoint to per-router; re-acquire the default.
      - "traefik.http.routers.n8n-webhook.middlewares=rate-limit@file"
      # Priority must be higher than the UI router so Traefik matches this first
      - "traefik.http.routers.n8n-webhook.priority=100"
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('2.0', '2048M', '0.10', '128M') }}

  n8n-runners:
    build:
      context: .
      dockerfile: Dockerfile-runners
      pull: true
    container_name: n8n-runners
    security_opt:
      - no-new-privileges:true
    # Executes arbitrary workflow code — the most code-exposed container in the fleet,
    # so drop all caps (the image ends `USER runner`, talks only to the broker over
    # `internal`, and binds no privileged port, so it needs none).
    cap_drop:
      - ALL
    restart: unless-stopped
    {{ healthcheck('["CMD", "pgrep", "-f", "task-runner-launcher"]', timeout='5s') }}
    environment:
      - N8N_RUNNERS_TASK_BROKER_URI=http://n8n:5679
      - N8N_RUNNERS_AUTH_TOKEN={{ n8n_runner_auth_token }}
    depends_on:
      n8n:
        condition: service_healthy
    networks:
      - internal
    labels:
      {{ kuma('n8n-runners') }}
    # Resource caps for blast-radius containment (M1). Runner executes arbitrary
    # workflow code, so a cap here is the main DoS guard; tune from cAdvisor/Grafana.
    {{ resources('2.0', '2048M', '0.10', '128M') }}


{{ external_networks() }}
  internal:
    internal: true
