{% from 'traefik.yml.j2' import labels with context %}
{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'healthcheck.yml.j2' import healthcheck %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
---
services:
  littlelink:
    image: ghcr.io/techno-tim/littlelink-server:latest
    container_name: littlelink
    environment:
      - META_TITLE=Daniel Hunter
      - META_DESCRIPTION=Software Engineer
      - META_AUTHOR=Daniel Hunter
      - META_KEYWORDS=Engineering
      - LANG=en
      - META_INDEX_STATUS=all
      - OG_SITE_NAME=Daniel Hunter
      - OG_TITLE=Daniel Hunter
      - OG_DESCRIPTION=The home of Daniel Hunter
      - OG_URL=https://www.{{ domain }}
      - OG_IMAGE=https://i.imgur.com/HAq1SNZ.jpg
      - OG_IMAGE_WIDTH=400
      - OG_IMAGE_HEIGHT=400
      - THEME=Dark
      - FAVICON_URL=https://i.imgur.com/HAq1SNZ.jpg
      - AVATAR_URL=https://i.imgur.com/HAq1SNZ.jpg
      - AVATAR_2X_URL=https://i.imgur.com/HAq1SNZ.jpg
      - AVATAR_ALT=Daniel Hunter Profile Pic
      - NAME=Daniel Hunter
      - BIO=Software Engineer @ Lithic Inc.
      # use ENV variable names for order, listed buttons will be boosted to the top
      - BUTTON_ORDER=GITHUB,LINKED_IN
      - GITHUB=https://github.com/DanielH2018
      - LINKED_IN=https://www.linkedin.com/in/danielrhunter/
    {{ service_networks() }}
    {{ healthcheck('wget --no-verbose --tries=1 --spider http://localhost:3000/ || exit 1', name=container_item.name) }}
    restart: unless-stopped
    # Read-only rootfs: `docker diff` shows zero rootfs writes. tmpfs /tmp is defensive
    # (Node's os.tmpdir) — this is the public landing page, so favor a safe margin.
    read_only: true
    tmpfs:
      - /tmp
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    labels:
      {# Generate labels(container, port, docker_network, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          (container_item.networks | default([docker_network]))[0],
          container_item.use_authelia
        )
      }}
      {{ kuma(container_item.name) }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('0.50', '128M', '0.05', '16M') }}

{{ external_networks() }}
