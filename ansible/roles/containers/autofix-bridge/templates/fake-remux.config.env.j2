# fake-remux config — managed by Ansible (autofix-bridge role). Host-only, 0600: embeds the Sonarr
# API key + the *arr Discord webhook. Read by BOTH host crons: /opt/autofix-fake-remux/
# fake_remux_scan.py (detector) and fake_remux_replace.py (reconciler). Both scripts have sane
# defaults for everything else (sonarr/jellyfin container names, ffprobe path, 40 s probe window);
# only secrets + the operator knobs live here.
SONARR_API_KEY={{ sonarr_api_key }}
ARR_DISCORD_WEBHOOK_URL={{ arr_discord_webhook_url }}
# A genuine remux keyframes ~every 1-2 s; a keyframe gap over this (seconds) is a re-encode.
GOP_MAX_S={{ autofix_fake_remux_gop_max_s | default(5) }}
# Blast valve: more than this many fakes in one scan = a rule bug / systemic import setting, not N
# bad grabs -> act on NONE and alert.
MAX_PER_SCAN={{ autofix_fake_remux_max_per_scan | default(5) }}
STATE_FILE=/var/lib/autofix-fake-remux/state.json

# --- replacer (reconciler: fake_remux_replace.py) ---
# off = detect only; shadow = log intended grabs with zero side effects; live = grab+delete+import.
FAKE_REMUX_REPLACE_MODE={{ autofix_fake_remux_replace_mode | default('shadow') }}
FAKE_REMUX_POLICY=/etc/autofix-fake-remux/policy.json
LEDGER_FILE=/var/lib/autofix-fake-remux/replacements.json
REPLACE_STATE_FILE=/var/lib/autofix-fake-remux/replace_state.json
OUTCOMES_FILE=/var/lib/autofix-fake-remux/outcomes.jsonl
