# fake-remux scan config — managed by Ansible (autofix-bridge role). Host-only, 0600: embeds the
# Sonarr API key + the *arr Discord webhook. Read by /opt/autofix-fake-remux/fake_remux_scan.py
# (host cron). The script has sane defaults for everything else (sonarr/jellyfin container names,
# ffprobe path, 40 s probe window); only secrets + the operator knobs live here.
SONARR_API_KEY={{ sonarr_api_key }}
ARR_DISCORD_WEBHOOK_URL={{ arr_discord_webhook_url }}
# Report-only (default): FLAG re-encoded remuxes via Discord + the "Fake Remux Scan" monitor without
# deleting. Flip to false (host_vars autofix_fake_remux_dry_run, + redeploy) to delete + re-search —
# the Anime profile's NTRX block (configarr) then steers the re-grab clean.
FAKE_REMUX_DRY_RUN={{ autofix_fake_remux_dry_run | default(true) | string | lower }}
# A genuine remux keyframes ~every 1-2 s; a keyframe gap over this (seconds) is a re-encode.
GOP_MAX_S={{ autofix_fake_remux_gop_max_s | default(5) }}
# Blast valve: more than this many fakes in one scan = a rule bug / systemic import setting, not N
# bad grabs -> act on NONE and alert.
MAX_PER_SCAN={{ autofix_fake_remux_max_per_scan | default(5) }}
STATE_FILE=/var/lib/autofix-fake-remux/state.json
