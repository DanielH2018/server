{% from 'traefik.yml.j2' import labels with context %}
---
version: "3.8"
services:
  glances:
    container_name: glances
    image: nicolargo/glances:latest
    restart: unless-stopped
    networks:
      - {{ docker_network }}
    pid: host
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - /etc/os-release:/etc/os-release:ro
    environment:
      - "GLANCES_OPT=-w"
    labels:
      # Enable traefik for container
      - "traefik.enable=true"
      # Use traefik network
      - "traefik.docker.network={{ docker_network }}"

      {# Generate labels(container, port, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          container_item.use_authelia
        )
      }}
      
      - "traefik.frontend.rule=Host:glances.docker.localhost"

networks:
  {{ docker_network }}:
    external: true
