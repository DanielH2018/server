{% from 'traefik.yml.j2' import labels with context %}
{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'healthcheck.yml.j2' import healthcheck %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
---

services:
  sonarr:
    image: lscr.io/linuxserver/sonarr:4.0.17.2952-ls312
    container_name: sonarr
    environment:
      - PUID={{ puid }}
      - PGID={{ pgid }}
      - TZ={{ tz }}
      # radarr-striptracks is INTENTIONAL here: TheCaptain989's striptracks mod auto-detects
      # Sonarr vs Radarr at runtime, and there is NO separate `sonarr-striptracks` LSIO mod —
      # the radarr-named image is the single published variant used by both apps.
      - DOCKER_MODS=linuxserver/mods:radarr-striptracks
    volumes:
      - /etc/localtime:/etc/localtime:ro
      - ./config:/config
      - /home/{{ sys_user }}/server/containers/data/media/tv:/tv
      - /home/{{ sys_user }}/server/containers/data/downloads:/downloads
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      - SETGID
      - SETUID
      - CHOWN
    {{ service_networks() }}
    {{ healthcheck('curl --fail -s http://localhost:8989/ping || exit 1') }}
    labels:
      # Disable watchtower update — pinned + Renovate-managed
      - "com.centurylinklabs.watchtower.enable=false"
      {# Generate labels(container, port, docker_network, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          (container_item.networks | default([docker_network]))[0],
          container_item.use_authelia
        )
      }}
      {{ kuma(container_item.name) }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('1.0', '1024M', '0.10', '128M') }}

{{ external_networks() }}
