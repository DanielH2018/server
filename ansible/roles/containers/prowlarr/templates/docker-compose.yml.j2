{% from 'traefik.yml.j2' import labels with context %}
{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'healthcheck.yml.j2' import healthcheck %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
---

services:
  prowlarr:
    image: lscr.io/linuxserver/prowlarr:2.4.0.5397-ls150
    container_name: prowlarr
    environment:
      - PUID={{ puid }}
      - PGID={{ pgid }}
      - TZ={{ tz }}
    volumes:
      - ./config:/config
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      - SETGID
      - SETUID
      - CHOWN
      - FOWNER
      - DAC_OVERRIDE
    {{ service_networks() }}
      # Reach the isolated flaresolverr sidecar on its dedicated bridge (Security M3);
      # prowlarr stays on `media` for Traefik + the monitor-bridge prowlarr:9696 check.
      - prowlarr-flaresolverr
    # Gate startup on the flaresolverr sidecar being healthy — on a cold `up` prowlarr would
    # otherwise start first and log challenge-solve failures until flaresolverr caught up (parity
    # with the karakeep -> karakeep-chrome gate). flaresolverr is only called on-demand during
    # indexer searches, so this is a boot-ordering nicety, not a hard runtime dependency.
    depends_on:
      flaresolverr:
        condition: service_healthy
    {{ healthcheck('curl --fail -s http://localhost:9696/ping || exit 1') }}
    labels:
      # Disable watchtower update — pinned + Renovate-managed
      - "com.centurylinklabs.watchtower.enable=false"
      {# Generate labels(container, port, docker_network, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          (container_item.networks | default([docker_network]))[0],
          container_item.use_authelia
        )
      }}
      {{ kuma(container_item.name) }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('1.0', '1024M', '0.10', '128M') }}

  flaresolverr:
    # DockerHub mirror flaresolverr/flaresolverr:latest
    image: ghcr.io/flaresolverr/flaresolverr:latest
    container_name: flaresolverr
    environment:
      - LOG_LEVEL=info
      - TZ={{ tz }}
    restart: unless-stopped
    volumes:
      - ./flaresolverr_config:/config
    security_opt:
      - no-new-privileges:true
    # Python service driving a bundled headless Chrome; no privileged ops, verified healthy
    # with zero caps (same empty-add rationale as karakeep-chrome's headless Chrome).
    cap_drop:
      - ALL
    # Isolated OFF the shared `media` net (Security M3): flaresolverr loads
    # attacker-controlled indexer pages and runs their JS in headless Chrome, so a
    # compromise must not reach the ~11 unauthenticated container ports on `media`.
    # It only needs internet egress + reachability FROM prowlarr, so it shares a
    # dedicated bridge with prowlarr instead of service_networks() — same isolation
    # pattern as karakeep-chrome's `internal` net. NOT media.
    networks:
      - prowlarr-flaresolverr
    {{ healthcheck('curl --fail -s http://localhost:8191/ || exit 1') }}
    labels:
      # Keep :latest but pin against watchtower auto-updates — prowlarr depends_on this sidecar
      # (service_healthy) at cold boot, so an unsupervised pull that breaks flaresolverr would block
      # prowlarr's next start (matches crowdsec/unbound, the other health-gating :latest sidecars).
      - "com.centurylinklabs.watchtower.enable=false"
      {{ kuma('flaresolverr') }}
    # Resource caps for blast-radius containment (M1). Runs headless Chrome, so
    # size generously and tune from cAdvisor/Grafana. 1.0 CPU throttled 11% of
    # periods once EZTV joined 1337x behind it (2026-07-03) — solves burst for
    # seconds while the 2-min average stays ~0.2, so the cap must fit the burst.
    {{ resources('2.0', '1024M', '0.10', '128M') }}

{{ external_networks() }}
  # Dedicated bridge isolating the headless-Chrome flaresolverr sidecar from the shared
  # `media` fleet (Security M3). internal:false — flaresolverr must reach the internet to
  # solve indexer Cloudflare/JS challenges (same as karakeep's `internal` bridge).
  prowlarr-flaresolverr:
    internal: false
