{% from 'traefik.yml.j2' import labels with context %}
---
version: "3.8"
services:
  duplicati:
    image: lscr.io/linuxserver/duplicati:latest
    container_name: duplicati
    environment:
      - PUID=0
      - PGID=0
      - TZ={{ TZ }}
      #- CLI_ARGS= 
    volumes:
      - ./config:/config
      - ./backups:/backups
      - ../:/source
    restart: unless-stopped
    networks:
      - {{ DOCKER_NETWORK }}
    labels:
      # Enable traefik for container
      - "traefik.enable=true"
      # Use traefik network
      - "traefik.docker.network={{ DOCKER_NETWORK }}"

      {# Generate labels(container_name, port, use_authelia) -#}
      {{ labels(container, '8200', 'y') }}

networks:
  {{ DOCKER_NETWORK }}:
    external: true
