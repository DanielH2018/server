{% from 'traefik.yml.j2' import labels with context %}
---
version: "3.8"
services:
  duplicati:
    image: lscr.io/linuxserver/duplicati:latest
    container_name: duplicati
    environment:
      - PUID=0
      - PGID=0
      - TZ={{ tz }}
      #- CLI_ARGS= 
    volumes:
      - ./config:/config
      - ./backups:/backups
      - ../:/source
    restart: unless-stopped
    networks:
      - {{ docker_network }}
    labels:
      # Enable traefik for container
      - "traefik.enable=true"
      # Use traefik network
      - "traefik.docker.network={{ docker_network }}"

      {# Generate labels(container, port, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          container_item.use_authelia
        )
      }}

networks:
  {{ docker_network }}:
    external: true
