{% from 'autokuma.yml.j2' import labels as kuma with context %}

services:
  wg-easy:
    image: ghcr.io/wg-easy/wg-easy:latest
    container_name: wg-easy
    # NET_ADMIN to create the wg interface + apply rules; NET_RAW because wg-quick runs
    # iptables (the iptables CLI opens a raw socket to init the 'nat' table — fails with
    # "can't initialize iptables table `nat`: Permission denied" without it). SYS_MODULE
    # not needed (wireguard module loaded on host). Verify on deploy (docker logs wg-easy).
    cap_drop:
      - ALL
    cap_add:
      - NET_ADMIN
      - NET_RAW
    security_opt:
      - no-new-privileges:true
    sysctls:
      - net.ipv4.ip_forward=1
      - net.ipv4.conf.all.src_valid_mark=1
    ports:
      - "51822:51822/udp"
      # Bind the admin UI to the Pi's LAN IP only (not 0.0.0.0) so it isn't reachable
      # on the WireGuard tunnel interface or other interfaces. UDP tunnel stays on all
      # interfaces — clients/port-forward must reach it and it's authenticated by WG.
      - "{{ server_ip }}:{{ container_item.port }}:51821/tcp"
    environment:
      - LANG=en
      - WG_HOST=wireguard.{{ domain }}
      - WG_PERSISTENT_KEEPALIVE=25
      - WG_PORT=51822
    volumes:
      - ./config:/etc/wireguard
    restart: unless-stopped
    networks:
{% for net in container_item.networks | default([docker_network]) %}
      - {{ net }}
{% endfor %}
    labels:
      {{ kuma('wg-easy') }}
    # Resource caps for blast-radius containment (M1); modest caps sized for the Pi.
    deploy:
      resources:
        limits:
          cpus: '0.50'
          memory: 256M
        reservations:
          cpus: '0.05'
          memory: 32M

networks:
{% for net in container_item.networks | default([docker_network]) %}
  {{ net }}:
    external: true
{% endfor %}
