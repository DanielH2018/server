{% from 'traefik.yml.j2' import labels with context %}
{% from 'autokuma.yml.j2' import labels as kuma with context %}
{% from 'networks.yml.j2' import service_networks, external_networks with context %}
{% from 'resources.yml.j2' import resources %}
---

services:
  speedtest:
    container_name: speedtest
    image: lscr.io/linuxserver/speedtest-tracker:latest
    {{ service_networks() }}
    volumes:
      - ./config:/config
    environment:
      - TZ={{ tz }}
      - PUID={{ puid }}
      - PGID={{ pgid }}
      - APP_KEY={{ speedtest_app_key }}
      # No quotes around values: list-form environment passes them literally into the
      # var (APP_URL was `"https://…"` with the quotes). The app's .env templating
      # happened to strip them, but don't rely on that.
      - APP_URL=https://speedtest.{{ domain }}
      # Results are stored in UTC by design (APP_TIMEZONE stays default); this is
      # the UI-display timezone, which otherwise also defaults to Etc/UTC.
      - DISPLAY_TIMEZONE={{ tz }}
      - OOKLA_EULA_GDPR=true
      - "SPEEDTEST_SCHEDULE=0 */6 * * *"
      - SPEEDTEST_SERVERS=1775
      - PRUNE_RESULTS_OLDER_THAN=30
    # Log rotation is set globally in the Docker daemon (daemon.json: json-file,
    # max-size 10m × 3) by the docker_install role — no per-service logging block needed.
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "wget", "-q", "--spider", "http://localhost:80/"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    # LSIO image: cap_drop ALL plus the s6 privilege-drop set and NET_BIND_SERVICE for :80.
    # Verify on deploy (docker logs speedtest) — add back caps if it fails to start.
    cap_drop:
      - ALL
    cap_add:
      - CHOWN
      - SETUID
      - SETGID
      - FOWNER
      - DAC_OVERRIDE
      - NET_BIND_SERVICE
    security_opt:
      - no-new-privileges:true
    labels:
      {# Generate labels(container, port, docker_network, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          (container_item.networks | default([docker_network]))[0],
          container_item.use_authelia
        )
      }}
      {{ kuma(container_item.name) }}
    # Resource caps for blast-radius containment (M1); tune from cAdvisor/Grafana.
    {{ resources('1.0', '512M', '0.10', '64M') }}

{{ external_networks() }}
