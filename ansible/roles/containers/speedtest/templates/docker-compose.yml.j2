{% from 'traefik.yml.j2' import labels with context %}
---
version: "3.8"
services:
  speedtest:
    container_name: speedtest
    image: henrywhitaker3/speedtest-tracker
    networks:
      - {{ DOCKER_NETWORK }}
    volumes:
      - ./config:/config
    environment:
      - TZ=
      - PUID={{ PUID }}
      - PGID={{ PGID }}
      - OOKLA_EULA_GDPR=true
    logging:
        driver: "json-file"
        options:
            max-file: "10"
            max-size: "200k"
    restart: unless-stopped
    labels:
      # Enable traefik for container
      - "traefik.enable=true"
      # Use traefik network
      - "traefik.docker.network={{ DOCKER_NETWORK }}"

      {# Generate labels(container, port, use_authelia) -#}
      {{ labels(
          container_item.hostname | default(container_item.name),
          container_item.port | string,
          container_item.use_authelia
        )
      }}

networks:
  {{ DOCKER_NETWORK }}:
    external: true
