{% from 'traefik.yml.j2' import labels with context %}
---
version: "3.8"
services:
  nordlynx:
    image: ghcr.io/bubuntux/nordlynx:latest
    container_name: nordlynx
    restart: unless-stopped
    cap_add:
      - NET_ADMIN #required
    environment:
      - ALLOWED_IPS=0.0.0.0/0 # So this docker network can access it
      - NET_LOCAL=172.19.0.0/16 # So it can be accessed within the local network
      - PRIVATE_KEY={{ NORDVPN_KEY }}
      - TZ={{ TZ }}
    volumes:
      - ./scripts:/scripts
    sysctls:
      - net.ipv6.conf.all.disable_ipv6=1  # Recomended if using ipv4 only
      - net.ipv4.conf.all.rp_filter=2
    ports:
      - 8080:8080 # qBittorrent WebUI
      - 6881:6881 # qBittorrent
      - 6881:6881/udp # qBittorrent udp
    networks:
      - {{ DOCKER_NETWORK }}
    healthcheck:
      test: bash ./scripts/vpn-health-check # health check script confirms protected vpn connection and a connected qbittorrent
      interval: 10s
      retries: 3
      timeout: 5s
      start_period: 30s
    labels:
      # Enable traefik for container
      - "traefik.enable=true"
      # Use traefik network
      - "traefik.docker.network={{ DOCKER_NETWORK }}"

      {# Generate labels(container_name, port, use_authelia) -#}
      {{ labels(container, '8080', 'y') }}

      # Disable Watchtower
      - "com.centurylinklabs.watchtower.enable=false"
      # Enable Autoheal
      - "autoheal=true"

  qbittorrent:
    image: lscr.io/linuxserver/qbittorrent:latest
    container_name: qbittorrent
    network_mode: service:nordlynx
    depends_on:
      nordlynx:
        condition: service_healthy
    environment:
      - PUID={{ PUID }}
      - PGID={{ PGID }}
      - TZ={{ TZ }}
      - UMASK_SET=022
      - WEBUI_PORT=8080
    volumes:
      - ./scripts:/scripts
      - ./config:/config
      - /home/{{ SYS_USER }}/server/data/torrents:/data/torrents
    restart: unless-stopped
    healthcheck:
      test: bash ./scripts/qbittorrent-health-check # health check script confirms protected vpn connection and a connected qbittorrent
      interval: 10s
      retries: 0
      timeout: 5s
      start_period: 1m
    labels:
      # Enable Autoheal
      - "autoheal=true"

  transcode:
    container_name: transcode
    build:
      context: ./transcode
    environment:
      - TZ={{ TZ }}
      - TRANSCODE_PATHS=data/torrents, /data/media/movies, /data/media/tv
    volumes:
      - /home/{{ SYS_USER }}/server/data/torrents:/data/torrents
      - /home/{{ SYS_USER }}/server/data/torrents:/data/media/movies
      - /home/{{ SYS_USER }}/server/data/torrents:/data/media/tv
      - ./transcode:/usr/app
      - transcode-data:/usr/app/node_modules
    restart: unless-stopped
    networks:
      - {{ DOCKER_NETWORK }}

networks:
  {{ DOCKER_NETWORK }}:
    external: true
volumes:
  transcode-data: