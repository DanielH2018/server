{% from 'traefik.yml.j2' import labels with context %}
---
version: "3.8"
services:
  hoppscotch:
    image: hoppscotch/hoppscotch:v2.2.1
    container_name: hoppscotch
    ports:
      - 3002:3000
    restart: unless-stopped
    networks:
      - {{ DOCKER_NETWORK }}
    healthcheck:
      test: wget --no-verbose --tries=1 --spider http://localhost:3000/ || exit 1
      interval: 30s
      timeout: 10s
      retries: 3
    labels:
      # Enable traefik for container
      - "traefik.enable=true"
      # Use traefik network
      - "traefik.docker.network={{ DOCKER_NETWORK }}"

      {# Generate labels(container_name, port, use_authelia) -#}
      {{ labels(container, '3000', 'y') }}

networks:
  {{ DOCKER_NETWORK }}:
    external: true
