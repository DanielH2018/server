{% from 'traefik.yml.j2' import labels with context %}
---
version: "3.8"
services:
  home-assistant:
    image: lscr.io/linuxserver/homeassistant:latest
    container_name: home-assistant
    environment:
      - PUID={{ PUID }}
      - PGID={{ PUID }}
      - TZ={{ TZ }}
    volumes:
      - ./config:/config
    ports:
      - 8123:8123
    restart: unless-stopped
    networks:
      - {{ DOCKER_NETWORK }}
    healthcheck:
      test: curl --fail -s http://localhost:8123/ || exit 1
      interval: 30s
      timeout: 10s
      retries: 3
    labels:
      # Enable traefik for container
      - "traefik.enable=true"
      # Use traefik network
      - "traefik.docker.network={{ DOCKER_NETWORK }}"

      {# Generate labels(container_name, port, use_authelia) -#}
      {{ labels(container, '8123', 'y') }}

networks:
  {{ DOCKER_NETWORK }}:
    external: true
