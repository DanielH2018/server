{% from 'traefik.yml.j2' import labels with context %}
---
version: "3.0"
services:
  littlelink:
    image: ghcr.io/techno-tim/littlelink-server:latest
    container_name: littlelink
    environment:
      - META_TITLE=Daniel Hunter
      - META_DESCRIPTION=Software Engineer
      - META_AUTHOR=Daniel Hunter
      - META_KEYWORDS=Engineering
      - LANG=en
      - META_INDEX_STATUS=all
      - OG_SITE_NAME=Daniel Hunter
      - OG_TITLE=Daniel Hunter
      - OG_DESCRIPTION=The home of Daniel Hunter
      - OG_URL=https://www.[REMOVED_KEY]
      - OG_IMAGE=https://media.licdn.com/dms/image/C4E03AQE1RAdnHr2FHQ/profile-displayphoto-shrink_200_200/0/1646779805962?e=1677110400&v=beta&t=J2ZX0AnGIDY9TsHl0LFX4ohLPCjIfeFGZlrdQISH1O8
      - OG_IMAGE_WIDTH=400
      - OG_IMAGE_HEIGHT=400
      - THEME=Dark
      - FAVICON_URL=https://media.licdn.com/dms/image/C4E03AQE1RAdnHr2FHQ/profile-displayphoto-shrink_200_200/0/1646779805962?e=1677110400&v=beta&t=J2ZX0AnGIDY9TsHl0LFX4ohLPCjIfeFGZlrdQISH1O8
      - AVATAR_URL=https://media.licdn.com/dms/image/C4E03AQE1RAdnHr2FHQ/profile-displayphoto-shrink_200_200/0/1646779805962?e=1677110400&v=beta&t=J2ZX0AnGIDY9TsHl0LFX4ohLPCjIfeFGZlrdQISH1O8
      - AVATAR_2X_URL=https://media.licdn.com/dms/image/C4E03AQE1RAdnHr2FHQ/profile-displayphoto-shrink_200_200/0/1646779805962?e=1677110400&v=beta&t=J2ZX0AnGIDY9TsHl0LFX4ohLPCjIfeFGZlrdQISH1O8
      - AVATAR_ALT=Daniel Hunter Profile Pic
      - NAME=Daniel Hunter
      - BIO=Software Engineer @ Publicis Sapient
      # use ENV variable names for order, listed buttons will be boosted to the top
      - BUTTON_ORDER=GITHUB,LINKED_IN
      - GITHUB=https://github.com/DanielH2018
      - LINKED_IN=https://www.linkedin.com/in/daniel-hunter-110952160/
    ports:
      - 3004:3000
    networks:
      - {{ DOCKER_NETWORK }}
    healthcheck:
      test: wget --no-verbose --tries=1 --spider http://localhost:3000/ || exit 1
      interval: 30s
      timeout: 10s
      retries: 3
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    labels:
      # Enable traefik for container
      - "traefik.enable=true"
      # Use traefik network
      - "traefik.docker.network={{ DOCKER_NETWORK }}"

      {# Generate labels(container_name, port, use_authelia) -#}
      {{ labels('www', '3000', 'n') }}

networks:
  {{ DOCKER_NETWORK }}:
    external: true
