{% from 'traefik.yml.j2' import labels with context %}
---
version: "3.8"
services:
  profilarr:
    image: santiagosayshey/profilarr:latest 
    container_name: profilarr
    ports:
     - 6868:6868
    volumes:
     - ./config:/config
    environment:
    - TZ={{ TZ }}
    networks:
      - {{ DOCKER_NETWORK }}
    restart: unless-stopped
    labels:
      # Enable traefik for container
      - "traefik.enable=true"
      # Use traefik network
      - "traefik.docker.network={{ DOCKER_NETWORK }}"

      {# Generate labels(container_name, port, use_authelia) -#}
      {{ labels(container, '6868', 'y') }}

networks:
  {{ DOCKER_NETWORK }}:
    external: true
