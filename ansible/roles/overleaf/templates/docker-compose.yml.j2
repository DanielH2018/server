version: '2'
services:
  sharelatex:
    restart: unless-stopped
    image: sharelatex/sharelatex
    container_name: sharelatex
    networks:
      - {{ DOCKER_NETWORK }}
    depends_on:
      mongo:
        condition: service_healthy
      redis:
        condition: service_started
    ports:
      - 8083:80
    links:
      - mongo
      - redis
    volumes:
      - ~/sharelatex_data:/var/lib/sharelatex
    environment:
      - SHARELATEX_APP_NAME= Overleaf Community Edition
      - SHARELATEX_MONGO_URL= mongodb://mongo/sharelatex
      # Same property, unfortunately with different names in
      # different locations
      - SHARELATEX_REDIS_HOST= redis:6379
      - REDIS_HOST= redis
      - ENABLED_LINKED_FILE_TYPES= 'project_file,project_output_file'
      # Enables Thumbnail generation using ImageMagick
      - ENABLE_CONVERSIONS= 'true'
      # Disables email confirmation requirement
      - EMAIL_CONFIRMATION_DISABLED= 'true'
      # temporary fix for LuaLaTex compiles
      # see https://github.com/overleaf/overleaf/issues/695
      - TEXMFVAR= /var/lib/sharelatex/tmp/texmf-var
    labels:
      # Enable traefik for container
      - "traefik.enable=true"
      # Setup HTTP entrypoint
      - "traefik.http.routers.sharelatex.entrypoints=http"
      - "traefik.http.routers.sharelatex.rule=Host(`sharelatex.{{ DOMAIN }}`)"
      # Redirect HTTP to HTTPS
      - "traefik.http.middlewares.sharelatex-https-redirect.redirectscheme.scheme=https"
      - "traefik.http.routers.sharelatex.middlewares=sharelatex-https-redirect"
      # Setup HTTPS entrypoint
      - "traefik.http.routers.sharelatex-secure.entrypoints=https"
      - "traefik.http.routers.sharelatex-secure.rule=Host(`sharelatex.{{ DOMAIN }}`)"
      - "traefik.http.routers.sharelatex-secure.tls=true"
      # Setup port forwarding to internal port
      - "traefik.http.routers.sharelatex-secure.service=sharelatex"
      - "traefik.http.services.sharelatex.loadbalancer.server.port=80"
      # Use traefik network
      - "traefik.docker.network={{ DOCKER_NETWORK }}"
      # Add authelia
      - 'traefik.http.routers.sharelatex-secure.middlewares=authelia@docker'

  mongo:
    restart: unless-stopped
    image: mongo:4.0
    container_name: mongo
    networks:
      - {{ DOCKER_NETWORK }}
    ports:
      - 27017:27017
    volumes:
      - ~/mongo_data:/data/db
    healthcheck:
      test: echo 'db.stats().ok' | mongo localhost:27017/test --quiet
      interval: 10s
      timeout: 10s
      retries: 5

  redis:
    restart: unless-stopped
    image: redis:5
    container_name: redis
    networks:
      - {{ DOCKER_NETWORK }}
    ports:
      - 6379:6379
    volumes:
      - ~/redis_data:/data

networks:
  {{ DOCKER_NETWORK }}:
    external: true
