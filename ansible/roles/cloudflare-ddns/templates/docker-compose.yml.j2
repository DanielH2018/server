version: '3.8'
services:
  cloudflare-ddns:
    image: local/cloudflare-ddns:latest # Have to build submodule image first
    container_name: cloudflare-ddns
    restart: unless-stopped
    environment:
      - API_KEY={{ CLOUDFLARE_DNS_TOKEN }}
      - ZONE={{ DOMAIN }}
    networks:
      - {{ DOCKER_NETWORK }}
    healthcheck:
      test: curl -fIsS 1.1.1.1 || exit 1
      interval: 30s
      timeout: 10s
      retries: 3

networks:
  {{ DOCKER_NETWORK }}:
    external: true
