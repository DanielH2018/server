version: '2'
services:
  cloudflare-ddns:
    image: oznu/cloudflare-ddns:latest
    container_name: cloudflare-ddns
    restart: unless-stopped
    environment:
      - API_KEY={{ CLOUDFLARE_DNS_TOKEN }}
      - ZONE={{ DOMAIN }}
    networks:
      - {{ DOCKER_NETWORK }}

networks:
  {{ DOCKER_NETWORK }}:
    external: true
