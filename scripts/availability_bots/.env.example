# Copy to `.env` (gitignored) and fill in real values, or export these in the
# environment that runs the bots (cron EnvironmentFile, systemd Environment=, ...).
# Each bot reads ONLY its own pair of variables and exits if one is missing.

# --- glenstone-bot.py ---
GLENSTONE_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/ID/TOKEN
GLENSTONE_HEALTHCHECK_URL=https://healthchecks.example.com/ping/your-uuid-here

# --- osteria-francescana-bot.py ---
OSTERIA_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/ID/TOKEN
OSTERIA_HEALTHCHECK_URL=https://healthchecks.example.com/ping/your-uuid-here

# Optional: log verbosity for all bots (default INFO).
# LOG_LEVEL=DEBUG
